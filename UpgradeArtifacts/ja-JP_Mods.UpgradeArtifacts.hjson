Items: {
	JungleMask: {
		DisplayName: ジャングルの仮面
		Tooltip:
			'''
			召喚ダメージが8%増加
			ミニオンの攻撃が敵に毒を与えることがある
			'''
	}

	PreciousBelt: {
		DisplayName: 尊いベルト
		Tooltip:
			'''
			召喚でできるミニオンの数が1体増え、
			召喚しているミニオン1体ごとに防御力が1増加
			'''
	}

	PredatorOfTheJungle: {
		DisplayName: ジャングルの捕食者
		Tooltip:
			'''
			召喚でできるミニオンの数が1体増え、
			召喚しているミニオン1体ごとに召喚ダメージが3%増加
			ミニオンの攻撃が敵に毒を与える
			ダメージを受けると蜂を放って、使用者を蜂蜜に浸す
			'''
	}

	HeavenlyShield: {
		DisplayName: 神聖な砦
		Tooltip:
			'''
			8防御力
			ダメージの一部を反射する
			ライフが35%以下の際、ダメージを12%軽減
			全ステータスを少し強化
			液体内で素早く動ける
			ほとんどの状態異常に耐性
			プレイヤーの周囲に光を作り出す
			'''
	}

	ObsidianFireBowl: {
		DisplayName: 黒曜石のボウル
		Tooltip:
			'''
			鞭で攻撃時に炎上効果を加える
			鞭の攻撃速度が10%上昇
			炎上に耐性を得る！
			ライフが50%以下の際、獄炎を得る
			'''
	}

	SpiderSwarmNecklace: {
		DisplayName: 蜘蛛の群れのアミュレット
		Tooltip:
			'''
			召喚ダメージが45%減少するが、
			召喚でできるミニオンの数が2倍になり、
			ミニオンの攻撃が敵に毒を与えることがある
			'''
	}

	RegularClover: {
		DisplayName: 普通のクローバー
		Tooltip: ゴルフでは運は当てにならない...
	}

	LuckyCharm: {
		DisplayName: 幸運のお守り
		Tooltip: 運が10%増加
	}

	RoyalAmulet: {
		DisplayName: 高貴なアミュレット
		Tooltip:
			'''
			運が20%増加
			移動速度が15%上昇
			採掘した鉱石を2倍入手できるようになる
			体が光る
			アイテムを拾う距離が広がる 
			スライム系から攻撃を受けない
			エキスパート
			'''
	}

	GripOfTheCursedFlame: {
		DisplayName: 呪いの炎の籠手
		Tooltip:
			'''
			鞭のダメージが12%増加
			鞭のノックバックが増加
			鞭で攻撃した敵を呪いの炎で燃やすことがある
			鞭で一度に攻撃した敵1体ごとに8%上昇し、最大で40%上昇する
			'''
	}

	TalismanOfResonance: {
		DisplayName: 共鳴のタリスマン
		Tooltip:
			'''
			近接攻撃速度が4%上昇
			近接武器で3回攻撃するごとに魔法弾を放つ
			'''
	}

	TowerShieldOfTerror: {
		DisplayName: 恐怖のタワーシールド
		Tooltip:
			'''
			4防御力
			45近接ダメージ
			ノックバック: とても強い
			被ダメージを8%軽減
			被ダメージの一部をライフに変換することがある
			敵に向かってダッシュ攻撃でき、敵を貫通する
			エキスパート
			'''
	}

	ObsidianBracer: {
		DisplayName: 黒曜石の腕当て
		Tooltip:
			'''
			2防御力
			近接攻撃のノックバックを増加
			近接攻撃で黒曜石の鎧を3秒間得て、防御力が5増加する
			'''
	}

	AmuletOfMalice: {
		DisplayName: 地獄のタリスマン
		Tooltip:
			'''
			近接ダメージが6%増加
			近接攻撃速度が5%上昇
			近接武器で攻撃すると幽霊を放つ
			'''
	}

	EmptyRing: {
		DisplayName: 空の指輪
		Tooltip: 1防御力
	}

	InfinityRing: {
		DisplayName: インフィニティリング
		Tooltip:
			'''
			ダメージが10%増加し、攻撃速度が12%上昇
			敵の防御力を5無視する
			最大ライフとマナが40増加し、ライフとマナの自然回復を増進
			移動速度が15%上昇し、ジャンプ速度が増加
			採掘スピードが33%上昇し、被ダメージを5%軽減
			飛行時間を延長し、最大落下速度が上昇
			虹色のオーラで身を守り、触れた敵にダメージを与え、周囲を照らす
			ライフが25%以下になるとラストブレスが発動し、ライフが120回復する
			'''
	}

	SnowBracer: {
		DisplayName: 雪の腕当て
		Tooltip:
			'''
			1防御力
			近接攻撃で敵にスノーウィーを与える
			雪玉が敵を内側から引き裂く
			'''
		
	}

	StellarMarble: {
		DisplayName: 星の大理石
		Tooltip:
			'''
			近接クリティカル率が6%上昇
			近接攻撃でクリティカル時に星が落ちてくる
			'''
	}

	LivingGranite: {
		DisplayName: 御影石のハート
		Tooltip:
			'''
			2防御力
			近接ダメージが10%増加し、近接攻撃速度が8%上昇
			近接武器で敵を攻撃すると火花を放つことがある
			'''
	}

	Mirror: {
		DisplayName: 鏡
		Tooltip: ""
	}

	DistortedMirror: {
		DisplayName: 歪んだ鏡
		Tooltip:
			'''
			クリティカル率が5%上昇
			魔法武器で攻撃時に50%の確率で弾を追加で発射するが、
			消費マナが33%増加
			'''
	}

	BlindEye: {
		DisplayName: 盲目の目
		Tooltip:
			'''
			魔法攻撃速度が10%上昇するが
			魔法武器の弾が拡散しやすくなる
			'''
	}

	AllSeeingEye: {
		DisplayName: 全知の目
		Tooltip:
			'''
			消費マナが10%減少
			魔法攻撃速度が12%上昇
			魔法武器の弾が拡散しやすくなる
			マナスターを拾う距離が広がる
			マナポーションを自動で使用
			'''
	}

	SignOfSpace: {
		DisplayName: 天空の印
		Tooltip:
			'''
			魔法クリティカル率が8%上昇
			魔法武器でクリティカル時にたくさんのハーピーの羽で追撃する
			'''
	}

	FossilizedBone: {
		DisplayName: 化石の骨
		Tooltip:
			'''
			魔法ダメージが15%減少するが、
			魔法攻撃速度が12%上昇し、
			魔法武器の弾の敵の貫通数が1体増える
			'''
	}

	ManaShield: {
		DisplayName: マナアブソーバー
		Tooltip:
			'''
			最大マナが50増加
			被ダメージの25%をマナで吸収するが、
			マナポーションとマナスターの効果がなくなる
