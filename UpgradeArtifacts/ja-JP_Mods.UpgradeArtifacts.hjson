			マナが0になると防具破損を受け、マナによるダメージ吸収が30秒間なくなる
			ダメージを吸収しなくなっている間、マナ自然回復を増進する
			'''
	}

	SilverFeather: {
		DisplayName: 銀の羽根
		Tooltip:
			'''
			遠距離クリティカル率が5%上昇
			遠距離武器でクリティカル時に喀血を与える
			'''
	}

	HunterSign: {
		DisplayName: 狩人の印
		Tooltip:
			'''
			遠距離攻撃速度が8%上昇
			遠距離クリティカル率が6%上昇
			遠距離武器で敵を攻撃すると毒を与えることがある
			'''
	}

	RangerBadge: {
		DisplayName: レンジャーのバッジ
		Tooltip:
			'''
			遠距離攻撃速度が6%上昇
			クリティカル率が4%上昇
			'''
	}

	BlastingBandolier: {
		DisplayName: 爆発弾帯
		Tooltip:
			'''
			遠距離ダメージが8%増加
			弾丸が当たると爆発することがある
			20%の確率で弾薬を消費しない
			'''
	}

	SurvivalKit: {
		DisplayName: 弓兵の道具
		Tooltip:
			'''
			矢の速度が上昇
			矢の敵の貫通数が2体増える
			15%の確率で矢を消費しない
			'''
	}

	SkyCrown: {
		DisplayName: 空の王冠
		Tooltip:
			'''
			召喚ダメージが8%増加
			1秒ごとにハーピーの羽根を1枚生成する（最大で4枚まで）
			羽根は近くの敵を攻撃する
			'''
	}

	SeedOfLife: {
		DisplayName: 生命の種
		Tooltip:
			'''
			動かずにいると、ライフ自然回復を増進
			ライフが50%以下の際、ドライアドの祝福を得る
			'''
	}

	FrozenScale: {
		DisplayName: 氷の鱗
		Tooltip:
			'''
			4防御力
			移動速度が10%低下
			被ダメージ時に敵の動きを遅くする鱗の破片を放つ
			'''
	}

	NecklaceOfBones: {
		DisplayName: 骨のネックレス
		Tooltip:
			'''
			お気に入りに登録するとインベントリ内でも効果を発揮する
			敵の出現率と出現上限が上昇
			'''
	}

	TideShell: {
		DisplayName: 潮の甲羅
		Tooltip:
			'''
			水中にとても長く居られる
			液体内で被ダメージを15%軽減し、光を放つ
			'''
	}

	AntFangs: {
		DisplayName: 蟻の牙
		Tooltip:
			'''
			近接攻撃速度が33%上昇するが、
			近接ダメージが10%減少し、
			近接武器のサイズが20%減少する
			'''
	}

	SwarmComb: {
		DisplayName: 群れのハニカム
		Tooltip:
			'''
			敵を倒すとハチをいくつか召喚することがある
			ジャングルにいると蜂蜜を得る
			'''
	}

	MinerLantern: {
		DisplayName: 故障したランタン
		Tooltip:
			'''
			2防御力
			光を発するが、時折ちらつく
			光を発しているときは宝物や鉱石の位置がわかる
			'''
	}

	NectarOfLife: {
		DisplayName: 生命の蜜
		Tooltip:
			'''
			ライフ自然回復を増進し、回復ポーションの再使用間隔を25%短縮させる
			ダメージを受けると蜂を放って、使用者を蜂蜜に浸し、移動速度が上昇する
			回復ポーションを使用するとあなたを回復するハチを召喚する
			'''
	}

	AuroraVeil: {
		DisplayName: オーロラベール
		Tooltip:
			'''
			6防御力
			ノックバックを無効化し、被ダメージ時の無敵時間を延長する
			ライフが50%以下の際、被ダメージを20%軽減する
			ダメージを受けると敵を追尾する流れ星が降る
			'''
	}

	DollOfSilence: {
		DisplayName: 沈黙の人形
		Tooltip:
			'''
			お気に入りに登録するとインベントリ内でも効果を発揮する
			敵の出現率と出現上限が低下
			'''
	}

	CursedFlameQuiver: {
		DisplayName: 呪いの炎の矢筒
		Tooltip:
			'''
			矢のダメージが12%増加し、矢の速度が大幅に上昇
			25%の確率で矢を消費しない
			矢が当たった敵に呪炎を与える
			'''
	}

	VeteranArcherSign: {
		DisplayName: 熟練弓兵の印
		Tooltip:
			'''
			遠距離ダメージが12%増加
			遠距離クリティカル率が8%上昇
			20%の確率で矢を消費しない
			遠距離武器が追加で弾を発射し、敵の貫通数が1体増えることがある
			'''
	}

	TopazAmberRing: {
		DisplayName: 探検家の指輪
		Tooltip:
			'''
			2防御力
			移動速度が12%上昇し、採掘スピードが15%上昇
			ジャンプの高度と速度が増加
			光を放つ
			'''
	}

	RubySapphireRing: {
		DisplayName: モンクの指輪
		Tooltip:
			'''
			2防御力
			最大ライフとマナが25増加
			ライフとマナの自然回復を増進
			'''
	}

	EmeraldAmethystRing: {
		DisplayName: 破壊の指輪
		Tooltip:
			'''
			2防御力
			ダメージが5%増加し、クリティカル率が5%上昇
			攻撃速度が6%上昇
			敵の防御力を2無視する
			'''
	}

	GhostlySkull: {
		DisplayName: 幽霊のドクロ
		Tooltip:
			'''
			魔法ダメージが10%減少するが、
			魔法攻撃速度が15%上昇
			魔法武器の弾の敵の貫通数が3体増える
