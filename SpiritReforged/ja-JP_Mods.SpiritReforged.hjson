		DisplayName: Otherworldly Duststorm
		Author: "{$By} jakedastardly"
	}

	Ziggurat: {
		DisplayName: Ziggurat
		Author: "{$By} {$Moonbird}, {$Salvati}"
	}

	Salt: {
		DisplayName: Reflected Skies (Salt Flats Day Theme)
		Author: "{$By} {$Sbubby}"
	}

	SaltNight: {
		DisplayName: Refracted Stars (Salt Flats Night Theme)
		Author: "{$By} {$Sbubby}"
	}

	Scarabeus: {
		DisplayName: Soaring Complications (Scarabeus Theme)
		Author: "{$By} {$Sbubby}"
	}

	ScarabeusP2: {
		DisplayName: Soaring Complications (Scarabeus Theme, Phase 2)
		Author: "{$By} {$Sbubby}"
	}

	RadioScarab: {
		DisplayName: Soaring Complications (Radio Edit)
		Author: "{$By} {$Sbubby}"
	}

	TitleTheme: {
		DisplayName: Another Journey (Spirit Title Theme)
		Author: "{$By} {$Salvati}"
	}
}

NPCs: {
	VanillaDialogue: {
		Guide: {
			WorldNPC: 世界を旅していると、他の探検者に出会うことがあるかもしれない。もし出会ったら、互いに助け合ってもいいかも！
			Ecotone: 適切な気候下では、砂漠とジャングルの間には広大なサバンナが広がっている聞いてたから、訪れる事が出来てとても嬉しいよ！
			Savanna: ここの動物の革を使えば、きっとかっこいい装備が作れるだろうね。
			Kelp: 海藻は食べないでね。
		}

		ArmsDealer.Savanna: この一帯は大型動物がうろついてる、きっとお前でも簡単に当てられるぜ！

		Stylist: {
			Savanna: この気候で髪型を維持するの、すごく大変だわ....
			Duststorm: もしもう一人髪の毛から砂を払えなんて言ってきたら、ホントに...
		}

		TravellingMerchant: {
			Cartographer1: 旅の途中、よく迷子の地図製作者に出会うよ。やれやれ、彼女にはいつもハラハラさせられるよ！
			Cartographer2: おっと、{0}だ！先月、彼女が私に道を教えてくれたけど、すぐに溝に落ちてしまうのさ。
			Discoveries: 旅の途中で、たまに珍しいアイテムに遭遇することがある。気をつけて探せば、君も見つけられるかもしれないよ。
		}

		Demolitionist.HasBoomshroom: 君、なに？もっとデカい爆発を起こすキノコ持ってるの？自然って最高！

		Nurse: {
			Duststorm: 外の砂埃で怪我しないでね！そんなの私の給料じゃ対応しきれないよ。
			Savanna: いいえ、私は獣医じゃない！その動物たちをここから出して。
		}

		PartyGirl: {
			Duststorm: うーん、パーティー日和じゃないね。代わりにまったりパーティーでもする？
			Savanna: この広大な空間はパーティーに最適！ねえ、昼間パーティーとかどう？
		}

		Golfer: {
			Duststorm: この砂埃のせいで、いつもよりスコアが悪いんだ！
			Savanna: ここは全部がハザードだ！ボールがいつも茂みや砂、木に引っかかるんだ！
		}

		Zoologist: {
			Savanna1: うわっ、この場所、めっちゃ最高！ここにいる可愛い動物たち、絶対チェックして！
			Savanna2: え、ハイエナに噛まれた？でも、めっちゃ可愛いのに！
		}

		Angler: {
			Pager0: ...なんだよ？ポケベルで魚を渡せるわけないだろ、バカ者！
			Pager1: 魚は必ず『手渡し』で持って来るように
		}

		Wizard.SaltFlats: この周辺の岩は、質の良い水晶玉になりそうだ。
		Painter.SaltFlats: こんなに美しい景色、見たことがない！ 一生ここで描いていたいよ。
		Cyborg.SaltFlats: ...アァ、焼ケルヨウダ
		Mechanic.SaltFlats: うわっ！ 塩のせいで機材が錆びちゃう！ 早くここから出して！
		Truffle.SaltFlats: この場所は我々には不快すぎる...干からびてしまいそうだ...
	}

	Crinoid: {
		DisplayName: ウミシダ
		Entry: この不思議な生き物はヒトデと近しい生態のようだ。いつも海の底に沈むものを食べている。
	}

	Pelican: {
		DisplayName: ペリカン
		Entry: 獲物を捕食する特徴的なクチバシを持つ大きな海鳥。驚かせると獲物を落とすかもしれないけど、それは意地悪だよ。
	}

	TinyCrab: {
		DisplayName: ペールクラブ
		Entry: この愛らしい小さな生き物は、より体の大きい親戚ほど敵対的じゃない。深い水に住んだことで、陽光が少なく色を失った。
	}

	Tubeworm: {
		DisplayName: チューブワーム
		Entry: キラキラした潮の下、光が届かない深いところには、熱水噴出孔から出るスモッグを食べる魅力的な生き物がいる。
	}

	SandPiper: {
		DisplayName: 浜辺のシギ
		Entry: 波が掘り起こす食べ物を求めて海岸線をパトロールする、小さくて勇敢な鳥。
	}

	Gar: {
		DisplayName: ガー
		Entry: 鋭いハンターであり、普段は淡水に住んでいる。ガーと泳ぐときはいつも警戒が必要で、横からでも前からでも、果てには後ろからだって襲ってくる。
	}

	GoldGar: {
		DisplayName: ゴールドガー
		Entry: この貴重ななゴールドガーを美味しいキャビアにするために引き裂こうなんて真似をするのは、モンスターだけだ。そう、モンスターだけ…
	}

	OceanSlime: {
		DisplayName: ココナッツスライム
		Entry: 上から来るぞ！気をつけろ！このずる賢いスライムは海岸にいて、皆がよく知るあのフルーツに巧妙に擬態している。
	}

	DiverZombie: {
		DisplayName: "{$NPCName.Zombie}"
		Entry: 酸素タンクに本物の酸素が必要だなんて、誰が言ったんだ？
	}

	KelpZombie: {
		DisplayName: "{$NPCName.Zombie}"
		Entry: 魚は俺を恐れ、女は俺を恐れ、男は俺を恐れ、子供は俺を恐れる、なぜなら俺はアンデッドだから。
	}

	SailorZombie: {
		DisplayName: "{$NPCName.Zombie}"
		Entry: 今はこんなだけど、生前は良質な豪華クルーザーを運営してたんだ、いつかチェックしてみて。
	}

	TridentZombie: {
		DisplayName: "{$NPCName.Zombie}"
		Entry: そのトライデントは生きてるときに役に立たなかったようだ。まだかなり尖ってるから、気をつけよう。
	}

	Killifish: {
		DisplayName: キリフィッシュ
		Entry: キリフィッシュは名前の通り、死にやすいことで有名だ。美しい虹色の鱗もあるけどね。
	}

	GoldKillifish: {
		DisplayName: ゴールドキリフィッシュ
		Entry: この輝く金色の鱗も、キリフィッシュの悩みを助けてはくれない。
	}

	Termite: {
		DisplayName: シロアリ
		Entry: この小さな虫たちは、複雑なトンネルの巨大な巣を作るために群がる。サバンナの乾いたカリカリの木が彼らの好物だ。
	}

	SavannaSandSlime: {
		DisplayName: "{$NPCName.SandSlime}"
		Entry: ちょっと葉っぱっぽく、砂がなんだか少ない。だが危ないことには変わらない。
	}

	PeevedTumbler: {
		DisplayName: イライラタンブラー
		Entry: サバンナの生活は楽じゃない…でも、まぁ悪くもない。だが目に砂が入ったら、君だってイラつくだろうよ。
	}

	Sparrow: {
		Entry: 森林にいる鳥のいとこで、世界的に有名な鳥と同じく単純明解だ。彼らは飛び回り、シロアリをついばみ、サバンナの空気を楽しんでいる。
		DisplayName: スズメ
	}

	SafariZombie: {
		DisplayName: "{$NPCName.Zombie}"
		Entry: 楽観的に言うなら、すでにゾンビなら蛇だって何の害も及ぼさないよね。
	}

	TumbleZombie: {
		DisplayName: "{$NPCName.Zombie}"
		Entry: ゾンビの姿の裏側...血や枝、胆汁の奥深くに、タンブラーとゾンビが意外な形で友情を育む感動的な物語が隠されている。
	}

	Hyena: {
		DisplayName: ハイエナ
		Entry: いたずら好きなハイエナは群れで狩りを行い、弱い野生動物を狙う。でも、テラリアンには敵対せずに逃げるようだ。
	}

	Ostrich: {
		DisplayName: ダチョウ
		Entry: 空は飛ばないが、驚くほど速く走れる。それを幸運にも、君じゃなく虫を探すのに使ってる。
	}

	ButterflyCritter: {
		DisplayName: エーテルバタフライ
		Entry: 夜空を見上げれば、星の間にもいるかもしれない。彼らはその身体と同じくらい儚いダンスで舞う。
	}

	SavannaJungleSlime: {
		DisplayName: ジャングルスライム
		Entry: 花を飲み込んでしまったようだ！殺すには可愛すぎる…
	}

	Cartographer: {
		DisplayName: 地図製作者
		Buttons.Map: 地図

		Names: {
			0: ソレーナ
			1: カイラ
			2: ジェシー
			3: 「うっかり屋」
			4: ウイン
			5: ネサ
		}

		Dialogue: {
			0: 地図作りは本当に骨が折れるよ～。時々自分がどこにいるか分からなくなっ...え、ちょ、待って!?
			1: ねぇ、しっかりした紙とか持ってない？オレ、全部使い切っちゃってさ！
			2: うわ～、ピン落としちまった！しかも茶色のやつ！見つかるわけねぇ～...
			3: 地図って持ってない？あれば見せてほしいな...できればちゃんと整理されてるヤツ！
			4: 一回その道を見つけるのは運だけどね、二回目は地図が良くねぇとムリなんだ。

			Map: {
				FloatingIsland: {
					0: たしかこの辺だ！ちっこくて可愛い浮島見つけたんだ！...どうやって行ったかって？いや～、ハーピーに運ばれちゃってさ。彼女、結構遠くまで飛べるもんなんだね～！
					1: ほら見て？あのずーーっと上！ちょいとイタズラしてたら、いつの間にか空まで行っちゃった！宝があった気がするけど、途中から無事に帰る方法しか考えてなかった！
					2: ここだここ！空に島があるんだよ。何週間か前に見つけたんだ～！凄く幻想的だったけど、近くにいた連中がうるさくてさ！オレが取り逃がしたもん、君が見つけてくれよな！
				}

				EnchantedSword: {
					0: ここだよここ！狭いトンネルの奥でさ、本当に石に刺さった剣見つけたんだ！伝説とかに出てくるやつ！...けど、ビビっちまって触れなかったんだよ。オレ、選ばれし者って感じじゃないもん！
					1: ここ！一見地味だけど、地下にドーンってキラキラした剣があったんだ！持って帰ろうと思ったけど、ポケットがキノコと地図でパンパンで～...泣く泣く諦めた！
					2: これだ！なんであそこあったのか知らないんだけど、石にぶっ刺さった剣を見つけたんだ！アーサー王？とかの話みたいに！でもオレ、そういう怪しい武器には手ぇ出したくないんだ。君が試してみなよ！
				}

				Shimmer: {
					0:
						'''
						どこだったかな～...あ、ココだ！真っ暗で危なそうな洞窟歩いてたらさ、奥のほうでピッカピカのピンクの光が光ってたの！
						凄く綺麗だったけど...自然界であんな色、絶対やばいと思ってさ。だからオレ、全速力で逃げたよ！
						'''
					1:
						'''
						たぶんこの辺だったと思うんだよな～。海から帰る途中でつまずいて頭をぶつけちゃってね。
						目を覚ましたら、小さな妖精みたいな生き物たちが、奇妙で不思議な場所にオレを運んでたんだ。
						その後のことはあんまり覚えてないけど、気づいたらすごくパニックになってて、妖精たちが慌ててオレを外に連れ出してくれたんだ。
						'''
					2:
						'''
						ここだ。水って見たことあるだろ？それが夜空みたいに光ってるんだ。信じられないほど鮮やかな紫色でね。
						...でも、飲むのはおすすめしない。身体が偽物みたいな感覚になるんだ。うまく説明できないけど...信じてほしい！
						'''
				}

				Savanna: {
					0:
						'''
						よし、ピンを立ててっと...あのね、いつものように朝の散歩をして、リンゴを取るために木を全力で叩いてたんだ。
						何本か殴ったあとでふと見上げたら、いつの間にか草原が広がってたんだよ。
						...ま、しばらく眺めてかまた叩いてたけどね。
						'''
					1:
						'''
						ここ見てくれ！まっすぐ前を見ずに、地面ばかり見て歩いたことってない？あるならもうやめた方がいい。前にそれをやってたら、
						草の色がだんだん鮮やかな緑から病的な緑に変わっていったんだ。
						顔を上げたら、見たこともないほど背の高い草が生えててさ。しかもやたら太い。
						で、どうしたかって？...もちろん、引き返したよ。あそこ歩くのは骨が折れるからね。
						'''
					2:
						'''
						少し前のことなんだけど、ジャングルのコウモリからどれだけ早く逃げられるか試してたんだ。
						そしたら、この辺で空気が急に砂っぽくなってさ。
						目の前にサバンナが広がってたんだよ。素晴らしい光景だった！
						それと念のため言っておくけど...いざとなればオレ、めちゃくちゃ速く走れるってわかったよ！
						'''
				}

				Hive: {
					0: ピンは...ここだ。正直に言うと、あのジャングルの場所はおすすめしない。かなり過酷なんだ。でも、大きなハチの巣を見つけたら、近くにハチミツがあるってことでもある。それはきっと、刺される価値のあるごちそうだよ。
					1: よし、これで完了！ぶっちゃけて言うとね、黄金の液体を見つけたとしても、それだけじゃ割に合わないこともあるんだよ。あの嫌な蜂どもがね...登山気分で行くならいいけど、商売にはしない方がいいね。
					2: この辺をよく見てみて...ここに、君が興味を持つものがあるはずだよ。ただ先に言っておく。針は痛い。覚悟して行くんだ。
				}

				Curiosity: {
					0:
						'''
						ほら、ここだよ。オレはよく歩き回るんだ。景色を見たり、独り言を言ったりしてさ...
						そしたら突然ズッコケてね、地面とごっつンしちゃったよ！
						この辺で何かにつまずいたんだけど、何だったのかは分からない。ムカついて見る気にもならなかったよ。
						'''
					1:
						'''
						たしか...この辺だったかな？まあ近い場所だよ。オレみたいにあちこち探検してると、面白いものに出くわすことも多い。
						たまに「これ凄い価値ありそう！」ってものもね。
						だから言っとくけど、行くなら今だよ？ほかのヤツに取られる前に、ね！
						'''
					2:
						'''
						この辺を見てみな。オレ、地図作る仕事してるだろ？ピンを立てたりして...でもたまに、自分のピンが何のためだったか忘れるんだよな。
						ここ、もう君に譲るよ。オレのただの物忘れなのか、それとも呪われた何かだったのかさえ知らないけど、関わりたくないの。
						'''
				}

				ButterflyShrine: {
					0:
						'''
						ここを見てくれ。この場所だ。寒くて不気味な夜だった。強い風が吹いて、地図がバックパックから飛んでっちまったんだ。
						慌てて拾おうと地面にしゃがんだとき、見つけたんだよ。地面に小さなピンホールみたいな穴が開いてて、それが紫に光ってたんだ！
						オレは関わる気にならなかったけど、君みたいな勇敢な冒険者なら...どうかな？
						'''
					1:
						'''
						この地図のこのポイントだ！どう言えばいいか分からないけど...目の前に小さな光がふわふわ浮かんでることってない？
						ちょ、笑わないでよ...？オレ、この場所で小さなピンクの蝶が飛んでるのを見たんだ。でも実体がないの！
						　						捕まえようとしても、光でできてるみたいで...ああもう、説明できないよぉ！
						'''
					2: オレ、今までにもいくつか穴に足を取られたことはあるけど、紫に光る穴なんて見たのは初めてだったよ。あれはまるで魔法みたいな代物だね。関わらない方がいい...さっさと通り過ぎるべきだよね。
				}

				WulfrumBunker: {
					0: たぶんこの辺だと思う。いつもみたいに歩いてたら、木陰の向こうに妙な緑色の機械施設が見えたんだ。上の方には何か変な装置がたくさんついてて、下からは機械のうなり音が聞こえてきた。...いや、ホント怖かった。
					1: たしかここがキャンプを張ってた場所だ。その日はたくさん歩いたあとで、休んでたんだ。そしたらちっこい機械野郎が来てさ、デカい手でオレのバッグ持ってったんだよ！休憩してなかったら絶対追いつけなかったな。おかげでまた汗だくになって...サイアクだった！
					2: あったあった！あれは忘れられないな。こんな場所で工業施設を見るなんて滅多にない。まあオレとしては静かな方がありがたい。特にあのとき、エネルギーフィールドが現れて金属の破片が飛び始めたときなんか特にそう思った。
				}

				BloodAltar: {
					0: これでよし！地表を記録するのは、まあ“表面”だけの話だ。地下には奇妙なものがたくさんあるけど、たいていは近づかないようにしてる。なんでって？...オレは地図職人であって、冒険者じゃないからね！
					1: ここだな！君ならできる気がする。オレが見つけたのは、話の通じるアンデッドだった。それだけでも十分変なのに、そいつが“手”を売ってきてさ。その手が指した方向に行ってみたら、不気味な地下墓地にたどり着いたんだ...オレはもう二度と行かないけど、君なら何か得られるかも？
					2: 挑戦してみるかい？オレはごめんだけどね。血の匂いが立ちこめる部屋のあるダンジョンがあってさ...その中央に奇妙な祭壇があったんだ。あんなの見たら、普通すぐに引き返すよ。
				}

				SaltFlat: {
					0: 忘れもしないよ！ほら、ここさ！初めて“空を映す鏡”を見た場所さ。いつものように下を見てたら――ドン！ 雲だよ！ 最初はちょっと焦ったけど、ただの浅い水だったみたいだ...たぶんね。安全かどうかは、君が確かめてみなよ。
					1: あそこだって！ 雪の坂で滑ったことある？ 氷でツルツルのやつ！ ないの？ まあ、とにかく前が見えなくなるんだよ、あれ。意図的にね。でもここ、かなりいい景色だよ。雪さえどければおすすめだね。
					2: いつもは転んだ勢いで発見するんだけど、今回は真面目に歩いてたんだ。そしたら、妙に濡れた地面に焦ったあと、絶景が広がってね。本当に見事だった。地図をちゃんと持っていけば、いい時間になるよ。
				}

				Ziggurat: {
					0: ああ...そこだ。オレは地図屋だからな、地図を描くのが仕事でね。だから、崩れた赤レンガのデカくて怪しい壁を見たら、関わるべきかどうか判断するのは得意なんだ。中でブンブン何か鳴ってたけどさ...ま、あとは君に任せる。
					1: あったあった！ 砂漠ってさ、覚えやすいんだよ。何もないからね。だから、いきなり地面から煙が出てたら...気になるだろう？で、覗いたら巨大な建物の表面が見えるわけ。印象に残るよな。あとは任せるよ。オレは溶岩とかごめんだ。
					2: ここだよ。遺跡を見つけるのも仕事の一環さ。大丈夫、手順はちゃんとしてる。...けど、中に入った瞬間に地面から串刺しにされかけてさ。いやあ、オレって走るの得意だったんだなって再認識したよ。
				}

				FirstPin: このピンを君の「ピンコレクション」に追加したよ。マップの左下からいつでも見られるからね！
			}
		}

		Entry: 情熱的な探検心と極端な不器用さが妙に混ざったようなこの地図製作者は、ほとんど誰も探検していない場所へと足を踏み入れる。だが、ときには斬新さよりも安全を優先する。
	}

	Hiker: {
		DisplayName: ハイカー

		Buttons: {
			Feed: 食料提供
			Supplies: 物資
			Silver: 20シルバー
		}

		Dialogue: {
			Hungry: {
				Asking: {
					0: ちょい、そこの見知らぬ者よ、スナックを分けてくれんかのぉ？{0}を譲ってくれるなら、ワシも何かいいものあげようかのぉ。
					1: 家を出てから小腹がすいてくること、ないかのぉ？ワシは今まさにそうじゃ...{0}を、一つ分けてくれんか？
					2: 長き上り坂の探検は本当に疲れるのぉ。本当にクタクタじゃぁ...あぁ、{0}が食べたいのぉ…助けてくれんか？
					3: 最後のプロテインバーを45分前に食べ終えてしもうてのぉ、足がガクガクなんじゃよ。お主、{0}を一つ分けてくれんか？
				}

				Thanks: {
					0: ありがとう、友よ。時には見知らぬ人の優しさも頼りになるもんじゃ。ホレ、この物資を持って行くがよい...見知らぬ者同士のぉ！
					1: ヴァッハッハ、最高じゃぁ！旨いスナックはいつもワシを気前よくさせよるわ、ホレ！タダでこいつらも持っていって良いぞぉ！
					2: 全く、感謝感激じゃ。相棒よ、このパック持って征きたまえ。
					3: 長き探検の後食べる食事ほど最高なものはないのぉ。さあ相棒よ、このパックを持っていけぃ！無料じゃぞ！
				}
			}

			Idle: {
				0: 洞窟の奥底へと突き進む探検ほど心躍るものもない。もっとも、全身がクモの巣まみれになるまでじゃが。そうなっては、さすがに興も冷めてしまうのぉ。
				1: かつての相棒が、松明の代わりにブリンクルートを使って探索しておってのぉ。「この方が安全なの！」じゃと。変な奴じゃったのぉ。あいつは今どうしとるのか...
				2: ピンを使ったことあるかのぉ？とても便利なんじゃ。かつての相棒もいつも持ち歩いておった...最後に話したときは「浮島に登る方法を考えたよ！」って。全く、大変そうな仕事じゃろうて。
				3: 時々妖精に出会うとな、金やプラチナに導いてくれてのぉ。いつも興奮した様子を見せてるんじゃが、ホントはピッケルさえ持ってないんじゃ。だが彼女らが喜んでくれてると嬉しいのぉ。
				4: 賢いやつはいつも予備の物資を持ってるもんじゃ。でも、さすがに背中が痛くてなぁ！持ちすぎたようじゃ...どうじゃ、ポケットで小銭がうずいているようなら、取引してやろうぞ、ヴァッハッハ！
			}

			Purchase: {
				0: お、肩の荷が少し下りたのぉ！じゃが背中の痛みと引き換えに、リュックが重くなるならいつでも大歓迎じゃよ。
				1: ヴァッハッハ、ありがとう、相棒よ！皆がよく「あんた、そんな量の荷物どうやって入れてんだ」って聞いてくるんじゃよ。ああ、安心せい、ワシはお主にそんなこと詮索せんよ！
				2: 見知らぬものよ、よくぞ出会った！良き取引ほど絆を強めるものもなかろうて。
				3: 空いたスペースを有効活用するんじゃぞ！ああ、これは聞いた話じゃが、天使の像をバッグに詰めまくると、驚くようなことが起こるらしいぞ。
				4: 取引に感謝じゃ！花でも楽しみたいところじゃが、おかしな植物がそこらにおるからのぉ。気をつけるんじゃぞ！
			}

			FailPurchase: {
				0: いやぁ、取引と呼ぶにゃあもう少し良い金額を見せてもらわんと。あぁ、食料がポケットでジャマしてるってなら別じゃがな、ヴァッハッハ！
				1: すまんね、ワシこの荷物たちは手放せんよ。もう少し金銭を持ってきてもらわんと。いやいや、時間をかけてでも得る価値があるぞ！それに、ワシの荷物だって減らせるしのぉ。
				2: ダメじゃね、相棒よ。今は取引するつもりはないんじゃ。なに、ただちょっと準備万端すぎただけじゃ。...スナックはちょっと足りんが
			}
		}

		Name: {
			0: ゲイリー
			1: ショーン
			2: ジオ
			3: ジェフ
			4: ロッキー
			5: ポーター
		}

		Entry: 陽気で気楽そうだが、見た目とは裏腹にとても強い。ハイカーはほぼどこへでも行く道を知り尽くしている。ジャングル？お手の物。砂漠？地下雪原？スイスイと。宇宙？どうやってかはわからないけど…彼ならそこにだって行っちゃうさ。
	}

	HideZombieBig: {
		DisplayName: "{$NPCName.Zombie}"
		Entry: ハイエナ達は、毎夜蔓延るゾンビからいつも逃げ隠れなければならない。さもなければ彼らの皮は乗っ取られてしまうだろう。
	}

	HideZombieSmall: {
		DisplayName: "{$NPCName.Zombie}"
		Entry: 彼らの服装は、最新のアンデッドファッションで大流行らしい。
	}

	PotterySlime: {
		DisplayName: 陶芸スライム

		Names: {
			0: セーブル
			1: サキ
			2: サル
			3: サントラ
			4: サーク
			5: ササフラス
			6: サティヤ
			7: サウィル
			8: セッポ
			9: シャミー
			10: シャード
			11: シオ
			12: サイラス
			13: シリカ
			14: シルティ
			15: スリート
			16: スローン
			17: スナップ
			18: ソギー
			19: ソーダ
			20: ソーニャ
			21: スパルタ
			22: スプレット
			23: スポット
			24: ストラットン
			25: サリバン
			26: スウェイン
		}

		Chatter: {
			0: ウッバ・ドゥビドゥー？
			1: ポチャポチャ。ブルン
			2: ワウワウ
		}

		Entry: 信じられないかもしれませんが、このスライムは陶芸の分野で世界的に有名です。あなたは今、今を生きる巨匠の前にいるのです！
		Census.SpawnCondition: 洞窟内で珍しい壺[i:SpiritReforged/BiomePotsCavernItem]を破壊する
	}

	StompableGnome.DisplayName: 踏み潰しノーム

	DunceCrab: {
		DisplayName: ダンスクラブ
		Entry: 冒険中の事故の主な原因の一つであるこの洞窟棲の軟体動物は、しばしば驚きを与えます。洞窟に多く生える苔や地衣類を食します。
	}

	Wheezer: {
		DisplayName: ウィーザー
		Entry: ウィーザーはサラマンダーの極めて毒性の強い近縁種で、攻撃的な行動で知られています。驚くべきことに、肉食の本性を裏切り、彼らはヒイラギの新芽を好んで食す。
	}

	WorldFrog: {
		DisplayName: 頼りになりそうなカエル
		Button: 世界を更新

		Sounds: {
			0: クワッ
			1: リビッ
		}

		Dialogue: {
			0: 探検すべき宝を求めているのなら、我が提案を聞くよう強く勧めよう！
			1: 新たな発見を欲するか？ この両手の間に、運命の提案を紡いだ！
			2: 我が魔法はこの空に欠落を感知す。されど、希望を捨てるな！
		}

		Reports: {
			CavesAndClubs_0: 『ホーカス・ポーカス』憂うな！ 洞窟に新たな宝の壺を満たした！
			CavesAndClubs_1: 『アブラ・カダブラ』汝に新たな壺を授く。地底へ赴けば喜びが待っている！
		}
	}

	MossSlime: {
		DisplayName: 苔スライム
		Entry: 何らかの理由で苔に覆われた好奇心旺盛なスライム達。多くの種類が存在するが、なぜか光る苔のものだけの様...。無料の光源になるかも？
	}

	KryptonMossSlime.DisplayName: クリプトン苔スライム
	LavaMossSlime.DisplayName: 溶岩苔スライム
	NeonMossSlime.DisplayName: ネオン苔スライム
	XenonMossSlime.DisplayName: キセノン苔スライム
	ArgonMossSlime.DisplayName: アルゴン苔スライム
	HeliumMossSlime.DisplayName: ヘリウム苔スライム
	OganessonMossSlime.DisplayName: オガネソン苔スライム
	RadonMossSlime.DisplayName: ラドン苔スライム
	Tumbleweed.DisplayName: 怒れるタンブラー

	Flamingo: {
		DisplayName: フラミンゴ
		Entry: 大きな群れを作り、水中の微生物をこし取って食べている。
	}

	DivingBeetle: {
		DisplayName: ゲンゴロウ
		Entry: 殻の下に空気をため、大きな後ろ脚で水中を泳ぐ。時折、魚がこれに引き寄せられる。
	}

	GoldDivingBeetle: {
		DisplayName: 黄金のゲンゴロウ
		Entry: 稀に、金色の生き物が見つかることがある！店主に高値で売れるし、魚は金色のエサが大好きだ！
	}

	Jerboa: {
		DisplayName: トビネズミ
		Entry: この素早く跳ね回る生き物は乾燥した気候を好み、平坦な砂漠を駆け抜け、サバンナの草地で虫を食べる。
	}

	Grub: {
		DisplayName: スカラベ幼虫
		Entry: スカラベは生まれた時から縄張り意識が強い。この小さな厄介者も、将来は恐るべき存在になるだろう！
	}

	DesertStactus: {
		DisplayName: スタクタス
		Entry: スタクタスは非常におとなしいが、そのトゲのせいで他者と打ち解けるのが苦手である。
	}

	CorruptStactus: {
		DisplayName: コラプションスタクタス
		Entry: スタクタスは非常におとなしいが、そのトゲのせいで他者と打ち解けるのが苦手である。
	}

	CrimsonStactus: {
		DisplayName: クリムゾンスタクタス
		Entry: スタクタスは非常におとなしいが、そのトゲのせいで他者と打ち解けるのが苦手である。
	}

	HallowedStactus: {
		DisplayName: ハロウスタクタス
		Entry: スタクタスは非常におとなしいが、そのトゲのせいで他者と打ち解けるのが苦手である。
	}

	BrineShrimp: {
		DisplayName: ブラインシュリンプ
		Entry: 一般には「シーモンキー」と呼ばれるが、海に生息するわけでもなく、見た目もサルとはまったく異なる。
	}

	GoldenBrineShrimp: {
		DisplayName: 黄金のブラインシュリンプ
		Entry: 金色に輝く珍しい個体で、幸運なフラミンゴを黄金に変えるとされるが、その真偽は定かではない。
	}

	Wisp: {
		DisplayName: ウィスプ
		Entry: 平原を漂う不思議なエネルギーで、刺激しない限りは穏やかに漂っている。わずかな夜明けの気配でも姿を消すことで知られる。
	}

	DecrepitMummy: {
		DisplayName: 老朽ミイラ
		Entry: 侵入者の気配に反応して目覚め、自らの領域を守るために墓から這い出してくる。
	}

	Graverobber: {
		DisplayName: 墓荒らし
		Entry: 彼らは不運にも、叩かれるとピニャータのように金をばら撒く。その様子は財宝にも劣らぬ魅力を持つ...
		HoldingLantern: ランタンを手にしているとき
	}

	LootBag.DisplayName: 戦利品バッグ

	Scarabeus: {
		DisplayName: スカラベウス
		Title: 冠せし偶像
		Entry: 堂々たる姿と玉虫色の輝きを持つこの巨大な甲虫は、かつてジッグラトの住民に神として崇められていた。現在もなお、供物を待ち続けている。
		SpawnInfo: ジッグラトにあるエンシェントアルターで宝石を使う
	}

	TinyGrub.DisplayName: ちび幼虫

	CactusZombie: {
		DisplayName: "{$NPCName.Zombie}"
		Entry: サボテンで死ぬなんて最悪の部類だろう。サボテンで蘇るのも、きっと同じくらいひどい。
	}

	SunburntZombie: {
		DisplayName: "{$NPCName.Zombie}"
		Entry: 太陽を嫌悪するようになり、腐りかけた皮膚を守るため夜間に行動する。
	}

	VeiledZombie: {
		DisplayName: "{$NPCName.Zombie}"
		Entry: 暑さを防ぐ装いだけでは砂漠では生き延びられない。食料と水の確保も重要である。
	}

	Cricket.DisplayName: コオロギ
	GoldCricket.DisplayName: 黄金のコオロギ
}

Origins: {
	Diver: {
		DisplayName: ダイバー
		Flavor: 凄惨な事故の後、ダイバーは新たな土地でまた、次なる海を見ようと懸命だ。
		Description: 古代ダイバーの衣装セット、足ひれ、そしてマーフォークの宝を持って開始する。
	}

	Botanist: {
		DisplayName: 植物学者
		Flavor: いわばハーブ学者。ハーブの収集と使用に非常に熟練している
		Description: かかしのそばで、植物学者の衣装セット、鎌、そしてハーブバッグをいくつか持って開始する。
	}

	Recluse: {
		DisplayName: 引きこもり
		Flavor: 彼らにとって、誰にも邪魔されない地下深くに隠れる方が楽だ。そしてここでの釣りは最高だね！
		Description: 地下の釣り小屋で釣り人の帽子、グラスファイバーの釣り竿、いくつかの餌、松明25個、そして木箱を持って開始する。
	}

	Hunter: {
		DisplayName: ハンター
		Flavor: 野生の獲物が彼らのゲームだ。サバンナに暮らす動物同様、ここでは狩りが全て！
		Description: サバンナでハンティングライフル、弾丸、そしてサファリの衣装セットを持って開始する。
	}

	Hiker: {
		DisplayName: ハイカー
		Flavor: 探求心が楽しさを増幅させ、ここには必要な物資だって揃ってる
		Description: 最高の高さの丘の上で、松明60個、蛍光灯30個、ロープ150本を持って開始する。
	}

	Caveman: {
		DisplayName: 原始人
		Flavor: シンプルな暮らしこそ実りあるものだ。すべてを表す言葉はひとつ・・・『ウグ』
		Description: 革のチュニックと木のこん棒を持ち、地下上層で開始する。
	}

	Disentombed: {
		DisplayName: 墓蘇者
		Flavor: 三千年の眠りを経て...我が時代は再来する。私は戻るのだ。
		Description: ジッグラトでミイラ装備を身に着けた状態で開始する。
	}

	Worshipper: {
		DisplayName: 崇拝者
		Flavor: 太陽へ祈る運命に縛られながら、その姿を見ることはできない。それでもなお希望を捨てない。
		Description: 地下のオアシスにて日輪の踊り子装備とウィンドシアの杖を持って開始する。
	}

	Purifier: {
		DisplayName: 粛清者
		Flavor: 忌むべき悪を払う...我が浄化の力に焼かれよ。
		Description: 塩原で棒の杖とマハーカーラの仮面を持って開始する（可能な場合）
	}
}

