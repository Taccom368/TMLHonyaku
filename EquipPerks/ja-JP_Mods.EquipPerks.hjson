Items: {
	WingStone: {
		Tooltip: 装備している翼の追加効果のオン/オフを切り替える
		DisplayName: ウィングストーン
	}

	ResonateStone: {
		Tooltip: 召喚しているペットの追加効果のオン/オフを切り替える
		DisplayName: レゾネイトストーン
	}

	MinersStone: {
		Tooltip: トロッコに乗っている際、そのトロッコの追加効果のオン/オフを切り替える
		DisplayName: マイナーストーン
	}

	LightStone: {
		Tooltip: 召喚している光源ペットの追加効果のオン/オフを切り替える
		DisplayName: ライトストーン
	}

	PotentialStone: {
		DisplayName: ポテンシャルストーン
		Tooltip: 召喚中のペットと光源ペット、装備している翼、乗っているトロッコの追加効果のオン/オフを切り替える
	}
}

