Configs: {
	Difficulty: {
		Ragnarok: {
			Tooltip: ""
			Label: Ragnarok
		}

		Infernum: {
			Tooltip: ""
			Label: Infernum
		}

		Death: {
			Tooltip: ""
			Label: Death
		}

		Revengence: {
			Tooltip: ""
			Label: Revengence
		}

		Legendary: {
			Tooltip: ""
			Label: Legendary
		}

		Master: {
			Tooltip: ""
			Label: Master
		}

		Expert: {
			Tooltip: ""
			Label: Expert
		}

		AlwaysOn: {
			Tooltip: ""
			Label: 全てオン
		}

		AlwaysOff: {
			Tooltip: ""
			Label: 全てオフ
		}

		Tooltip: ""
	}

	InfernalConfig: {
		ThereIsNoReasonDisableThis: {
			Tooltip:
				'''
				Infernumと統合すると不具合やバランス崩壊が発生する難易度を無効化するための設定です。
				基本的に無効化する理由はありません。
				影響を理解している場合のみ変更してください。
				この設定を無効にした状態での不具合報告は受け付けられません。
				'''
			Label: 無効化しないでください
		}

		MergeThrowerIntoRogue: {
			Tooltip:
				'''
				投擲をローグクラスを統合し、1つの洗練されたクラスにまとめます。
				変換された投擲武器も元のリフォージ効果を維持します。
				ステルスバーのダメージ倍率もそのまま適用されます。
				'''
			Label: 投擲をローグに統合
		}

		AutomaticallyReforgeThoriumRogueItems: {
			Tooltip:
				'''
				消費アイテム以外のThorium産ローグ装備に「完璧な」相当のステータスを自動付与します。
				リフォージできないThorium産ローグ装備をCalamity装備水準に近づけます。
				RagnarokまたはUnofficial Calamity Bard & Healer有効時のみ機能します。
				Merge Thrower Into Rogueが有効な場合、この設定は機能しません。
				'''
			Label: Thorium産ローグ装備を自動強化
		}

		CalamityExpertAccessories: {
			Tooltip: 一部のCalamityボスドロップをエキスパート限定にします。
			Label: Calamityエキスパート装備
		}

		DontEnableThis: {
			Tooltip: 有効化しないでください。ゲームバランスが大きく崩れる可能性があります。
			Label: 有効化しないでください
		}

		MoveDeerclopsChecklistEntry: {
			Tooltip: ディアクロップスをスケルトロンより前に移動し、CalamityおよびInfernumの進行段階に合わせます。
			Label: ディアクロップスの順番を調整
		}

		AutomatedConfigSetup: {
			Tooltip: Infernal Eclipse of Ragnarok向けに他Modの設定を自動調整します。
			Label: 設定を自動調整
		}

		ForceMenu: {
			Tooltip: Mod読み込み時にInfernal Eclipse of Ragnarokのメニューテーマを強制適用します。
			Label: メニューテーマを強制
		}

		ColoredRelics: {
			Tooltip: このModのカラーレリックの有効／無効を切り替えます。
			Label: カラーレリック
		}

		NerfThoriumMulticlass: {
			Tooltip: 吟遊およびヒーラーのマルチクラスが過度に強くならないよう制限を加えます。
			Label: Thoriumマルチクラス弱体化
		}

		MultiplayerRespawnsAllowed: {
			Tooltip: ボス戦中に許可される復活回数を設定します。
			Label: マルチプレイ復活回数
		}

		MinimumDifficultyToPreventRespawns: {
			Tooltip: 復活制限を適用する最低難易度を設定します。
			Label: 復活制限の最低難易度
		}

		MultiplayerBossRespawnTimer: {
			Tooltip: ボス戦中の復活までの待機時間を設定します。
			Label: ボス戦復活時間
		}

		AdjustAdvisorSpawnConditions: {
			Tooltip:
				'''
				アドバイザーが常時出現状態にならないよう出現条件を調整します。
				Infernumボスバー使用時に常時表示を防ぎたい場合に有効です。
				マルチプレイで問題が発生する可能性があります。その場合は無効にしてください。
				'''
			Label: アドバイザー出現条件を調整
		}

		EnableInterlude4: {
			Tooltip:
				'''
				第4間奏曲の有効／無効を切り替えます。
				Exoメカとカラミタス撃破後に再生されます。
				再生中はTheir FabricatorとAcceptanceを上書きします。
				'''
			Label: 間奏曲4を有効化
		}

		DisplayWorldEntryMessages: {
			Tooltip: ワールド入場時メッセージの表示／非表示を切り替えます。
			Label: ワールド入場メッセージ表示
		}

		ChanageWeaponClasses: {
			Tooltip: 一部武器のクラスを変更し、多様性や整合性を向上させます。
			Label: 武器クラス変更
		}

		BloodOrbPotionDuplication: {
			Tooltip: ブラッドオーブポーションのレシピを複製レシピに変更します。
			Label: ブラッドオーブポーション複製化
		}

		MergeCraftingTrees: {
			Tooltip: 複数Mod間の類似アイテムのクラフトツリーを統合し、クロスMod素材を追加します。
			Label: クラフトツリー統合
		}

		AdditonalVanillaBossAdjustments: {
			Tooltip: 一部バニラボスの性能をわずかに強化します。
			Label: バニラボス調整
		}

		DisableDuplicateContent: {
			Tooltip: 複数Modで重複するコンテンツを無効化します。
			Label: 重複コンテンツ無効化
		}

		DisableUnfinisedContent: {
			Tooltip: 未完成コンテンツを無効化し、体験の一貫性を保ちます。
			Label: 未完成コンテンツ無効化
		}

		PreventBossCheese: {
			Label: ボス攻略の抜け道防止
			Tooltip: 特定ボスを容易に倒せる戦法を防ぐ仕組みを追加します。
		}

		DisableBloodOrbPotions: {
			Label: ブラッドオーブポーション無効化
			Tooltip: ブラッドオーブを使用するポーションのレシピを無効化します。
		}

		SOTSThrowerToRogue: {
			Label: ヴォイド＋投擲とローグを統合
			Tooltip: Unofficial SOTS Bard, Thrower, and Healerのヴォイド＋投擲装備をヴォイド＋ローグ装備に変更します。
		}

		ForceFullXerocDialogue: {
			Tooltip: ボスラッシュ開始時およびクリア時にゼロックの全台詞を強制表示します。サーバー向けです。
			Label: ゼロック台詞を完全表示
		}

		InfernumRecipeTweaks: {
			Label: Infernumレシピ調整
			Tooltip: 一部Infernumレシピを調整します。
		}

		ConsolariaBalanceChanges: {
			Label: Consolariaバランス調整
			Tooltip: Consolaria装備をCalamity基準に調整します。
		}

		SOTSBalanceChanges: {
			Label: Secrets of the Shadowsバランス調整
			Tooltip: Secrets of the Shadows装備をCalamity基準に調整します。
		}

		InfernumModeForced: {
			Label: Calamity難易度固定
			Tooltip:
				'''
				ボス戦外でもCalamity難易度スライダーを固定します。
				有効化前に難易度を設定してください。
				難易度変更を防ぎたいサーバー向けです。
				'''
		}

		TerraBladeBossInBossRush: {
			Label: ボスラッシュにYouボス追加
			Tooltip: ボスラッシュにテラブレードを追加します。
		}

		DisplayName: メイン設定

		VanillaBalanceChanges: {
			Label: バニラバランス調整
			Tooltip: 一部バニラ装備をCalamity基準に調整します。
		}

		BossKillCheckOnOres: {
			Label: Calamity進行段階を維持
			Tooltip:
				'''
				本来の段階まで特定アイテムを入手不可にします。
				特定ボス撃破まで一部鉱石やタイルを採掘不可にします。
				'''
		}

		CalamityBalanceChanges: {
			Label: Calamityバランス調整
			Tooltip:
				'''
				性能が貧弱または過剰なCalamityおよび関連アドオン装備を調整します。
				一部クロスModレシピもバランス維持のため調整します。
				'''
		}

		CalamityRecipeTweaks: {
			Label: Calamityレシピ調整
			Tooltip: 一部Calamityレシピを調整し、多くのバニラQOLレシピを削除します。
		}

		ThoriumBalanceChangess: {
			Label: Thoriumバランス調整
			Tooltip: Thoriumおよび関連アドオン装備をCalamity基準に調整します。
		}

		Headers: {
			Secret: シークレット設定
			Main: メイン
			MultiplayerAdjustments: マルチプレイ調整・ユーティリティ
			Miscellaneous: その他
			BalanceChanges: バランス調整
			BossRushChanges: ボスラッシュ設定
		}

		DreadnautillusInBossRush: {
			Label: ボスラッシュにドレッドノーチラス追加
			Tooltip: ボスラッシュにドレッドノーチラスを追加します。
		}

		BetsyInBossRush: {
			Label: ボスラッシュにベッツィ追加
			Tooltip: ボスラッシュにベッツィを追加します ※現在不具合あり
		}

		WrathoftheGodsBossesInBossRush: {
			Label: Wrath of the Godsボスをボスラッシュに追加
			Tooltip: XG-07 マーズ、虚無の化身、無名の神をボスラッシュに追加します。
		}
	}
}

BullyingTooltip:
	'''
	未使用の召喚スロット1つにつき召喚以外のダメージを2%増加
	使用中の召喚スロット1つにつき召喚ダメージを10%減少
	ムチは召喚ボーナスではなく近接補正でダメージが計算されるようになる
	ムチのダメージを10%増加
	[c/E3AF40:ディランが設計したプログラムメモリー付きの紙切れ]
	[c/BEBEBE:「左Shift」で裏面のメモを読む]
	'''

