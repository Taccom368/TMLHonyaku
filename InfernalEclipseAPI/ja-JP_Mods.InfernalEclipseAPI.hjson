SpawnInfo: {
	PrimordialWyrmHead: 深淵の最深部に古代の遺物が眠っているようだ...
	Dreadnautilus: ブラッドムーンの夜に釣りをしていると出現することがある
}

Buffs: {
	CrimulanAura: {
		Description: 移動が大きく妨げられている！
		DisplayName: クリムランのオーラ
	}

	DefaultSummonTag: {
		Description: Mods.InfernalEclipseAPI.Buffs.DefaultSummonTag.Description
		DisplayName: デフォルト召喚タグ
	}

	LowGround: {
		Description: 移動速度が大幅に低下している！
		DisplayName: 低地
	}

	VoidSickness2: {
		Description: ヴォイドダメージが軽減されている！
		DisplayName: ヴォイド酔い
	}

	BubbleShock: {
		Description: これ以上バブルの影響を受けるわけにはいかない！
		DisplayName: バブルショック
	}

	BrokenOath: {
		Description: 害をなすなかれ ― ヒポクラテス
		DisplayName: 破られた誓い
	}

	AnchoredSoul: {
		Description: 魂が別の場所に固定されている
		DisplayName: 錨に繋がれた魂
	}

	WarpJammed: {
		DisplayName: ワープ妨害
		Description: ドレイドンがテレポートを監視している...
	}

	StarboundHorrification: {
		DisplayName: 星縛の恐怖
		Description: アストラゲルドンからは逃れられない...
	}
}

