		DropIdolFragments: {
			Label: 霊像の代わりに霊像の破片をドロップする
			Tooltip: 
				'''
				オンにすると敵は完全な霊像ではなく霊像の破片をドロップします
				ユニークな霊像は通常通りドロップします
				霊像の破片は商人と交換して霊像を買うことができる
				'''
		}

		IdolFragmentDropRate: {
			Label: 霊像の破片のドロップ率
			Tooltip: 霊像の破片のドロップ率を変更します
		}
	}

	IdolStatsMultiplierConfig: {
		DisplayName: 霊像のステータスの倍率設定

		Headers: {
			GlobalMultiplier: グローバル倍率
			IdolSizeMultipliers: 霊像ごとの倍率
		}

		GlobalStatMultiplier: {
			Label: グローバルのステータス倍率
			Tooltip:
				'''
				ユニークでない全ての霊像に適用されるグローバルの倍率
				例: 0.5に設定すると、ユニークでない全ての霊像の強さが半分になります
				'''
		}

		SmallIdolMultiplier: {
			Label: 小さな霊像の倍率
			Tooltip:
				'''
				1x1サイズ（通常）の霊像の倍率
				デフォルト = 1
				'''
		}

		HybridIdolMultiplier: {
			Label: ハイブリッド霊像の倍率
			Tooltip:
				'''
				1x2か2x1サイズ (ハイブリッド)の霊像の倍率
				デフォルト = 2
				'''
		}

		ClassIdolMultiplier: {
			Label: クラス霊像の倍率
			Tooltip:
				'''
				1x3か3x1サイズ (クラス)の霊像の倍率
				デフォルト = 3
				'''
		}

		AdornedIdolMultiplier: {
			Label: 彩られたクラス霊像の倍率
			Tooltip:
				'''
				2x2サイズ(彩られた)の霊像の倍率
				デフォルト = 4
				'''
		}
	}
