	PackYellow: {
		DisplayName: パック (黄)
		Tooltip:
			'''
			パックに既に入っているアイテムを自動的に保管する
			インベントリ内のパックの中身は、クラフトに使用できる
			右クリックで開く
			'''
	}	

	PaintBucket: {
		DisplayName: ペイントバケツ
		Tooltip:
			'''
			ペンキを自動的に保管する
			インベントリ内のバケツの中身は、クラフトに使用できる
			右クリックで開く
			バケツ内のペンキは、最初のペンキがバケツの中に入っているなら使用される
			バケツ内のペンキがお気に入りに登録されている場合、お気に入りに登録したペンキのみを使用する
			'''
	}

	PortableStation: {
		DisplayName: 携帯ステーション
		Tooltip:
			'''
			作業台とバフステーションを動的に保管する
			インベントリ内のステーションの中身は、クラフトに使用できる
			右クリックで開く
			インベントリにあるなら、デフォルトで最大1つの作業台を使用できる
			設置すると、デフォルトで全ての作業台を使用できる、効果範囲は通常のブロック範囲内
			各作業台はインベントリを共有する
			ステーション内の使用できる作業台は背景が黄色になり、近くに同じ作業台がある場合は背景が紫色になるが、
			携帯ステーションから作業台を選択する際、近くの作業台を自動的にスキップはしない
			インベントリにあるなら、デフォルトで最大1つのバフステーションのバフが付与される
			設置すると、デフォルトで全てのバフステーションのバフが付与されるが、バフの範囲は通常
			バフが付与されているアイテムは背景が明るい緑色になり、
			すでに得ているバフはスキップされ、背景が紫色になる
			設置中にテーブルを開くと、アクティブになっている全てのバフステーションのバフを得る
			'''
	}

	PotionFlask: {
		DisplayName: ポーションの瓶
		Tooltip:
			'''
			ポーションと食品を自動的に保管する
			インベントリ内の瓶の中身は、クラフトに使用できる
			右クリックで開く
			クイックバフはバッグ内の食品とお気に入りに登録したポーションを使用する
			クイックヒールはバッグ内の回復アイテムを使用する
			クイックマナはバッグ内のマナ回復アイテムを使用する
			瓶の中の食品、ライフ回復アイテム、マナ回復アイテムがお気に入りに登録されている場合、
			お気に入りに登録したアイテムのみを使用する
			ポーションのバフは、通常通りバフを解除するのと同じように右クリックするか、
			ポーションのお気に入りを解除すると一時停止できる
			バフを付与中のポーションは緑色の背景で表示され、一時停止中のポーションは黄色の背景で表示される
			一時停止中のバフは、クイックバフを使用するか、瓶の中のポーションをお気に入りに登録することで再開できる
			ポーションのバフは、死亡時も死亡前の持続時間で維持される
			すでにポーションのバフを受けている状態で新たなバフを得た場合、持続時間が加算される
			Shiftを押しながらバフを解除すると、バフは一時停止ではなく完全に削除される
			'''
	}

	SlayersSack: {
		DisplayName: スレイヤーの袋
		Tooltip:
			'''
			敵がドロップした素材や、たいまつ、ロープ、鍵などのアイテムを自動的に保管する
			インベントリ内の袋の中身は、クラフトに使用できる
			右クリックで開く
			袋を左クリックすると、袋からロープを配置できる
			袋の中のロープがお気に入りに登録されている場合、お気に入りに登録したロープのみを使用する
			Shiftを押しながら使うと松明や蛍光棒をインベントリにあるかのように使用できる
			'''
	}

	SpookyGourd: {
		DisplayName: 不気味なひょうたん
		Tooltip:
			'''
			Spooky Modのアイテムを自動的に保管する
			インベントリ内のひょうたんの中身は、クラフトに使用できる
			右クリックで開く
			'''
	}

	TrashCan: {
		DisplayName: ゴミ箱
		Tooltip:
			'''
			アイテムを自動的に売却するのに使う
			インベントリ内のゴミ箱の中身は、クラフトに使用できる
			右クリックで開く
			ゴミ箱は他のバッグと同様に機能するが、いくつかの例外がある
			各種類のアイテムは1つしか収納できず、同じ種類のアイテムがすでにある状態で新しいアイテムを追加すると、
			新しく追加されたアイテムは売却される
			ゴミ箱を空にするをクリックで、お気に入りに登録していないゴミ箱内のアイテムが全て売却される
			'''
	}

	WallEr: {
		DisplayName: ウォーラー
		Tooltip:
			'''
			壁材（壁、フェンス、梁など）を自動的に保管する
			インベントリ内のウォーラーの中身は、クラフトに使用できる
			右クリックで開く
			ウォーラーを左クリックすることで、ウォーラーからアイテムを配置できる
			ウォーラー内のアイテムがお気に入りに登録されている場合、お気に入りに登録したアイテムのみを使用する
			'''
	}

	OreBag: {
		DisplayName: 鉱石バッグ
		Tooltip: ""
	}
}

