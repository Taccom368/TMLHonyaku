#

Configs: {
	BagsClientConfig: {
		BagStorageOptions: バッグ設定
		DisplayName: クライアント設定
		LoggingInformation: ログ情報

		AllAmmoItemsGoIntoAmmoBag: {
			Label: 弾薬類は全て弾薬バッグに入れる
			Tooltip:
				'''
				オンだと、あらゆる武器の弾薬は全てバッグに入ります
				オフだと、ホワイトリストに入った弾薬のみが入り、星などの一部のアイテムは除外されます
				'''
		}

		AllOtherCreateTileItemsIntoBuildersBox: {
			Label: その他全てのタイルアイテムを建築士の箱に入れる
			Tooltip:
				'''
				オンだと、使用時にタイルを生成するアイテムは全て、他のバッグのホワイトリストに既に登録されていない限り、
				建築士の箱のホワイトリストに追加されます
				これはほとんどの家具を対象とするはずですが、意図しないアイテムも含まれてしまう可能性があります
				'''
		}

		PortableStationPassiveBuffsOnlyActiveIfFavorited: {
			Label: 携帯ステーションのバフは、お気に入り登録のみ有効
			Tooltip: オンだと、お気に入りに登録したバフステーションのバフだけを得ます
		}

		PrintWikiInfo: {
			Label: 全てのwiki情報をログに記録する
			Tooltip:
				'''
				ワールドに入ると情報はclient.logに記録されます
				client.logのデフォルトの場所はC:\Steam\SteamApps\common\tModLoader\tModLoader-Logsです
				'''
		}

		SilencePortableStationActiveBuffs: {
			Label: 携帯ステーションのバフを付与する際、静かにする
			Tooltip: これをオンにすると、携帯ステーションは、ステーションを開いた際に有効なバフを付与する際、効果音が鳴りません
		}

		SimpleBagsVacuumAllItems: {
			Label: シンプルなバッグが全てのアイテムを吸引する
			Tooltip:
				'''
				オンだと、全てのアイテムがシンプルなバッグに吸引されます
				オフだと、バッグ内のアイテムと同じ種類のアイテムのみを吸い込みます
				'''
		}

		TurnOffRegularPotionFlask: {
			Label: 通常のポーションの瓶を無効にする
			Tooltip: オンにすると、通常のポーションの瓶の全ての効果が無効になります（高級ポーションの瓶には影響しません）
			}
	}

	BagsServerConfig: {
		BagEffectOptions: バッグのエフェクト設定
		Crafting: クラフト
		DisplayName: サーバー設定

		BannerBagNumberOfBannersInInventory: {
			Label: バナーバッグ内の有効になるバナーの数
			Tooltip:
				'''
				バナーバッグがインベントリにある場合、バッグ内の最初のX個のバナーがバフを付与します
				バナーをお気に入りに登録すると、お気に入りに追加していないバナーよりも優先してバフが付与されます
				-1に設定するとバッグ内の全てのバナーのバフが付与されます
				'''
		}

		BannerBagNumberOfBannersWhenPlaced: {
			Label: バナーバッグを配置時に有効になるバナーの数
			Tooltip:
				'''
				バナーバッグをワールドに設置すると、バッグ内の最初のX個のバナーがバフを付与します
				バナーをお気に入りに登録すると、お気に入りに追加していないバナーよりも優先してバフが付与されます
				-1に設定するとバッグ内の全てのバナーのバフが付与されます
				'''
		}

		HarderBagRecipes: {
			Label: バッグのレシピを難しくする
			Tooltip: バッグの作成に必要な素材が増え、入手が難しくなります
		}

		PortableStationCanGiveHoneyBuff: {
			Label: 携帯ステーションは蜂蜜を付与する
			Tooltip: オンにすると携帯ステーションが蜂蜜を付与するようになります
		}

		PortableStationMustBeTouchedToGetHoneyBuff: {
			Label: 蜂蜜を得るには携帯ステーションに触れる必要がある
			Tooltip:
				'''
				オンだと、携帯ステーションから蜂蜜を得るには、
				携帯ステーションに蜂蜜入りバケツを入れ、ステーションに触れる必要があります
				オフだと、携帯ステーションに近づくと蜂蜜を得ます
				ステーションに底なしの蜂蜜バケツを入れた場合、設定に関わらず効果範囲は有効になります
				'''
		}

		PortableStationNumberOfPassiveBuffStationsInInventory: {
			Label: 携帯ｽﾃｰｼｮﾝ内の有効になるﾊﾞﾌｽﾃｰｼｮﾝの数
			Tooltip:
				'''
				携帯ステーションがインベントリにある場合、中に入れた最初のX個のステーションがバフを付与します
				ステーションをお気に入りに登録すると、お気に入りに追加していないステーションよりも優先してバフが付与されます
				-1に設定すると中に入れた全てのステーションのバフが付与されます
				水の蝋燭、平和の蝋、燭影の蝋燭は、お気に入りに追加しない限り有効にならず、バフの上限にもカウントされません
				'''
		}

		PortableStationNumberOfPassiveBuffStationsWhenPlaced: {
			Label: 携帯ｽﾃｰｼｮﾝを配置時に有効になるﾊﾞﾌｽﾃｰｼｮﾝの数
			Tooltip:
				'''
				携帯ステーションをワールドに設置すると、中に入れたの最初のX個のステーションがバフを付与します
				ステーションをお気に入りに登録すると、お気に入りに追加していないステーションよりも優先してバフが付与されます
				-1に設定すると中に入れた全てのステーションのバフが付与されます
				水の蝋燭、平和の蝋、燭影の蝋燭は、お気に入りに追加しない限り有効にならず、バフの上限にもカウントされません
				'''
		}

		PortableStationNumberOfStationsInInventory: {
			Label: 携帯ｽﾃｰｼｮﾝの有効になる作業台の数
			Tooltip:
				'''
				携帯ステーションがインベントリにある場合、中に入れた最初のX個の作業台がクラフトに利用できます
				作業台をお気に入りに登録すると、お気に入りに追加していない作業台よりも優先されます
				-1に設定すると中に入れた全ての作業台がクラフトに利用できます
				'''
		}

		PortableStationNumberOfStationsWhenPlaced: {
			Label: 携帯ｽﾃｰｼｮﾝを配置時に有効になる作業台の数
			Tooltip:
				'''
				携帯ステーションをワールドに設置すると、中に入れたの最初のX個の作業台がクラフトに利用できます
				作業台をお気に入りに登録すると、お気に入りに追加していない作業台よりも優先されます
				-1に設定すると中に入れた全ての作業台がクラフトに利用できます
				'''
		}

		PortableStationsActivateActiveBuffsWhenOpened: {
			Label: 携帯ステーションは、開くとバフを付与する
			Tooltip: オンにすると、携帯ステーションを開くとバフステーションからバフを得ます
		}

		PotionFlaskSavesBuffsOnDeath: {
			Label: 死亡時にポーションの瓶のバフが残る
			Tooltip:
				'''
				オフだと、死亡時に得ていたポーションのバフはリスポーン時に残りの持続時間でプレイヤーに付与されます
				高級ポーションの瓶は、設定に関係なく、常にこの効果を発揮します
				'''
		}
	}
}

Items: {
	AmmoBag: {
		DisplayName: 弾薬バッグ
		Tooltip:
			'''
			投擲武器、矢、弾丸、照明弾、環境変更液を自動的に保管する
			インベントリにあるなら、バッグの中身はクラフトに使用できる
			右クリックで開く
			バッグ内の弾薬は、最初の弾薬が弾薬バッグの中に入っているなら使用される
			選択中の武器で使用できる弾薬がバッグ内にお気に入りに登録されている場合、お気に入りに登録した弾薬のみを使用する
			'''
	}

	BagBlack: {
