		Tooltip:
			'''
			パックに既に入っているアイテムを自動的に保管する
			インベントリ内のパックの中身は、クラフトに使用できる
			右クリックで開く
			'''
	}

	PackPink: {
		DisplayName: パック (ピンク)
		Tooltip:
			'''
			パックに既に入っているアイテムを自動的に保管する
			インベントリ内のパックの中身は、クラフトに使用できる
			右クリックで開く
			'''
	}

