Items: {
	AridCore: {
		DisplayName: 古代のスカラベ
		Tooltip:
			'''
			カーソルの周囲に砂のオーラを発生させ、オーラ内の敵は被ダメージが18%増加
			敵がオーラから出ても1.5秒間は被ダメージが増加するが、徐々に増加量が減っていく
			視線が通っていないと効果がない
			'''
	}

	BeetleBoot: {
		DisplayName: 甲虫のガントレット
		Tooltip:
