Configs: {
	ConfigurationsIndividual: {
		DisplayName: ローカル構成

		Headers: {
			Audio: 音
			Visual: 表示
		}

		NoPain: {
			Tooltip: 一部のアイテムが発する音声テキストを無効にします
			Label: 音声テキストを無効にする
		}

		NoMessage: {
			Label: 特定のチャットメッセージを無効にする
			Tooltip:
				'''
				ボス/特定のアイテムから表示される特定のチャットメッセージを無効にします
				ワールドイベントのステータスメッセージは引き続き表示されます
				'''
		}

		NoShake: {
			Tooltip: このModの画面が揺れる効果を無効にします
			Label: 画面揺れ効果を無効にする
		}

		ShakeAmount: {
			Label: 画面揺れ効果の強さ
			Tooltip: 
				'''
				画面揺れの強さを変更します
				0に設定すると無効になります
				デフォルトは5
				'''
		}
	}

	ConfigurationsGlobal: {
		DisplayName: グローバル構成

		Headers: {
			EnemyMisc: 敵のその他
			EnemySpawning: 敵の出現
			GenMisc: その他
			AprilFools: エイプリルフールのイベント
		}

		PreventBossStorm: {
			Tooltip: オフにするとこのModのボスが生きている場合の天候の変更を無効にします
			Label: ボスの天候変更を無効にする
		}

		PreventBuffedDerps: {
			Tooltip: オフにするとプランテラを倒してもダープリングが強化されなくなります
			Label: ダープリングの強化を無効にする
		}

		StormBossSkipsPlant: {
			Tooltip: オンにするとオーバーロードスキャンドローンを倒した後、プランテラ撃破後の要素が追加されるようになります
			Label: ｵｰﾊﾞｰﾛｰﾄﾞｽｷｬﾝﾄﾞﾛｰﾝはﾌﾟﾗﾝﾃﾗの代わりとして機能する
		}

		NoMoonling4U: {
			Label: ムーンリングの自然出現を無効にする
			Tooltip: 
				'''
				オンにすると宇宙でムーンリングが出現しなくなります
				ムーンリングのコアで召喚できます
				'''
		}

		PreventPillarEnemies: {
			Tooltip: オンにするとこのModの新しいピラーの敵が出現しなくなります
			Label: ピラーのMod追加の敵の出現を無効にする
		}

		NoChestforu: {
			Tooltip: オンにすると御影石、大理石、キノコの宝箱が追加で生成されなくなります
			Label: 御影石、大理石、キノコの宝箱の追加生成を無効化する
		}

		NoScaryCurse: {
			Tooltip: オンにするとこのModの寺院のアイテムがインベントリ内にあっても寺院の呪いが発動しなくなります
			Label: 寺院の呪いを無効にする (推奨されません)
		}

		GlassSoWeak: {
			Tooltip: オンにするとこのModのガラスの武器と道具が1回で壊れるようになります
			Label: ガラスの武器と道具が必ず1回で壊れる
		}

		AFTouchGrass: {
			Label: (2025) タッチグラスモード (バランスが悪くテストされていない)
			Tooltip: 
				'''
				タッチグラスモードをオンにするための特別な草の種を作成できるようになります
				オフにするとワールドのタッチグラスモードがオフになります
				'''
		}

		AFGacha: {
			Label: (2026) 金のペインマスクのガチャシステム
			Tooltip:
				'''
				オンにするとペイントークンを入手できるようになり、
				金のペインマスクを入手できるようになります
				オフにしてもクールダウンと天井カウントはリセットされません
				'''
		}
	}
}

