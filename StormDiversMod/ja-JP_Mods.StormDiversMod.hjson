	PainMusicBoxitem: {
		DisplayName: オルゴール (アルティメットペイン)
		Tooltip: 「アルティメットペインに耐えた者の証」
	}

	ShockBand: {
		DisplayName: 嵐のお守り
		Tooltip: クリティカルが出ると近くの敵にも電撃で攻撃する
	}

	ShockQuiver: {
		DisplayName: 電撃の矢筒
		Tooltip:
			'''
			矢のスピードとダメージが10%増加
			20%の確率で矢を消費しない
			クリティカルが出ると近くの敵にも電撃で攻撃する
			'''
	}

	ShockEye: {
		DisplayName: 嵐の目
		Tooltip:
			'''
			運が大きく増加
			クリティカル時のダメージが12%増加
			クリティカルが出ると近くの敵にも電撃で攻撃する
			'''
	}

	ZephyrFeather: {
		DisplayName: ゼファーの羽根
		Tooltip: 永久に移動速度と加速度が10%上昇
	}

	CleansingHeart: {
		DisplayName: 浄化のお守り
		Tooltip:
			'''
			全ての永続するシマーの強化と手作りパンの効果を削除し、アイテムが戻ってくる
			現在消費したアイテムの効果がなくなる
			'''
	}

	SpectreStarPickup: {
		DisplayName: スペクトルスター 
		Tooltip: 拾うとマナが100回復し、スペクターの星の強化を5秒間得る
	}

	GalacticBat: {
		DisplayName: ギャラクティックベースボーラー
		Tooltip:
			'''
			攻撃が敵に当たるとチャージが1増加し、チャージは最大で10まで溜められる
			チャージが最大まで溜まると右クリックで必ずクリティカルし、敵の防御力を15無視する強力な攻撃を行う
			さらに破損を5秒間与え、被ダメージを10%増加させ、ライフを徐々に減少させる
			敵に当たらないと再度チャージする必要はない
			「ルールは…破られるためにある！」
			'''
	}

	IOUBannerItem: {
		DisplayName: IOUのバナー
		Tooltip:
			'''
			特定の素材と組み合わせると、このModのあらゆるバナーに変換できる
			バナーシステムが変更されたため、古いバナーが全て削除され、
			全てのバナーが同じタイルIDを共有する新しいシステムに置き換えられた
			そのため、古いバナーを直接1対1で変換することはできない
			'''
	}

	TouchGrassSeed: {
		DisplayName: 特別な草の種
		Tooltip:
			'''
			使用するとこのワールドでタッチグラスモードがオンになる
			このモードでは、5分内に草ブロックの上に立たないと、様々なペナルティが課せられる
			代わりに草の上に立つと、多くのバフが得られる
			Shiftを押しながら操作すると、効果を確認できる
			この操作は元に戻せない為、自己責任で使うこと！
			'''
	}

	ABladeofGrass: {
		DisplayName: 草の剣
		Tooltip:
			'''
			文字通りそれだけ、何を期待していたの？
			本物の草に触れたことにはならない
			'''
	}

	GlassSword: {
		DisplayName: ガラスの剣
		Tooltip:
			'''
			敵を攻撃すると、壊れて持続ダメージを与えることがある
			壊れた後は修復できる
			「これはあまり良い考えとは思えない…」
			'''
	}

	GlassSwordBroken: {
		DisplayName: 壊れたガラスの剣
		Tooltip: 「ガラスの剣に何を期待していたんだ？」
	}

	GlassBow: {
		DisplayName: ガラスの弓
		Tooltip:
			'''
			攻撃時、壊れて通常よりダメージが高い破片を発射することがある
			壊れた後は修復できる
			「なぜこんなことをするんだ？」
			'''
	}

	GlassBowBroken: {
		DisplayName: 壊れたガラスの弓
		Tooltip: 「ガラスの弓に何を期待していたんだ？」
	}

	GlassStaff: {
		DisplayName: ガラスの杖
		Tooltip:
			'''
			攻撃時、壊れて破片を発射することがある
			壊れた後は修復できる
			「一体何が問題になるというのか？」
			'''
	}

	GlassStaffBroken: {
		DisplayName: 壊れたガラスの杖
		Tooltip: 「ガラスの杖に何を期待していたんだ？」
	}

	GlassBHelmet: {
		DisplayName: ガラスの兜
		Tooltip:
			'''
			ダメージが6%増加
			ダメージを受けると壊れて、敵にダメージを与え、破片が刺さる
			壊れた後は修復できる
			'''
	}

	GlassChestplate: {
		DisplayName: ガラスの胸当て
		Tooltip:
			'''
			ダメージが8%増加
			ダメージを受けると壊れて、敵にダメージを与え、破片が刺さる
			壊れた後は修復できる
			'''
	}

	GlassGreaves: {
		DisplayName: ガラスのすね当て
		Tooltip:
			'''
			ダメージが6%増加
			ダメージを受けると壊れて、敵にダメージを与え、破片が刺さる
			壊れた後は修復できる
			'''
	}

	GlassAxe: {
		DisplayName: ガラスの斧
		Tooltip:
			'''
			木を伐採すると、壊れて破片を放つことがある
			敵を攻撃した場合は必ず壊れる
			壊れた後は修復できる
			'''
	}

	GlassHammer: {
		DisplayName: ガラスのハンマー
		Tooltip:
			'''
			壁を破壊すると、壊れて破片を放つことがある
			敵を攻撃した場合は必ず壊れる
			壊れた後は修復できる
			'''
	}

	GlassPick: {
		DisplayName: ガラスのつるはし
		Tooltip:
			'''
			ブロックを採掘すると、壊れて破片を放つことがある
			敵を攻撃した場合は必ず壊れる
			壊れた後は修復できる
			'''
	}

	GlassHandle: {
		DisplayName: 壊れたガラスの取っ手
		Tooltip: 「ガラスの道具に何を期待していたんだ？」
	}

	GlassArmourShard: {
		DisplayName: 壊れたガラスの破片
		Tooltip: 「ガラスの防具に何を期待していたんだ？」
	}

	ShotgunBlaster: {
		DisplayName: オーバークロックされたショットガン
		Tooltip:
			'''
			撃ち続けると不安定になっていく
			「これは安全そうにない」
			'''
	}

	VoidSuitcase: {
		DisplayName: 狡猾なスーツケース
		Tooltip:
			'''
			左クリックを長押しするとチャージし、チャージするほど大きく、残る時間が延び、ダメージが増加する力場を放つ
			同時に放てる力場は1つだけで、新たに力場を放つと前の力場が消滅する
			放つには最低で60マナが必要
			「たっぷり遊んであげる！へっ！」
			'''
	}

	PainTicket: {
		DisplayName: ペインチケット
		Tooltip:
			'''
			右クリックでガチャを引く
			90分の1の確率で、[i:StormDiversMod/TheGoldenPainMask] 伝説の金のペインマスクを50%の確率で入手する
			天井は90で、50%の確率で入手できなかった場合、通常のペインマスクを入手するが、
			次の金のペインマスクは必ず入手できる
			それでもダメだった場合、10分の1の確率で少し珍しいアイテムを入手する
			天井は10で、
			上記全てに失敗した場合は、一般的なアイテムを入手する
			-- 天井の数 --
			金のペイン
			保証
			少し珍しいアイテム
			'''
	}

	TheGoldenPainMask: {
		DisplayName: 金のペインマスク
		Tooltip: ""
	}

	PainCoin: {
		DisplayName: ペイントークン
		Tooltip:
			'''
			ペインチケットの作成に使う
			-- 現在のクールダウン --
			敵のドロップ
			敵のドロップのクールダウン
			ボスのドロップ
			ボスのドロップのクールダウン
			'''
	}
}

