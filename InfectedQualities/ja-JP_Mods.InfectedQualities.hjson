		CorruptDiamondGemstoneBlock.DisplayName: "{$ItemName.Diamond}のブロック（不浄）"
		CorruptAmberGemstoneBlock.DisplayName: "{$ItemName.Amber}のブロック（不浄）"
		CrimsonSapphireGemstoneBlock.DisplayName: "{$ItemName.Sapphire}のブロック（真紅）"
		CrimsonRubyGemstoneBlock.DisplayName: "{$ItemName.Ruby}のブロック（真紅）"
		CrimsonEmeraldGemstoneBlock.DisplayName: "{$ItemName.Emerald}のブロック（真紅）"
		CrimsonTopazGemstoneBlock.DisplayName: "{$ItemName.Topaz}のブロック（真紅）"
		CrimsonAmethystGemstoneBlock.DisplayName: "{$ItemName.Amethyst}のブロック（真紅）"
		CrimsonDiamondGemstoneBlock.DisplayName: "{$ItemName.Diamond}のブロック（真紅）"
		CrimsonAmberGemstoneBlock.DisplayName: "{$ItemName.Amber}のブロック（真紅）"
		HallowedSapphireGemstoneBlock.DisplayName: "{$ItemName.Sapphire}のブロック（聖域）"
		HallowedRubyGemstoneBlock.DisplayName: "{$ItemName.Ruby}のブロック（聖域）"
		HallowedEmeraldGemstoneBlock.DisplayName: "{$ItemName.Emerald}のブロック（聖域）"
		HallowedTopazGemstoneBlock.DisplayName: "{$ItemName.Topaz}のブロック（聖域）"
		HallowedAmethystGemstoneBlock.DisplayName: "{$ItemName.Amethyst}のブロック（聖域）"
		HallowedDiamondGemstoneBlock.DisplayName: "{$ItemName.Diamond}のブロック（聖域）"
