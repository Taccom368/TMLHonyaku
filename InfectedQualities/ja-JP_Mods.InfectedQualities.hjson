Items: {
	DivinePowder: {
		DisplayName: 聖なる粉
		Tooltip: 聖域の地を広める
	}

	KeyOfNaught: {
		DisplayName: 無の鍵
		Tooltip:
			'''
			{$ItemTooltip.NightKey}
			別の邪悪のミミックを召喚する
			'''
	}

	Placables: {
		CorruptSnowBlock.DisplayName: 雪のブロック（不浄）
		CrimsonSnowBlock.DisplayName: 雪のブロック（真紅）
		HallowedSnowBlock.DisplayName: 雪のブロック（聖域）

		PylonOfNightBlock: {
			DisplayName: 闇のパイロン
			Tooltip:
				'''
				別のパイロンにテレポートできる。住民は必要ない
				邪悪なバイオーム内でのみ機能する
				1種に付き1つだけ、適したバイオームに設置することができる
				'''
		}

		CorruptSapphireGemstoneBlock.DisplayName: "{$ItemName.Sapphire}のブロック（不浄）"
		CorruptRubyGemstoneBlock.DisplayName: "{$ItemName.Ruby}のブロック（不浄）"
		CorruptEmeraldGemstoneBlock.DisplayName: "{$ItemName.Emerald}のブロック（不浄）"
