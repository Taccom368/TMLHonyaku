	InspirationFlower: {
		DisplayName: 活力の葦
		Tooltip:
			'''
			旋律ダメージが8%増加
			インスピレーションポーションを自動で使用してくれる
			'''
	}

	LesserInspirationPotion.DisplayName: 小型インスピレーションポーション
	InspirationPotion.DisplayName: インスピレーションポーション
	GreaterInspirationPotion.DisplayName: グレートインスピレーションポーション
	SuperInspirationPotion.DisplayName: スーパーインスピレーションポーション
	SupremeInspirationPotion.DisplayName: シュプリームインスピレーションポーション
	DecorativeGreaterInspirationPotion.DisplayName: 装飾用のグレートインスピレーションポーション
	DecorativeInspirationPotion.DisplayName: 装飾用のインスピレーションポーション
	DecorativeLesserInspirationPotion.DisplayName: 装飾用の小型インスピレーションポーション
	DecorativeSuperInspirationPotion.DisplayName: 装飾用のスーパーインスピレーションポーション
	DecorativeSupremeInspirationPotion.DisplayName: 装飾用のシュプリームインスピレーションポーション
