StagnationWatchPrefix: "{0}日、"

Items: {
	CosmicSunblock: {
		DisplayName: コズミックサンブロック
		Tooltip:
			'''
			太陽の黙示録を停止させる
			昼間かつ地上で使用できる
			太陽が消滅している場合は使用できない
			'''
	}

	GrassPowder: {
		DisplayName: 草の粉
		Tooltip: 土に草を広げ、火を消す
	}

	CyanSolution: {
		DisplayName: 環境変更弾 （空色）
		Tooltip:
			'''
			環境変更銃の弾
			灰を土に、溶岩を石に変える
			地上と地下で機能する
			'''
	}

	DarkGreenSolution: {
		DisplayName: 環境変更弾 （濃い緑）
		Tooltip:
			'''
			環境変更銃の弾
			土地をジャングルにする
			'''
	}

	SolarAccelerationPill: {
		DisplayName: 太陽の{0}薬 ({1}-日)
		Tooltip:
			'''
			太陽の黙示録を開始する
			昼間に使用できる
			太陽が消滅している場合は使用できない

			'''
		TooltipStagnation:
			'''
			{$Items.SolarAccelerationPill.Tooltip}
			{$Items.SolarAccelerationPill.TooltipStagnationInner}
			{$Items.SolarAccelerationPill.FunnyQuip}
			'''
		TooltipDissipation:
			'''
			{$Items.SolarAccelerationPill.Tooltip}
			{$Items.SolarAccelerationPill.TooltipDissipationInner}
			{$Items.SolarAccelerationPill.FunnyQuip}
			'''
		TooltipNova:
			'''
			{$Items.SolarAccelerationPill.Tooltip}
			{$Items.SolarAccelerationPill.TooltipNovaInner}
			{$Items.SolarAccelerationPill.FunnyQuip}
			'''
		FunnyQuip: 「副作用として大量破壊が含まれる」
		TooltipStagnationInner: 時間切れ後は最終日の状態を維持する
		TooltipDissipationInner: 時間切れになると、太陽が燃え尽きる
		TooltipNovaInner: 時間切れになると太陽が爆発し、全てが破壊される
	}

	PillEssences: {
		DisplayName: 太陽の{0}エッセンス
		Tooltip:
			'''
			太陽の黙示録を開始させる薬を作成するのに使用できる
			{0}
			'''
	}

	AshWallItem: {
		DisplayName: 灰の壁
		Tooltip: ""
	}

	CombustibleLemon: {
		DisplayName: 可燃性レモン
		Tooltip:
			'''
			投げたり、ロケットとして使用できる
			ブロックに火をつける小さな爆発を起こす
			「人生からレモンを取り戻そう！」
			'''
	}

	Match: {
		DisplayName: マッチ
		Tooltip: 火をつける
	}

	HornfelsItem: {
		DisplayName: 接触変成岩
		Tooltip: ""
	}
}

