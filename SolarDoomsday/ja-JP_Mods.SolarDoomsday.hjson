	ServerConfig: {
		DisplayName: ゲーム設定

		RainGivesSafety: {
			Label: 雨が降っている間は安全
			Tooltip:
				'''
				オンにすると、雨が降っている間は黙示録の悪影響が全てなくなります
				しかし、ワールドは次第に雨が降らなくなっていきます！
				'''
		}
	}

	ClientConfig: {
		DisplayName: 表示設定

		ScreenShakeStrength: {
			Label: 画面の揺れの強さ
			Tooltip:
				'''
				爆発に設定したワールドの最終日には、画面が揺れ、
				終わりに近づくにつれてより激しくなっていきます
				この設定で振動の強さを変更できます
				'''
		}

		dayCounterDisplay: {
			Label: 日数のカウント表示
			Tooltip: 消失と爆発に設定したワールドの日数のカウントの外観を変更します
