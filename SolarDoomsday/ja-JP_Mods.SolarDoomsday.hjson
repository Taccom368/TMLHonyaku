WorldEndSettings: {
	Stagnation: 停滞
	Dissipation: 消失
	Nova: 爆発
}

DoomsdaySelection: {
	Stagnation: {
		Title: "{$WorldEndSettings.Stagnation}"
		Description: 時間切れ後は最終日の状態を維持する
	}

	Dissipation: {
		Title: "{$WorldEndSettings.Dissipation}"
		Description: 時間切れになると、太陽が燃え尽きる
	}

	Nova: {
		Title: "{$WorldEndSettings.Nova}"
		Description: 時間切れになると太陽が爆発し、全てが破壊される
	}

	Enabling: {
		Title: 太陽の黙示録を有効にする
		Description: 有効にするとこのワールドは徐々に焼却されるようになる！
	}

	DaysLeft: {
		Title: 日数:
		Empty: <30>
		Description: ワールドが最終段階に到達するまでの日数
		Input: 日数を入力 (最低でも12日が推奨)
	}
}

WorldFileLabel: 日数 {0}

