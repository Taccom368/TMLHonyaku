		1: "{0}は病気で亡くなった。"
		2: "{0}は電球を飲み込んだ。"
		3: "{0}は特別な石を舐めた。"
	}

	ChasmeHead: {
		0: "{0}はチャスメに貪り食われた。"
		1: "{0}はハッチから降りていった。"
		2: "{0}はまさに求めていたものだった。"
	}
}

