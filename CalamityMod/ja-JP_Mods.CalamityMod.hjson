		}

		CoralskinFoolfish: {
			Tooltip: 「擬態は自然界でも有数の防御手段だ」
			DisplayName: サンゴ肌のモンガラカワハギ
		}

		Slurpfish: {
			QuestDescription: 地獄の底にあるって言われてる古代遺跡の魚が欲しいんだけど、流石に危険すぎてさ...というわけで、キミが行ってきて！
			DisplayName: スラップフィッシュ
