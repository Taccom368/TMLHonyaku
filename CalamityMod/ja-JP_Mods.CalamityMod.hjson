	Pets: {
		TrashmanTrashcan: {
			Tooltip: ゴミ箱男を召喚する
			DisplayName: ゴミ箱
		}

		ToastyBatBottle: {
			Tooltip:
				'''
				炎のコウモリを召喚して進行方向を照らし、輝く残り火の軌跡を残す
				[c/CF6454:「地獄の橋から突き落とされる心配は一切なし！」]
				'''
			DisplayName: 炎のコウモリの瓶
		}

		ThiefsDime: {
			Tooltip:
				'''
				盗賊のコインのゴールディを召喚し、近くのコインを集めて道を照らす
				深淵の視認性を僅かに向上させる
				「かつては無価値な宝物、今では泥棒仲間の遺物」
				'''
			DisplayName: 盗賊の硬貨
		}

		TheEtomer: {
			Tooltip:
				'''
				電気のトラブルメーカーを召喚
				ちょっとしたメモが添えられている:
				「ありがとう、アロエ！ベンより」
				'''
			DisplayName: エトマー
		}

