			Pumpkaboom: {
				Tooltip:
					'''
					敵に張り付き、遅れて爆発するかぼちゃを投げる
					ステルス攻撃ではより大きなかぼちゃを投げ、爆発前に敵を引き寄せて大爆発を起こす
					'''
				DisplayName: 爆裂かぼちゃ
			}

			WulfrumKnife: {
				Tooltip:
					'''
					ウルフラムナイフを3本連続で投げる
					ステルス攻撃はナイフをより遠くへ飛ばし、一度に何回もヒットさせる
