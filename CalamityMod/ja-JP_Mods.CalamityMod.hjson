NPCs: {
	HorribleHog: {
		DisplayName: 恐ろしき豚
	}

	TownPiggy: {
		Chat: {
			2: ブヒッ！
			1: ブヒィ…
			0: ブー！
		}

		Name: {
			Piglet: Piglet
			JohnPork: John Pork
			Techno: Techno
