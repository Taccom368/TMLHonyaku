	Lecherous: {
		Description:
			'''
			自分とマウスカーソルの間に、追尾武器を妨害する
			煉獄の怪物を召喚する。
			死亡時に大量のハートをドロップする。
			'''
		DisplayName: 魅惑の
	}

	Persecuted: {
		Description:
			'''
			攻撃されるか、時間経過により
			自分の近くに悪魔のポータルが現れる。
			十分なダメージを与えると味方になるが、
			ダメージが不足していたり、ポータルにダメージを
			与えると敵対する。
			'''
		DisplayName: 迫害された
	}

	Withering: {
		Description:
			'''
			被ダメージ時、これまでに与えたダメージに応じた
			割合で回復する（最大100％）。
			その後、このアイテムを持っている間は
			ダメージブーストを得るが、
			代わりに自身もダメージを受ける。
			'''
		DisplayName: 凋落の
	}

	Traitorous: {
		Description:
			'''
			マナが25％未満の時にこのアイテムを使用すると、
			残りのマナをすべて消費し、自身と敵に害を与える
			怪物を解き放つ。
			'''
		DisplayName: 裏切りの
	}

	Tainted: {
		Description:
			'''
			このアイテムの発射能力を削除する代わりに、
			使用時にマウスカーソルに攻撃を行う2本の
			骨の腕を召喚する。
			'''
		DisplayName: 穢された
	}

	Hellbound: {
		Description:
			'''
			ミニオンは40秒が経過すると爆発し、
			ミニオンが長く生きるほどダメージが増加する。
			何もしていない状態でも爆発する。
			'''
		DisplayName: 地獄の従者の
	}

	Ephemeral: {
		Description:
			'''
			このアイテムのダメージが使用により減少する。
			使用しないとダメージが回復し、通常よりも高い
			ダメージになる。
			'''
		DisplayName: 儚き
	}

	Bloodthirsty: {
		Description:
			'''
			ヒットした対象との距離に応じて攻撃のダメージが
			変動する。
			近いほどダメージが増加し、遠いほど減少する。
			'''
		DisplayName: 血飢の
	}

	Resentful: {
		Description:
			'''
			ヒットした対象との距離に応じて攻撃のダメージが
			変動する。
			遠いほどダメージが増加し、近いほど減少する。
			'''
		DisplayName: 怨恨の
	}

	Oblatory: {
		Description:
			'''
			マナ消費を減少させ、ダメージを大幅に増加させるが
			時々ライフを消費することがある。
			'''
		DisplayName: 献身の
	}

	Aflame: {
		Description:
			'''
			攻撃がヒットすると、至高の魔女の力で敵を炎上させ
