Items: {
	Weapons: {
		Typeless: {
			StratusSphere: {
				Tooltip:
					'''
					特異点を放ち、その広範囲に存在するあらゆる存在へ影響を及ぼす
					影響下のプレイヤーは時間経過でスターバーストを獲得し、敵は代わりにダメージを受ける
					<right>でスターバーストを障壁として形成し、体力の代わりにスターバーストを消費して被弾を防ぐことができる
					特異点を展開すると障壁は解除され、障壁を展開すると特異点は解除される
					「魂を星へと変えるなど、愚かしい発想だ」
					'''
				DisplayName: 層雲の宝珠
			}

			StarStruckWater: {
				Tooltip: ブロックにアストラルの汚染を広げる
				DisplayName: 星の水
			}

			Skynamite: {
				Tooltip:
					'''
					重力を無視する浮遊性の爆発物を投げる
					「これを使うのに航空力学の専攻は必要ない...」
					'''
				DisplayName: スカイナマイト
			}

			RelicOfDeliverance: {
				Tooltip:
					'''
					<left>を使用すると槍に乗る
					<left>を押し続けると槍を回転させ、速度を低下させる
					離すと高速で自身を発射する。ボスが生存中は速度が半減する
					チャージ中に速度が低下しすぎるとチャージが失敗し、速度がリセットされる
					ダッシュにより敵を貫通し、ブロックを通過できる
					ブロック内に長時間滞在すると入口位置にワープする
					<right> で降りる
					槍を構えている間、全ての召喚物のダメージが大幅に減少する
					[c/FF8C00:「復讐が私を駆り立て、報復以外の考えはなかった]
					[c/FF8C00:　竜は私からすべてを奪い、砕けた私の残骸を地面に散乱させた]
					[c/FF8C00:　しかし、彼女の傍にいた時、戦うに値するものがまだあると悟った」]
					'''
				DisplayName: 救済の遺物
			}

			LunicEye: {
				Tooltip:
					'''
					敵の防御力を低下させるルーニックビームを発射する
					すべてのダメージステータスを一度に低下させる
					'''
				DisplayName: ルーニックアイ
			}

			EyeofMagnus: {
				Tooltip:
					'''
