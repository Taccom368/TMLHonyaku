		AsgardianAegis: {
			Tooltip:
				'''
				ノックバックを無効化する
				ダメージを受けずに敵を貫通するコズミックインフェルノダッシュが発動可能になる
				'''
			DisplayName: アスガルドの護盾
		}

		AscendantInsignia: {
			Tooltip:
				'''
				翼の飛行時間が30%増加
				移動速度とジャンプ速度が10% 増加、加速が 1.1倍になる
				[KEY] を押すと「昇天の力」を得て、4秒間無限飛行が可能になる
				この効果は40秒のクールダウンが必要
				'''
			DisplayName: アセンダントの記章
		}

		ArchaicPowder: {
			Tooltip:
				'''
				採掘速度が{0}%上昇
				落下ブロックおよびダーツトラップのダメージを無効化
				トラップから受ける全ダメージを{1}%軽減
				下位互換とは重複しない
				'''
			DisplayName: 古代の粉
		}

		ArcFlashRing: {
			Tooltip:
				'''
				攻撃時、{0}%の確率で{1}倍ダメージの雷を落とす
				攻撃が命中した敵の数に応じて確率は低下する
				雷撃のダメージは非クリティカル時の値を基準とするが、雷自体はクリティカル可能
				視覚効果を無効にすると、雷撃は透明かつ無音になる
				'''
			DisplayName: 閃雷の指輪
		}

		AquaticHeart: {
			FullTooltip:
				'''
				水中にいる間、海の祝福が付与され、最高速度と加速が{0}%増加する
				酸素の減りを大幅に軽減し、深淵での視認性が僅かに向上する
				プレイヤーに触れた敵に[cbuff:CalamityMod/GlacialState]を付与する
				自分の周囲に氷のシールドを展開するが、{1}%のダメージを吸収すると壊れる
				{2}秒後に氷のシールドが再生する
				「泳げるようになったんだね！」
				'''
			LockedTooltip: "[c/F05A5A:「真珠の魔法は古代の呪いによって封じられている...」]"
			Tooltip:
				'''
				水のエレメンタルに変身する
				[STATUS]
				'''
			DisplayName: アクアティックハート
		}

		AquaticEmblem: {
			Tooltip:
				'''
				ほとんどの海の敵は友好的になり、水中呼吸を可能にする
				水中にいると、時間の経過とともに防御力が徐々に上がるが、{0}秒かけて移動速度が低下する
				水中以外では、防御力増加と移動速度低下が徐々に減少する
				防御力増加の最大値は{1}、移動速度低下は{2}%
				深淵での視認性が僅かに向上させ、酸素の減りを僅かに減少させる
				'''
			DisplayName: 水の紋章
		}

		Apollyon: {
			Unequipped: 現在の[cbuff:CalamityMod/Bane]ダメージを表示するにはこのアクセサリーを装備する必要がある
			Equipped: 現在の[cbuff:CalamityMod/Bane]ダメージ: {0} DPS
			Tooltip:
				'''
				クリティカルヒット時、クリティカル率に大きく依存する[cbuff:CalamityMod/Bane]を敵に付与する
				クリティカルヒットを受けた敵は、自身に付与されている[cbuff:CalamityMod/Bane]より弱いデバフを周囲の敵へ拡散する
				クリティカルヒットは敵に付与されているデバフ1つにつき追加で3%のダメージを与える
				[DAMAGELINE]
				'''
			DisplayName: アポリオン
		}

		AngelTreads: {
			Tooltip:
				'''
				移動速度が{0}%上昇、飛行時間が{1}%増加
				水と溶岩、蜂蜜の上を歩くことができる
				燃えているブロックのダメージが無効化され、溶岩への耐性を{2}秒付与する
				溶岩の接触ダメージを軽減
				「速すぎる！」
				'''
			DisplayName: エンジェルトレッズ
		}

		AngelicAlliance: {
			Tooltip:
				'''
				天の力を、自分とミニオンに付与する
				最大ミニオン数+{0}、召喚ダメージが{1}%増加、その他全クラスのダメージが{2}%増加
				飛行時間を一部または完全に消費している間、ライフ自然回復+{3}/秒
				[KEY]キーで[cbuff:CalamityMod/DivineBless]を{4}秒間付与
				神聖なる加護の効果中、ミニオン1体につき、戦闘を補助する大天使1体を召喚する
				出現した天使は、即座にライフを{5}回復する
				すべてのミニオンの攻撃は[cbuff:CalamityMod/BanishingFire]を与え、{6}秒ごとに4ずつ自分のライフが増加する
				この効果には{7}分のクールダウンがある
				「勇気、啓示、至福。審判にて一つとなる」
				'''
			DisplayName: エンジェリックアライアンス
		}

		AnechoicPlating: {
			Tooltip:
				'''
				深淵の敵に発見されづらくなる
				深淵が引き起こす防御力低下を軽減する
				'''
			DisplayName: 無響の装甲板
		}

		AncientFossil: {
			Tooltip: 採掘速度が{0}%%上昇
			DisplayName: 古代の化石
		}

		AmidiasPendant: {
			Tooltip: 定期的にプリズムの破片を降らせ、敵を短時間スタンさせる
			DisplayName: 海の王のペンダント
		}

		AmbrosialAmpoule: {
			Tooltip:
				'''
				失ったライフに応じてライフ自然回復を毎秒{0}～{1}増進 [c/999999:(現在: +[REGEN]/秒)]
				ライフ自然回復の効果が{2}%増加し、回復開始が{3}%早くなる
				見た目表示が有効な場合は黄色い光を放つ
				'''
			DisplayName: 神々しい薬瓶
		}

		AmalgamatedBrain: {
			HoldShiftTooltip:
				'''
				最大ライフの5%未満の攻撃は回避されない
				回避には攻撃のダメージに応じて20秒から90秒のクールダウンがあり
				これは他のすべての回避や反射と共有される
				'''
			Tooltip:
				'''
				ダメージを受けると周囲の敵を混乱させ、ダンククリーパーを召喚する
				ダンククリーパーは頭上を飛び、爆発し、陰の雨を降らす雲になる
				攻撃を回避する能力を得る
				回避後はクリティカル率と召喚ダメージを一時的に10%増加させる
				'''
			DisplayName: 融合された脳
		}

		AlluringBait: {
			Tooltip:
				'''
				フィッシング・パワーを30増加
				ポーションの材料となる魚が釣れる確率と数が大幅に増加
				'''
			DisplayName: 魅力的な釣り餌
		}

		AlchemicalDecanter: {
			Tooltip:
				'''
				すべての攻撃が[cbuff:CalamityMod/Plague]を与え、
				疫病によるダメージを{0}%軽減する
				飛び道具が敵に当たると、疫病の追跡体を発生させる
				被ダメージ時、疫病蜂を放出し、自身を[cbuff:Honey]で覆う
				'''
			DisplayName: 疫禍蒸留器
		}

		Affliction: {
			Tooltip:
				'''
				自分とチーム内の他のすべてのプレイヤーのライフを毎秒+{0}回復する
				最大ライフ+{1}%、ダメージ{2}%軽減、防御{3}、ダメージ{4}%増加
				'''
			DisplayName: アフリクション
		}

		AeroStone: {
			Tooltip:
				'''
				飛行時間を{0}秒延長する
				飛行または滑空していない場合、飛行時間はゆっくりと回復する
				「古代の遺物の一つ」
				'''
			DisplayName: エアロストーン
		}

		AbyssalMirror: {
			FlavorTooltip: 「光は海の底まで届かない」
			HoldShiftTooltip:
				'''
				最大ライフの5%未満の攻撃は回避されない
				回避には攻撃のダメージに応じて20秒から90秒のクールダウンがあり
				これは他のすべての回避や反射と共有される
				攻撃を回避するとステルス状態になる
				'''
			Tooltip:
				'''
				深淵を含む敵がプレイヤーを標的にする確率が低下する
				静止時にステルスゲージの増加スピードが{0}%速くなり、移動中は{1}%速くなる
				攻撃を回避する能力を得る
				攻撃を回避するとルメニルの液の破片が放出され敵を攻撃し
				周囲の敵にダメージとスタン効果を与える
				'''
			DisplayName: 深淵の鏡
		}

		AbyssalDivingSuit: {
			Tooltip:
				'''
				「深海のダイバー用の装備」
				水中では最大移動速度と加速度が増加するが、水中以外では移動速度が遅くなる
				泳ぐ能力を与え、水中で発光するようになり、酸素の減りを大幅に減少させる
				深淵の生物に発見されにくくなり、防御力低下を緩和する
				氷上で機動性が上がる
				硫黄の水および[cbuff:CalamityMod/CrushDepth]による酸素減少効果に耐性を得る
				[cbuff:CalamityMod/HadopelagicPressure]による呼吸減少増加を軽減する
				液体に沈みやすくなる
				'''
			DisplayName: 深海のダイビングスーツ
		}

		AbyssalDivingGear: {
			Tooltip:
				'''
				息を切らしている間、深淵の圧力によるダメージを軽減する
				深淵による出血効果を除去する
				泳ぐ能力を与え、水中での呼吸を大幅に延長する
				水中での軽快な動きと氷上での機動性を実現
				深淵の視認性を大幅に向上させる
				深淵での酸素の減りを大幅に減少させる
				'''
			DisplayName: 深海の潜水具
		}

		Abaddon: {
			DisplayName: アバドン
			Tooltip:
				'''
				クリティカルヒット時、クリティカル率に依存する[cbuff:CalamityMod/Bane]を敵に付与する
				クリティカルヒットを受けた敵は、自身に付与されている[cbuff:CalamityMod/Bane]より弱いデバフを周囲の敵へ拡散する
				[DAMAGELINE]
				'''
			Equipped: 現在の[cbuff:CalamityMod/Bane]ダメージ: {0} DPS
			Unequipped: 現在の[cbuff:CalamityMod/Bane]ダメージを表示するにはこのアクセサリーを装備する必要がある
		}
	}
}

GameTips: {
	KeybindsTip: Modの設定は、設定で変更することができる。
	BloodOrbTip: ブラッドムーン中にドロップする血のオーブは、ほとんどのポーションの素材になる。
	RevengeanceTip: エキスパートモードを超える挑戦が必要ですか？Revengeanceモードを試してみよう！
	DefenseDamageTip: 特定の攻撃は防御力を減少させるが、しばらくすると回復する。
	SummonNerfTip: 召喚武器でない武器を持つと、自分のミニオンのダメージが減少する。
	StealthTip: ローグの装備を着用すれば、ステルス状態になることができる！
	FactoryChargingTip: パワーセル製造機と充電ステーションは、地底世界の研究所から入手できる。
	PowerCellTip: パワーセル製造機は、時間とともにパワーセルを製造する。
	CodebreakerTip: コードブレーカーは増設可能で、世界中のさまざまな研究所で発見された新しい設計図を解読できる。
	TerminusTip: 深淵の底には古代の遺物が眠っている。使用には細心の注意を。
	RoDAbyssTip: 深淵でのディスコードロッドの使用は自己責任で。その光は、望まぬ敵の注意を引くかもしれない。
	BossEnemyTip: 無害な敵を殺すと、強大なモンスターの怒りを買うことがある！
	TitanHeartTip: 巨人の心臓は、アストラル汚染地帯にあるビーコンで供物として使うことができる。
	BrimstoneWitchTip: 煉獄の魔女は、アイテムにエンチャントを施して新たな力を与えることができる。
	ArchmageTip: 大魔導士は、氷の檻に幽閉されている。破壊して解放しよう。
	AmidiasBlessingTip: 海王は、助けを求める人に水中での呼吸を助ける泡を提供することができる
	SeaKingTip: かつて海王はハマグリが好きだったが、ハマグリに食べられてから気が変わったらしい。
	RefundTip: ゴブリンのよろず屋に鍛え直しを沢山してもらっているのなら、盗賊を訪ねてみるのもいいかもしれない。
	BanditTip: 盗賊は貧しい人からは盗まない。彼らに会いたければ、気を引くために大金が必要だ。
	AbyssTip: 深淵は硫黄の海の地下深くにある。探検する際は、適切な潜水具を用意したほうがいい。
	PlanetoidTip: 小惑星は宇宙に存在する！
	ArsenalLabTip: 地表の地下には、放棄された研究所が点在しているらしい...
	SunkenSeaTip: 砂漠の奥深くに、没落した王国の廃墟と化した郊外があるらしい...
}

Events: {
	BossRushEndText_Death: ...私の予想通り、この世界は自らを救うことさえできないのだろう。ましてや私を救うことなど。
	BossRushEndText_Repeat: 君は確かに手強い戦士であることを証明した。しかし、それではまだ足りない。さらなる力を求め、高みを目指せ。いつの日かふさわしい者となるために。
	BossRushEndText_8: さらばだ、今のところはな。
	BossRushEndText_7: その間、私にはやらねばならないことがある。
	BossRushEndText_6: さらなる力を求め続けよ。そして再び会う時、君が十分に成長していることを期待している。
	BossRushEndText_5: 君は私の要求を満たすには至らなかったが、これが我々が交わる最後の機会というわけでもないはずだ。
	BossRushEndText_4: 一種の記念品のようなものだ。
	BossRushEndText_3: だが、慰めの品として、この古代の石を持っていくがよい。
	BossRushEndText_2: その力でさえ、残念ながら十分ではないし、考えを共有するつもりもない。
	BossRushEndText_1: 見事な戦いぶりだ。私の考えは正しかったようだ！君はこの世界で最強の戦士かもしれない。しかし...
	BossRushTierFourEndText_3: 自らを超越する力があることを証明せよ。
	BossRushTierFourEndText_2: 今こそ君の信念、そして力と意志の真価を示す時だ。
	BossRushTierFourEndText_1: 試練はまもなく最高潮に達する。
	BossRushTierThreeEndText_2: だが、試練はまだ終わりではない。一瞬たりとも油断してはならない。
	BossRushTierThreeEndText_1: 君の決意と成長への意志...それは私がまだ人間だった頃の自分を思い出させる。
	BossRushTierTwoEndText_2: だが、まだ足りない。さらなる試練に進むとしよう。
	BossRushTierTwoEndText_1: 間違いなかった。君は確かに称賛に値する戦士だ。
	BossRushTierOneEndText_2: これから訪れる試練に備え、肉体と精神を整えるがよい。
	BossRushTierOneEndText_1: ここまでは及第点と言えるが、私の期待には到底及ばない。
	BossRushStartText_Death: ...私は本当に、こんなことのために戻ってきたのか？
	BossRushStartText_Accept: よろしい。試練を始めよう！
	BossRushStartText_Decline: そうか。私の思い違いだったのだろう。さらばだ。
	BossRushStartText_Repeat: 私の挑戦を受けたいか？
	BossRushStartText_12: この挑戦を克服する覚悟はあるか？
	BossRushStartText_11: この試練は容易ではないだろう。だが、君ならば。
	BossRushStartText_10: 私は君の力を試したい。君が過去に倒した敵の姿をとった、私の「原初の光」の断片を使ってな。
	BossRushStartText_DraedonSCal: 私自身が力を疑った唯一の人間と匹敵する力を持つ者よ...
	BossRushStartText_Yharon: 我が古き友の、不死鳥さえ打ち破った者よ...
	BossRushStartText_DoG: 名もなき蛇を討ち倒した者よ...
	BossRushStartText_9: 君は、一つの時代を終わらせたこの秘宝を手にし、もうひとつの時代を終わらせるための冒険に出たのだな...
	BossRushStartText_8: ...もしかすると、これは一つの転機なのかもしれない。この遺物を手に入れることは簡単なことではないし、私は君の旅の一端を垣間見ている。
	BossRushStartText_7: 一体何が君をそこまで駆り立てて、そんな朽ちた石板を手に入れようとしたのだ？
	BossRushStartText_6: しかも今回はただの人間だとは！なんと興味深いことか...
	BossRushStartText_5: こんな状況にもかかわらず、それを手に入れる勇気を持つ者が他にもいるとは驚きだ。
	BossRushStartText_4: かつて無限の力を与えたこの遺物が、もはや利用されることはない...
	BossRushStartText_3: その存在を知る者はほとんどいない...
	BossRushStartText_2: この私の遺物を再び使われることがないよう、世界の最深部へと沈めたのだ。
	BossRushStartText_1: ...どれほどの時が経っただろう？数世紀か？あるいは千年もの時が経ったのか？
	BossRush: ボスラッシュ
	AcidRainEnd: 硫黄の空が晴れ始める...
	AcidRainStart: 荒れ果てた海に毒々しい豪雨が降り注ぐ！
	AcidRain: 酸性雨
}

