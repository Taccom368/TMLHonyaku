		}

		AlwaysOn: {
			Label: 常に表示
			Tooltip: この設定がオンだとBGMトラックが常に表示されます
		}

		AlwaysOnOpacity: {
			Label: 常に表示する場合の透明度
			Tooltip:
				'''
				「常に表示」がオンの場合の透明度を変更します
				「常に表示」がオフだと機能しません
				'''
		}

