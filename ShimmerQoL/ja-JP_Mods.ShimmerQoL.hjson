Configs: {
	Config: {
		DisplayName: 設定

		aetherPrefixing: {
			Label: ジェネシスコンジットの接頭辞を有効にする
			Tooltip:
				'''
				これをオンにするとエーテル内に設置したジェネシスコンジットが、近くでアイテムを作成した時に、
				接頭辞の付与システムを変更するようになり、武器、道具、アクセサリーなどが影響を受け、
				影響を受けたアイテムは特定の接頭辞のみが付くようになります
				詳細とこの動作のカスタマイズは「ジェネシスコンジットの接頭辞ホワイトリスト」を参照してください
				'''
		}

		prefixWhitelist: {
			Label: ジェネシスコンジットの接頭辞のホワイトリスト
			Tooltip:
				'''
				この設定はエーテル内に設置したジェネシスコンジットの近くでアイテムを作成した時に、
				付与される接頭辞に影響します
				デフォルトではこのリストには最高のバニラの接頭辞（例:幻の、神々しい、神話の）が含まれています
				ブラックリストとホワイトリストが有効でどちらにも同じ接頭辞が入っている場合は
				ブラックリストが優先されることに注意してください
				警告: デフォルトではModで追加される接頭辞はリストにないので、手動で追加する必要があります！
				'''
		}

		sellAetherPylon: {
			Label: エーテルのパイロンを買える
			Tooltip:
				'''
				エーテルのパイロンの入手可否を変更します
				販売条件は他のパイロンと同じですが、エーテルに対応しています
				'''
		}

		aetherPylonNPCS: {
			Label: エーテルのパイロンの必要人数
			Tooltip:
				'''
				エーテルのパイロンを使用するのに必要な近くの住民の数を変更します
				エーテルのパイロンはエーテルでのみ機能します
				デフォルトでは近くに1人いれば機能します
				'''
		}

		wellCrafting: {
			Label: エーテルの泉によるクラフトを有効にする
			Tooltip:
				'''
				エーテルの泉の機能の有効/無効を切り替えます
				これはシマー変化でのみ入手できるアイテムを作成可能な、特別な作業台です
				ただし、シマーに入れたときの効果が別のアイテムに変化するものでない場合と、
				素材に分解されるだけのアイテムは含まれません
				これをオフにしてもこのアイテムは入手できますが、クラフト機能は無効になります
				'''
		}

		transmuteTooltip: {
			Label: シマー変化のツールチップを表示する
			Tooltip:
				'''
				このModはシマーに入れると別のアイテムに変化するアイテムにツールチップを追加します
				該当するアイテムは「シマーで変化可能なアイテム」と付いています
				この変更はシマーに入れたときの効果が別のアイテムに変化するものでない場合と、
				素材に分解されるだけのアイテム（例：煌めくスライムの風船）には影響しません
				この設定で「シマーで変化可能なアイテム」の表示/非表示を変更します
				'''
		}

		nerfPrefixing: {
			Label: ジェネシスコンジットの機能を制限する
			Tooltip:
				'''
				ジェネシス・コンジットの機能を変更し、
				シマーに入れると素材に分解されるアイテムのみに影響するようになります
				特殊な変化パターンを持つアイテムと分解できないアイテムはジェネシスコンジットの恩恵を受けません
				'''
		}

		compoundTooltip: {
			Label: 素材とシマー変化のツールチップを同じ行に入れる
			Tooltip:
				'''
				バニラの「素材アイテム」と「シマーで変化可能なアイテム」を微調整して、同じ行に表示されるようにします
				アイテムが他のアイテムの素材でシマーで変化するものなら、
				「素材アイテム」の行は「素材アイテム、シマーで変化する」に置き換えられます
				「シマー変化のツールチップを表示する」がオンの場合に機能します
				'''
		}

		wellAether: {
			Label: エーテルの泉を使用するにはシマーが必要
			Tooltip:
				'''
				エーテルの泉のレシピを使用するには、エーテル内にいる必要があるようにします
				「エーテルの泉によるクラフトを有効にする」がオンの場合に機能します
				'''
		}

		shimmerPylon: {
			Label: パイロンがエーテルのパイロンに変化する
			Tooltip: 
				'''
				ユニバーサルパイロンを除く、バニラの全てのパイロンをシマーで、
				エーテルのパイロンに変化させることができるようになります
				'''
		}

		sellAetherCompass: {
			Label: 旅商人が神秘のコンパスを販売する確率
			Tooltip:
				'''
				旅商人が神秘のコンパスを販売する確率を変更します
				神秘のコンパスはエーテルへと導いてくれる特別な道具です
				0にすると販売しなくなり、100にすると必ず販売します
				'''
		}

		postEyeCompass: {
			Label: EoCを撃破後に神秘のコンパスを販売する
			Tooltip: これをオンにするとEoCを撃破後に神秘のコンパスが販売されるようになります
		}

		detransmuteBoosters: {
			Label: 変化の解除:永続ステータスアップアイテム
			Tooltip:
				'''
				ステータスを永続で上昇させる、シマー変化でのみ入手できるアイテムを、
				シマーに再度入れることで変化前に戻すことができるようになります
				例えば、バイタルクリスタルをライフクリスタルに戻すことができます
				この機能は以下のModに対応しています
				Thorium Mod、The Clicker Class、Storm's Additions Mod、Q.O.L. 3000
				'''
		}

		aetheriumBlockTransmute: {
			Label: 黒曜石をエーテルのブロックに変化可能にする
			Tooltip:
				'''
				黒曜石をシマーに入れるとエーテルのブロックに変化するようになります
				これにより、シマーを減らさずにエーテルのブロックを入手できるようになります
				'''
		}

		enableConduit: {
			Label: ジェネシスコンジットを有効にする
			Tooltip:
				'''
				ゴブリンの作業台をシマーで変化させて入手できるジェネシスコンジットの機能の有効/無効を切り替えます
				エーテル内に置くとジェネシスコンジットはアイテムの作成時に付与される接頭辞を調整/改善します
				これにより、シマーによる素材への分解を利用して、目的の接頭辞を持つアイテムを繰り返し作成しやすくなります
				詳細とこの動作のカスタマイズは、以下の設定を参照してください
				'''
		}

		Headers: {
			Tooltips: ツールチップ
			ShimmerWell: エーテルの泉
			AetherCompass: 神秘のコンパス
			AetherPylon: エーテルのパイロン
			Transmutations: シマーによる変化
			GenisisConduit: ジェネシスコンジット
		}

		usePrefixBlacklist: {
			Label: 接頭辞のブラックリストを有効にする
			Tooltip:
				'''
				この設定はエーテル内に設置したジェネシスコンジットの近くでアイテムを作成した時に、
				付与される接頭辞に影響します
				条件を満たしてアイテムを作成したときに付与される接頭辞がリストにないもののみになります
				詳細は「ジェネシスコンジットの接頭辞ブラックリスト」を参照してください
				'''
		}

		usePrefixWhitelist: {
			Label: 接頭辞のホワイトリストを有効にする
			Tooltip:
				'''
				この設定はエーテル内に設置したジェネシスコンジットの近くでアイテムを作成した時に、
				付与される接頭辞に影響します
				条件を満たしてアイテムを作成したときに付与される接頭辞がリスト内のもののみになります
				詳細は「ジェネシスコンジットの接頭辞ホワイトリスト」を参照してください
				'''
		}

		prefixBlacklist: {
			Label: ジェネシスコンジットの接頭辞のブラックリスト
			Tooltip:
				'''
				この設定はエーテル内に設置したジェネシスコンジットの近くでアイテムを作成した時に、
				付与される接頭辞に影響します
				デフォルトではこのリストには弱体化するバニラの接頭辞と弱い接頭辞（例:不格好な、荒々しい）が含まれています
				ブラックリストとホワイトリストが有効でどちらにも同じ接頭辞が入っている場合は
				ブラックリストが優先されることに注意してください
				警告: デフォルトではModで追加される接頭辞はリストにないので、手動で追加する必要があります！
				'''
		}

		tooltipFix: {
			Label: エーテルの泉のツールチップの修正
			Tooltip:
				'''
				エーテルの泉によって追加されたレシピによる発生する副作用を修正します
				エーテルの泉は専用アイテムへの変化を持つアイテムのレシピを生成するので、素材アイテムとなります
				これをオンにするとエーテルの泉に関連付けられたレシピのみを持つアイテムから、「素材アイテム」を削除します 
				'''
		}

		unrestrictLunarBrick: {
			Label: ルミナイトのレンガのシマー変化クラフトを可能にする
			Tooltip:
				'''
				これをオンにすると月の月相に関係なく、
				エーテルの泉でルミナイトのレンガのバリエーションを入手できるようになります
				通常は実際の変化と同様に、各バリエーションは特定の月相でのみ入手できます
				'''
		}

		detransmuteBiomeChests: {
			Label: 変化の解除: バイオームの宝箱
			Tooltip:
				'''
				これをオンにするとバイオームの宝箱をそれぞれのバイオームの鍵に変化できるようにします
				警告: これはModがプランテラ出現前にバイオームの宝箱を開ける可能性を考慮していないので、
				使用は推奨されません
				この機能は以下のModに対応しています
				Thorium Mod、The Clicker Class、Capture Disc Class、Rise of Ages
				'''
		}

		detransmuteBricks: {
			Label: 変化の解除: レンガ
			Tooltip: 
				'''
				これをオンにすると古代のレンガとルミナイトのレンガの派生品（アストラ、宇宙の残り火など）を、
				元のレンガに戻すことができるようになります
				'''
		}

		detransmuteUnsafeWalls: {
			Label: 変化の解除: 危険な壁
			Tooltip: これをオンにすると危険な壁を安全な壁に戻すことができるようになります
		}
	}
}

Items: {
	AetherPylonItem: {
		DisplayName: エーテルのパイロン
		Tooltip:
			'''
			{0} 人以上の{^0:住民;住民}が近くにいる別のパイロンにテレポートできる
			1つだけ設置でき、エーテル内でのみ機能する
			'''
	}

	GenesisConduitItem: {
		DisplayName: ジェネシスコンジット
		Tooltip:
			'''
			特殊なアクセサリーをクラフトできる
			エーテルに配置し、その隣でアイテムを作成すると良い接頭辞が付きやすくなる
			'''
	}

	ShimmerWellItem: {
		DisplayName: エーテルの泉
		Tooltip: シマーにアイテムを入れずに変化させることができる
	}

	AetherCompass: {
		DisplayName: 神秘のコンパス
		Tooltip:
			'''
			エーテルの方向を示す無害な光線を放つ
			エーテルが本来存在する領域にエーテルが存在しない場合、コンパスは機能しない
			「おかしいな…北を指さない」
			'''
	}
}

Tiles: {
	AetherPylonTile.MapEntry: エーテルのパイロン
	GenesisConduitTile.MapEntry: ジェネシスコンジット
	ShimmerWellTile.MapEntry: エーテルの泉
}

CommonItemTooltip: {
	TransmutableTip: シマーで変化可能なアイテム
	TransumtableMaterialTip: 素材アイテム、シマーで変化する
	WellConfig: 「エーテルの泉によるクラフトを有効にする」が有効になっている
	PylonConfig: 「パイロンがエーテルのパイロンに変化する」が有効になっている
	PylonCond: 「パイロンがエーテルのパイロンに変化する」が有効になっていて、エーテル内で、邪悪なバイオーム内でなく、他のNPCの近くで、幸福度が一定以上で販売する
	ConduitNerf: 素材に分解されないアイテムには影響しません
	ConduitDisabled: 警告: 現在、設定により接頭辞に影響を与えるシステムが無効になっています！
	WellDisabled: 警告: 設定によりエーテルの泉の機能は無効になっています！
	WellNerf: エーテルの泉を使用するクラフトには泉がエーテル内にある必要があります
}

Buffs: {
	GenesisConduitBuff: {
		DisplayName: ジェネシススパーク
		Description: アイテムを作成時に特定の接頭辞のみが付く
	}
}

Projectiles.CompassBeam.DisplayName: コンパスの光線
