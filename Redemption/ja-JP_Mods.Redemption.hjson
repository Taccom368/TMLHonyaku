		Configs: {
			RedeConfigClient: {
				DisplayName: 個人設定

				NoBossIntroText: {
					Label: ゼルダ風ボス演出を無効化
					Tooltip: ボス登場時の「ゼルダの伝説」風イントロテキストを無効化する
				}

				CameraLockDisable: {
					Label: カメラ固定を無効化
					Tooltip:
						'''
						カットシーン中のカメラ固定、無敵化など無効化する
						演出の雰囲気を損なう可能性があるため、初回プレイでの導入は非推奨
						'''
				}

				ShakeIntensity: {
					Label: 画面揺れの強さ
					Tooltip: 値を下げると画面揺れ効果の強度が弱まる、0で完全に無効化
				}

				ElementalDamageTooltipStyle: {
					Label: 属性ダメージツールチップ表示形式
					Tooltip: 武器ツールチップ内での属性ダメージ増加表示のスタイルを変更、または無効化する
				}

				NoFlyBuzz: {
					Label: ハエの羽音を無効化
					Tooltip: ハエが無音になる
				}

				DialogueInChat: {
					Label: カットシーン台詞をチャットに記録
					Tooltip: カットシーンや「調和の聖杯」、ボスのセリフをテキストチャットにも表示する
				}

				LegacyNebSky: {
					Label: ネビュレウスの背景
					Tooltip: ネビュレウス最終形態戦の背景を旧バージョンの回転画像に戻す
				}

				DisableMPWarning: {
					Label: マルチプレイ警告を無効化
					Tooltip: マルチプレイ時に表示される警告メッセージを無効化する
				}
			}
			RedeConfigServer: {
				DisplayName: グローバル設定

				DialogueWaitTime: {
					Label: 追加のセリフ待機時間
					Tooltip:
						'''
						セリフが次に進むまでの表示時間を延長する
						単位は秒
						'''
				}

				DialogueSpeed: {
					Label: セリフ表示速度
					Tooltip:
						'''
						通常のセリフ速度が遅すぎる、または速すぎる場合のみ変更を推奨
						1文字ごとの表示間隔を秒単位で短縮する値、高いほど速くなる
						速くしすぎると読み終える前に進んでしまうため、「追加のセリフ待機時間」も調整すること
						'''
				}

				ElementDisable: {
					Label: 属性システム無効化
					Tooltip: 属性耐性と属性ダメージを無効化する。
				}

				VanillaGuardPointsDisable: {
					Label: バニラの敵のガードポイント無効化
					Tooltip: 通常の敵がガードポイントを持たないようにする
				}

				NoPZBuildUp: {
					Label: ペイシェント・ゼロの準備フェーズを無効化
					Tooltip: ボス戦を即時に開始する（ノーヒット練習向け）※音楽との同期がずれる可能性あり。
				}

				FindNewStructureCoords: {
					Label: 構造物座標のリセット
					Tooltip:
						'''
						ワールドに入る際、重要な構造物のタイル座標を再検出して設定する。
						構造物の位置を変更したい場合にのみ必要（例：地表ポータルを破壊して別の場所に設置した場合）
						無効時は一度設定された座標は変更されない
						'''
				}

				FunniHeader: ジョーク設定（通常のワールドを生成する場合は必ず無効化してください）

				FunniSpiders: {
					Label: あっ！全部クモ！
					Tooltip: 新しいワールド生成時、すべての石ブロックからスパイダースウォーマーが発生する可能性がある
				}

				FunniWasteland: {
					Label: 誰が核を撃ったんだ？
					Tooltip: 新しいワールド生成時、放射線汚染地帯バイオームが自然生成される（進行ルートが崩壊する可能性あり）
				}

				FunniAllWasteland: {
					Label: 家でもライデン
					Tooltip: 新しいワールド生成時、すべてのタイルが被曝されたバージョンに変換される（進行ルートが崩壊する可能性あり）
				}

				FunniJanitor: {
					Label: 用務員の最後の抵抗
					Tooltip: 新しいワールド生成時、廃水のない安全な「清潔な研究所」が生成される（進行ルートが崩壊する可能性あり）
				}

				FunniAncient: {
					Label: 古代の世界
					Tooltip: 新しいワールド生成時、タイルが古代版に変換され、古代の墓場の生成頻度が上昇する
				}
			}

