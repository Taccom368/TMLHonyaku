


		TownNPCMood: {
			Daerel: {
				Content: 今はけっこう落ち着いてるよ
				NoHome: できれば屋根のある場所で暮らしたいな
				FarFromHome: 家に戻してくれない？この辺ちょっと怖くてさ
				LoveSpace: ここは広くていいね、弓の練習もしやすいし
				DislikeCrowded: 人が多いのはちょっと苦手なんだ、落ち着かなくてさ
				HateCrowded: 人が多すぎるのは無理だよ、ほんと落ち着かない
				LoveBiome: "{BiomeName}はいい場所だね、静かで落ち着くよ"
				LikeBiome: "{BiomeName}はいいところだね、前いた場所じゃ雪なんてほとんど見なかったし"
				DislikeBiome: "{BiomeName}はあまり好きじゃないな、危ないやつに出くわしそうでさ"
				HateBiome: ここは正直嫌いだ
				LoveNPC: "{NPCName}とは仲いいんだ、同じ町に住めてよかったよ"
				LikeNPC: "{NPCName}はいいやつだよ、髪も整えてくれるし...別に変じゃないよね？"
				DislikeNPC: "{NPCName}がやたら土を買わせようとしてくるんだけど..."
				HateNPC: ねえ、{NPCName}を遠くに移せない？ただでさえ金ないんだよ
				LikeNPC_Princess: "{NPCName}は好きだよ"
				Princess_LovesNPC: "{NPCName}は好きだよ"
			}

			Fallen: {
				Content: なかなかいい場所だな
				NoHome: できれば屋根のある場所で過ごしたいものだ
				FarFromHome: すまないが、家まで戻してもらえるか？
				LoveSpace: 少し広すぎる気もするが...まあ悪くない
				DislikeCrowded: 人間が多すぎてな...骨がガタガタ鳴ってしまう
				HateCrowded: 人間が多すぎてな...どうにも落ち着かない
				LoveBiome: 洞窟は我々アンデットにとって理想的だ、人間もあまり来ないしな
				LikeBiome: ああ、{BiomeName}か...生きていた頃のガスラムを思い出す。悪くない記憶だ
				DislikeBiome: "{BiomeName}で暮らすのか...あまり好みじゃないな、人間と鉢合わせるのは避けたい"
				HateBiome: ここは気に入らない、{BiomeName}は妙な聖なる気配があってな...どうにも居心地が悪い
				LoveNPC: "{NPCName}は面白い道具を売っているな。なかなか抜け目もない、嫌いじゃない"
				LikeNPC: "{NPCName}は悪くないやつだ"
				DislikeNPC: "{NPCName}はずっと疑うような目で見てくる...そのうち『浄化』でもするつもりかもしれないな"
				HateNPC: "{NPCName}がな、私を弱った老人だと思って治療しようとしてくるんだ...悪いが離してもらえないか"
				LikeNPC_Princess: "{NPCName}は悪くない"
				Princess_LovesNPC: "{NPCName}は気に入っている、どこか昔の老人を思い出す"
			}

			Newb: {
				Content: ここ好き！
				NoHome: おうちどこ？
				FarFromHome: 迷っちゃった...帰り道わかる？
				LoveSpace: 人が少ない！やったー！
				DislikeCrowded: 顔が多すぎる！
				HateCrowded: 顔が多すぎる！
				LoveBiome: "{BiomeName}大好き！なんかいい思い出が...えっと..."
				LikeBiome: "{BiomeName}いいね。緑って好き"
				DislikeBiome: つまんない場所！砂きらい！
				HateBiome: ...{BiomeName}、なんか悲しくなる
				LoveNPC: "{NPCName}も魔法使うの？ボクと同じだ！"
				LikeNPC: "{NPCName}好き！"
				DislikeNPC: "{NPCName}から悪い感じする...すごくイヤ！"
				HateNPC: "{NPCName}へのこの嫌いさは...君にはわからないよ"
				LikeNPC_Princess: "{NPCName}、なんか...ボクに似てる気がする！好き！"
				Princess_LovesNPC: "{NPCName}って変だけど、好き！"
			}

			TBot: {
				Content: 今はとても穏やかな気分です、聞いてくれてありがとう。
				NoHome: 風雨にさらされるのは好きではありません。しばらく滞在できる住居か避難所はありますか？
				FarFromHome: ......かなり迷ってしまったようです。この辺りには見覚えがありません。
				LoveSpace: ここはとても静かですね。心地よいです。
				DislikeCrowded: 入居者の不満が高まっています。この過密状態を改善すべきでしょう。
				HateCrowded: 入居者の不満が高まっています。この過密状態を改善すべきでしょう。
				LoveBiome: この土地の活気はとても心地よいですね。
				LikeBiome: この環境は美しいですが、未知の魔力や生物には少し不安を感じます。
				DislikeBiome: 砂が私の繊細な構造を傷つけます。別の場所へ移していただけますか？
				HateBiome: どうしてこのような場所に......。できるだけ早く移動をお願いします。
				LoveNPC: "{NPCName}はよく私に意見を求めます。助けになれるのは嬉しいことです。"
				LikeNPC: "{NPCName}とは機械いじりの趣味が合います。良い関係です。"
				DislikeNPC: "{NPCName}の生体構造は理解しがたいですね。"
				HateNPC: あの存在......サイボーグ。見るたびに回路がざわつきます。
				LikeNPC_Princess: "{NPCName}は検査のあとにいつもキャンディをねだるんです。かつて大切にしていた誰かを思い出しますね。"
				Princess_LovesNPC: "{NPCName}のこと、好きですよ。"
			}

			Zephos: {
				Content: 特に問題はないぜ。
				NoHome: よぉ、俺に泊まる家を貸してくれないか？
				FarFromHome: よぉ、自分の家が見つからねぇんだ。手伝ってくれないか？
				LoveSpace: この場所、めっちゃ広いな！剣術の練習にぴったりだ！
				DislikeCrowded: うわ、人多くねぇか？
				HateCrowded: うわ、人多くねぇか？
				LoveBiome: "{BiomeName}にいると、仲間から逃げてダエレルに会った時のことを思い出すな！人生最高の瞬間だった！"
				LikeBiome: "{BiomeName}っていいな。鳥のさえずりや花の香りが聞こえてくる。"
				DislikeBiome: ここ寒すぎだろ、ブーツの中で震えてるぜ！
				HateBiome: この場所、マジで最悪だ！
				LoveNPC: "{NPCName}とは大の仲良しだ。近くに住めるのは最高だな！"
				LikeNPC: "{NPCName}はいい奴だ！あいつがモノを吹っ飛ばすのを見るのが好きなんだ！"
				DislikeNPC: "{NPCName}は嫌な記憶を思い出させるし、臭いまで最悪だ！"
				HateNPC: "{NPCName}には絶対に金を渡さねぇ！絶対にな！！"
				LikeNPC_Princess: "{NPCName}のこと、好きだな。"
				Princess_LovesNPC: "{NPCName}のこと、好きだな。"
			}
		}

