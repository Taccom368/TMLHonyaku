			BileArrow: {
				DisplayName: 胆汁の矢
				Tooltip: 敵の防御力を減少させ、ライフを吸収する
			}

			BileBullet: {
				DisplayName: 胆汁の弾丸
				Tooltip: 敵の防御力を減少させ、ライフを吸収する
			}

			EnergyPack: {
				DisplayName: エナジーパック
				Tooltip:
					'''
					インベントリ内にあると、エネルギー兵器の使用が可能になる
					エネルギー兵器は相手の防御を貫通する
					1つにつき100エナジーを保持し、最大3つまで重複可能
					4つ以上所持しても最大エナジーは増加しない
					'''
			}

			Divinity: {
				DisplayName: ディヴィニティ
				Tooltip:
					'''
					左クリックを押し続けると小さな太陽を生成し、マナを消費してチャージを始める
					十分にチャージされた後に離すことで、カーソル位置に向けて発射する
					'''
			}

			Dusksong: {
				DisplayName: ダスクソング「黄昏の絆」
				Tooltip:
					'''
					敵に命中すると分裂する大きな光を放つ
					地形を貫通する
					'''
			}

			GigapeiliContactor: {
				DisplayName: ギガペイリ・コンタクター
				Tooltip:
					'''
					近距離に電撃を拡散して放つ
					右クリックでドローンを展開または回収できる
					ドローンに電撃を当てると、最も近い敵に向けて反射する
					'''
			}

			GlobalDischarge: {
				DisplayName: グローバル・ディスチャージ
				Tooltip:
					'''
					不安定な雷球を放ち、爆発させる
					左クリックを押し続けることで雷球を安定させ、慣性を利用して振り回すことができる
					左クリックを離す、または急な旋回等でエネルギーが途切れることで、雷球は爆発する
					球の移動速度が速いほど与えるダメージが増加する
					'''
			}

			LightningRod: {
				DisplayName: ライトニングロッド
				Tooltip:
					'''
					左クリックを押し続けて電力をチャージし、離すとカーソル位置に雷撃を放つ
					チャージ量が多いほど敵に連鎖し、ダメージも増加する
					最大までチャージするとダメージは減少するが、攻撃範囲が広がる
					'''
			}

			Nanoswarmer: {
				DisplayName: ナノ・スウォーマー
				Tooltip:
					'''
					敵の体内に侵入し内部から破壊するナノマシン弾を連射する
					敵の防御力をほとんど無視する
					「ナノマシンだよ、ボウヤ」
					'''
			}

			NoidanSauva: {
				DisplayName: ノイダン・サウヴァ
				Tooltip: 魅惑的な火花を放つ魔女の杖
			}

			Pommisauva: {
				DisplayName: ポンミサウヴァ
				Tooltip:
					'''
					爆弾を3連続まで放つ
					爆弾は地形を破壊できる
					「地面を効率的に破壊するために作られた魔法の杖」
					'''
			}

			Rockslide: {
				DisplayName: ロックスライド
				Tooltip:
					'''
					大量の岩をプレイヤーの頭上に最大10個浮かべる
					左クリックを離すとカーソル方向へ一斉に射出される
					'''
				Lore:
					'''
					「古代王テネブリスが所有していた遺物。この書物に記された文言は、
					精神魔法を極めるための知識を秘めていると伝えられている。

					テネブリス王はエレロンの首都アルガスを治めており、
					豊かな生命の地と不毛の死の地に囲まれた国を支配していた。
					彼の古代に関する知識は、まさに無限とも言われている。」
					'''
			}

			SunshardGreatstaff: {
				DisplayName: 太陽の大杖
				Tooltip:
					'''
					救済の炎を放つ
					3連射ごとに聖なる光線を放つ
					'''
				Lore:
					'''
					「タモールの修道院にて聖職者たちによって守られていた黄金の杖。
					聖なる魔力を宿し、その治癒の力が特に崇められていた。
					多くの人々が、この杖の癒しの力を求め、自らや愛する者のために追い求めたという。」
					'''
			}

			Synthesizer: {
				DisplayName: シンセサイザー
				Tooltip: 地面を伝っていく音符の波を放つ
			}

			XenomiteScepter: {
				DisplayName: ヘリックスセプター
				Tooltip:
					'''
					感染する螺旋弾を放つ
					連続して発射するごとに弾速が増加する
					'''
			}

			BlindJustice: {
				DisplayName: ブラインドジャスティス「悪魔の恐怖」
				Tooltip:
					'''
					左クリックを押し続けて「輝光の回転斬り」をチャージする
					物理攻撃（接触ダメージまたは武器攻撃）を受ける直前に右クリックでパリィを行い、
					無敵時間を獲得する
					敵が静止している、またはプレイヤーの半分以下の速度で移動している場合は
					接触攻撃によるパリィは発動できない
					パリィ成功後に左クリックで即座に「輝光の回転斬り」で反撃を行う
					悪魔系の敵へのダメージが2倍に増加する
					'''
				Lore:
					'''
					「優雅かつ神聖。この武器は高位テンプラーの著名な一員、
					エイメンが所有していた。彼は刃が死後も聖性を保つよう、
					自身の魂の一部をその中に刻み込んだという。
					エイメンはこの武器を自らの肉体の一部のように扱い、
					数多の強大な悪魔を討ち払った。」
					'''
			}

			BloodstainedPike: {
				DisplayName: 血塗れのパイク
				Tooltip:
					'''
					構えたまま突進することで弱い敵を貫く
					敵を10秒間貫く、または同時に5体まで貫いた場合、
					敵の命を吸収して10秒間武器が強化される
					'''
			}

			Chernobyl: {
				DisplayName: セントリフュージ
				Tooltip:
					'''
					この武器で敵を倒すと爆発する
					「臨界点突破！」
					'''
			}

			CrystalGlaive: {
				DisplayName: クリスタルグレイヴ
				Tooltip:
					'''
					左クリックで近距離コンボ攻撃を行い、敵に命中することで連撃が続く
					右クリックで中距離に結晶の破片を発射
					左クリックのコンボを完遂すると、右クリックの能力が5発分強化される
					'''
			}

			CyberChakram: {
				DisplayName: サイバーチャクラム
				Tooltip: ""
			}

			ForgottenGreatsword: {
				DisplayName: 忘れられた大剣（オフォス）
				Tooltip:
					'''
					左クリックで剣を振り回す
					しばらくするとプレイヤーを包み込む火炎の嵐を形成し、{0}ダメージを与える
					左クリックを離すと火炎の嵐が解放され、周囲の敵を吹き飛ばす
					'''
				Lore:
					'''
					「銀の刃に鋼の柄を持つ剣。伝説の鍛冶師オフォスによって
					アングロンの地で鍛えられた。
					火炎魔法の使い手として知られた彼は、自身の魔力を宝石に封じ、
					それを武器に埋め込んだという。
					この剣は、北丘領で伝統的に用いられたデザインを採用している。」
					'''
			}

			GravityHammer: {
				DisplayName: グラビティハンマー
				Tooltip: 地面を叩きつけて衝撃波を発生させる
			}

			HammerOfProving: {
				DisplayName: 試練のハンマー
				Tooltip:
					'''
					空中で左クリックを押し続けると急降下攻撃を行う
					地面に叩きつけると、敵への跳ね返り回数に応じて{0}ダメージの聖なるハンマーが出現
					聖なるハンマーはさらに{1}ダメージを与える
					所持中は落下速度が増加する
					一定以上の速度で落下すると敵をスタンさせる
