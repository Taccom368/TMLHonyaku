			PetrifiedWoodSword: {
				DisplayName: 石化した木の剣
				Tooltip: 「焦げた小枝程度の役にしか立たない」
			}

			SlayerFist: {
				DisplayName: スレイヤーのロケットパンチ
				Tooltip:
					'''
					追尾するロケットパンチを発射する
					左クリックを長押しすると突進し、近距離の敵を殴り飛ばす
					'''
			}

			Spellsong: {
				DisplayName: スペルソング「西方の核」
				Tooltip:
					'''
					斬撃が{0}の波を放つ
					左クリックを長押しすると3連撃のコンボを繰り出し、
					最後の一撃で光線を放ち、幻影剣を呼び出す
					'''
				Lore:
					'''
					「西方の地、レイヴンクラグ山脈を越えた
					遥か西の国から伝わったとされる、神話の剣。
					これは模造品だが、かつて『西の男』がこれを振るい、
					多くの邪悪を討ち払ったという。」
					'''
			}

			SwordRemote: {
				DisplayName: クリーヴァー・リモート
				Tooltip:
					'''
					オメガ・クリーヴァーを呼び出し、強力な攻撃を放つ
					右クリックで攻撃モードを切り替える
					クールダウン：15秒
					「やっぱりサイズは重要だ」
					'''
				Mode1: スイングモード
				Mode2: スタブモード
				Mode3: ソードバーストモード
				Mode4: レッドプリズムモード
			}

			TidalWake: {
				DisplayName: タイダルウェイク
				Tooltip:
					'''
					渦潮を発生させ、弱い敵を引き寄せる
					この武器で敵を倒すとライフを回復する
					'''
			}

			TinyCleaver: {
				DisplayName: タイニー・クリーヴァー
				Tooltip: 攻撃時に刃の節が分離し、リーチが伸びる
			}

			WraithSlayer: {
				DisplayName: レイススレイヤー
				Tooltip:
					'''
					敵を倒すと一定確率で呪われた侍を召喚する
					呪われた侍は一時的な従者として共に戦う
					幽霊系の敵に追加ダメージを与える
					'''
				Lore:
					'''
					「北イソンの屋敷で見つかった古い剣。
					鍛冶師の魂が宿ると伝えられている。
					この剣を買い取った男は、やがて狂気に呑まれ、
					家族を斬り捨てたという。」
					'''
			}

			BileLauncher: {
				DisplayName: バイルランチャー
				Tooltip:
					'''
					胆汁グレネードを弾薬として使用する
					放射性の粘液を噴出する
					'''
			}

			CorruptedDAN: {
				DisplayName: 破損したD.A.N
				Tooltip:
					'''
					ロケット弾を2連射する
					左クリックを押し続けると回転しながら発射し、
					追尾ロケットを高速乱射する
					(15[i:Redemption/EnergyCell]消費) 
					下向きに構えたまま長押しで赤いビームをチャージし、着弾時に爆発を起こす
					通常時は66%、回転射撃時は90%の確率で弾薬を消費しない
					'''
			}

			CorruptedDoubleRifle: {
				DisplayName: 破損したダブルライフル
				Tooltip:
					'''
					マスケット弾を高速弾に変換する
					命中を重ねることでヒートゲージが増加し、
					外すと減少する
					ヒートゲージの量に応じて最大40%までダメージが増加
					(6[i:Redemption/EnergyCell]消費) 
					最大ヒート時に右クリックで
					2本の灼熱ビームを発射し、ダメージボーナスをリセットして
					{0}ダメージを与える
					33%の確率で弾薬を消費しない
					'''
			}

			DAN: {
				DisplayName: D.A.N
				Tooltip:
					'''
					使用時に弾丸を2連射する
					左クリックを押し続けると回転しながら弾を撃ち出し、
					弾丸を高速乱射する
					(15[i:Redemption/EnergyCell]消費) 
					下向きに構えて長押しで紫のビームをチャージし、着弾時に爆発を起こす
					通常時66%、スパイラル時90%の確率で弾薬を消費しない
					「侵入者より、愛を込めて」
					'''
			}

			DoubleRifle: {
				DisplayName: ダブルライフル
				Tooltip:
					'''
					マスケット弾を高速弾に変換する
					33%の確率で弾薬を消費しない
					「侵入者より、愛を込めて」
					'''
			}

			DrillRevolver: {
				DisplayName: ドリルリボルバー
				Tooltip:
					'''
					弾丸をドリル弾に変換し、敵や地形を貫通する
					相手の防御値を減少させ、防御を貫通する
					'''
			}

			FlakCannon: {
				DisplayName: フラックキャノン
				Tooltip:
					'''
					グレネード（粘着、弾むグレネードも可）を弾薬として使用する
					防御を貫通するフラックグレネード弾を発射する
					左クリック長押しでチャージし、連続射撃を行う
					連続射撃でも消費するグレネードの数は変化しない
					「ドッカンとバンバンと、まさに非現実的な大爆発」
					'''
			}

			GhastlyRecurve: {
				DisplayName: ガストリーリカーブ
				Tooltip:
					'''
					右クリックで狙った地点に霊魂を放ち、
					2つの霊魂の間に「霊の裂目」を生成する
					裂目を通過した矢はスピリットアローへ変化し、
					命中時に追尾する破片へと分裂して{0}ダメージを与える
					'''
			}

			HyperTechRevolvers: {
				DisplayName: ハイテクリボルバー
				Tooltip:
					'''
					マスケット弾をナノバレットに変換する
					右クリックで片方を空中に投げ、キャッチ成功で連射速度が5秒間増加
					キャッチに失敗すると、5秒間片手撃ちになり攻撃速度が激減する
					'''
			}

			PrototypeAtomRifle: {
				DisplayName: プロトタイプ・アトムライフル
				Tooltip:
					'''
					(4[i:Redemption/EnergyCell]消費) 
					マスケット弾をプラズマ弾に変換する
					インベントリにエナジーパックが必要
					'''
				Lore:
					'''
					「テオクローム社の実験兵器。
					会議の席で『核動力スナイパーライフルを作ろう』という
					思いつきから誕生した。
					なぜか試作機は正常に動作し、放射線による死者数も
					驚くほど少なかったという。」
					'''
			}

			SlayerGun: {
				DisplayName: ハイテクブラスター
				Tooltip:
					'''
					(2〜6[i:Redemption/EnergyCell]消費) 
					マスケット弾をエナジーボルトに変換する
					右クリックで射撃モードを切り替える
					インベントリにエナジーパックが必要
					'''
				Mode1: バラージショット
				Mode2: スプレッドショット
				Mode3: リバウンドショット
			}

			SteampunkMinigun: {
				DisplayName: スチームパンクミニガン
				Tooltip:
					'''
					左クリックを長押しで武器のクランクを回し、短時間高速射撃状態になる
					クランクを回した時間が長いほど射撃時間が延びる
					射撃中に長押しすることでさらにクランクを回すことが可能だが、移動速度が減少する
					マスケット弾を高速弾に変換する
					66%の確率で弾薬を消費しない
					'''
				Lore:
					'''
					「古代の真鍮技術の遺産。
					錆びた金属の腕を持つ隠者によって発掘された。
					氷原の山々には、滅びかけた北方民族と
					亡国の避難民が遺した技術が今も眠っている。」
					'''
			}

			ToxicGrenade: {
				DisplayName: 胆汁グレネード
				Tooltip: 放射性の毒雲を残すグレネードを投げる
			}

			UraniumRaygun: {
				DisplayName: ウラン光線銃
				Tooltip:
					'''
					(2[i:Redemption/EnergyCell]消費) 
					ウランの輪を発射する
					敵と地形を貫通する
					インベントリにエナジーパックが必要
					'''
			}

			AndroidHologram: {
				DisplayName: アンドロイドホログラム
				Tooltip: 共に戦う小型のアンドロイドを召喚する
			}

			GolemStaff: {
				DisplayName: 太陽神の杖
				Tooltip:
					'''
					{$CommonItemTooltip.Sentry}
