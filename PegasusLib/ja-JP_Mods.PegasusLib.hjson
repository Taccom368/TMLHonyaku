NotSynced_KeybindHandlerPlayer: {
	Base: KeybindHandlerPlayerですが、サーバーにPegasusLibが存在しないため、一部のキーバインドが他のクライアントで期待どおりの効果を発揮しない可能性があります
	1: "{n}は{$Base}を使用します"
	2: "{n}と{n}は{$Base}を使用します"
	Any: "[{n}、]および{n}は{$Base}を使用します"
}

NotSynced_WeakSyncedAction: {
	Base: WeakSyncedActionですが、サーバーにPegasusLibが存在しないため、一部のアクションは他のクライアントで期待どおりの効果を発揮しない可能性があります
	1: "{n}は{$Base}を使用します"
	2: "{n}と{n}は{$Base}を使用します"
	Any: "[{n}、]および{n}は{$Base}を使用します"
}

