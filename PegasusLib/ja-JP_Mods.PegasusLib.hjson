		preferredTextCursor: {
			Label: 優先テキスト入力カーソル
			Tooltip: PegasusLibを使用するテキスト入力フィールドで使用されるテキストカーソルの種類
		}

		ProceduralLightSourceDyeRate: {
			Label: プロシージャル光源染料のレート
			Tooltip:
				'''
				未知の染料がサポートされている光源の色を照会する頻度（照会あたりのティック数）
				0に設定すると、光源は既知の染料のみで染色されます
				低い値を設定すると、高性能なコンピューターが必要になります
				'''
		}
	}

