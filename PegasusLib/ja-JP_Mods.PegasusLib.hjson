		showAdditionalDebuffsTooltip: {
			Label: 追加のデバフを表示するツールチップ
			Tooltip: 通常のツールチップに記載されていないバフ効果を表示するためのツールチップの行を追加するかどうか
		}

		colorBuffHints: {
			Label: バフのヒントに色を付ける
			Tooltip: ""
		}

		invertOnHitBuffHintColor: {
			Label: 「命中時」効果のバフヒントカラーを反転する
			Tooltip: ""
