	FargoSeedConfectionConfiguration: {
		DisplayName: Fargoシード：Confection設定
		Headers.DrunkSeedRequiresFargosbestofbothworldsmod: Drunk Seed（Fargo's Best of Both Worlds Mod必須）

		BothGoods: {
			Label: "[i:526][i:TheConfectionRebirth/CookieDough] 両方有効"
			Tooltip: ""
		}
	}

	ConfectionServerConfig: {
		CookieSpread: {
			Tooltip:
				'''
				No Spread:
				　お菓子楽園専用タイルは広がりません
				　ワールド生成でも出現しません

				Partial Spread:
				　お菓子楽園専用タイルは、拡散可能なタイルが
				　6x6範囲内にあるときのみ広がります（例: クリームストーン、クリームグラスなど）

				Full Spread:
				　以下のタイルが拡散するようになります:
				　　　クッキーブロック
				　　　クリームブロック
				　　　ピンクフェアリーフロス
				　　　パープルフェアリーフロス
				　　　ブルーフェアリーフロス
				　　　クッキエスト・クッキーブロック
				　　　すべてのクリームストーン系宝石
				'''
			Label: クッキー＆クリームの広がり
		}

		Headers.ConfectionServersideConfig: Confection サーバー側設定
		DisplayName: Confection サーバー設定
	}
}

