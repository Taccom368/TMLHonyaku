	SpiritHammer.DisplayName: スピリットハンマー

	StormCloudBoss: {
		DisplayName: ストームクラウド
		BestiaryFlavorText: ストームクラウドは空の守護者だ。雷と灼熱の雨で潜在的な脅威を攻撃する。

		BossChecklistIntegration: {
			SpawnInfo: "{0} を地上で使う"
