	ShimmerTech: {
		DisplayName: シマーメーター
		Tooltip:
			'''
			[c/ff0000:Debug Item]
			自身のシマー効果を取り除く
			<right>でワールド全体のシマー効果を取り除く
			バイタルクリスタル
			アルケインクリスタル
			イージスフルーツ
			アンブロシア
			グミワーム
			ギャラクシーパール
			高度な戦闘テクニック：第２巻
			旅商人のカバン
			「ああ、永遠に見える！」
			'''
	}

	Dummy: {
		DisplayName: ダミーのかかし
		Tooltip:
			'''
			DPSのテストに使える
			左クリックでカーソルの位置にダミーを出現させる
			右クリックで選択したダミーを削除
			Altキーを押しながら右クリックで全てのダミーを削除
			コマンドを使って属性を変更することもできる：
			/dummy info → ダミーのステータスを表示
			/help dummy → ダミーの使用状況を表示
			「叩かないで :)」
			'''
