Items: {

	MagickWand: {
		DisplayName: 爆破の杖
		Tooltip:
			'''
			固定モード： 指定された固定エリアのブロックを破壊する
			自由モード： 選択したブロックを破壊する
			採掘力はインベントリにある一番高いつるはしの採掘力と同じ
			<right>で破壊設定を編集したり、選択した範囲をキャンセルできる
			'''
	}

	SpaceWand: {
		DisplayName: 空間の杖
		Tooltip:
			'''
			[c/0099ff:右クリックでコントロールパネルを開く]
			選択した種類のブロックを指定された範囲に配置することができる
			インベントリのブロックを消費する
			<right>で選択した範囲をキャンセルする
			「私はこれらの道具に同情する」
			'''
	}

	StarburstWand: {
		DisplayName: 星屑の杖
		Tooltip:
			'''
			固定モード： 指定された固定エリアのブロックを破壊する
			自由モード： 選択したブロックを破壊する
			採掘力はインベントリにある一番高いつるはしの採掘力と同じ
			<right>で破壊設定を編集したり、選択した範囲をキャンセルできる
			'''
	}

	CreateWand: {
		DisplayName: 建築の杖
		Tooltip:
			'''
			保管している素材を使って家を建てる
			保管している素材がない場合は、インベントリにある素材を使用する
			十分な素材がないと、不完全な家になる
			<right>で、素材保管庫と家の種類の切り替えパネルを開く
			[c/ff0000:廃棄された場合、中の保管物は返却されません！] 
			'''
	}

	WallPlace: {
		PureName: 技術の杖
		DisplayName: 技術の杖
		Tooltip:
			'''
			カーソルの位置にウォールプレイサーを召喚する
			部屋を自動的に認識し、インベントリにある壁を自動で配置する
			部屋の大きさは最大10000ブロックまで
			ブロック、足場、ドアを境界とみなす
			各プレイヤーは1つしか召喚できない
			<right>で選択モードに切り替える
			'''
	}

	LiquidWand: {
		DisplayName: 液体の杖
		Tooltip:
			'''
			液体を吸収、設置できる
			<right>で液体コントロールパネルを開く
			吸収モード： 選択した範囲内の選択した液体を吸収する
			配置モード： 選択した範囲を選択した液体で満たす
			液体が多すぎても少なすぎても、余分な液体は吸収/設置されない
			'''
	}

	PotionBag: {
		DisplayName: ポーションカバン
		Tooltip:
			'''
			バフポーションを保管できる鞄
			ポーションを持って[c/0099ff:<left>]で収納できる
			[c/0099ff:<right>]でポーションバッグを開く
			このポーションバッグがインベントリの一番上にあるなら、
			拾ったポーションが自動的に回収される
			200スタックのポーションを保管できる
			'''
		TooltipByKeybind: "[c/0099ff:{KeybindName}]で携帯ストレージからポーションを集める"
	}

	BannerChest: {
		DisplayName: バナーボックス
		Tooltip:
			'''
			バナーを保管できる箱
			バナーを持って[c/0099ff:<left>]で収納できる
			[c/0099ff:<right>]でバナーボックスを開く
			このバナーボックスがインベントリの一番上にあるなら、
			拾ったバナーが自動的に回収される
			500スタックのバナーを保管できる
		'''
		TooltipByKeybind: "[c/0099ff:{KeybindName}]で携帯ストレージからバナーを集める"
	}

	Autofisher: {
		DisplayName: 自動釣り機
		Tooltip:
			'''
			配置した釣り機を右クリックでフィッシングパネルを開く
			上の"+"をクリックして水の種類を選択し、釣り竿とルアーを入れると稼働する
			仕組みはプレイヤーが釣りをするときと同じ
			フィッシング・パワーを増加させたり、溶岩で釣りをする能力を付与するアクセサリーを付けることもできる
			餌の消費量は手動釣りの40%
			初期の釣り速度は手動釣り速度の30％だが、様々な方法で上昇させることができる
			- [i:Bass] バス1匹につき、釣り速度が5%上昇し、最大で500%上昇 ([i/s100:Bass])
			- [i:AnglerEarring] 、[i:AnglerTackleBag] 、[i:LavaproofTackleBag] はそれぞれ釣り速度を200%、250%、300%上昇させる
			- ハードモードでは釣り速度が200%上昇
			- 最終速度は基本速度×全てのボーナスの合計で、最大速度は手動釣りの300%まで
			[c/AAAAAA:Quality of Terrariaに対応するModアクセサリも使用可能]
			ほとんどのMod追加バイオームに対応し、釣る対象をフィルタリングできる
			'''
		Tip: "[c/15d36a:{0}, {1}]の釣り機には餌がありません"
		DepthText: "{0} {1}"
	}

	PaintWand: {
		DisplayName: ペイントの杖
		Tooltip:
			'''
			[c/0099ff:<right> でペイントモードパネルを開く]
			範囲内のブロックのペンキを塗ったりはがしたりできる
			[i:塗装はがし]のように、ペンキを落としながらブロックのコケも除去できる
			999以上スタックしているペンキは消費しない
			'''
	}

	ConstructWand: {
		DisplayName: 工事の杖
		Tooltip:
			'''
			[c/0099ff:<right> で建設パネルを開く]
			自由に構造物を配置できる
			記録モード - 選択した建設物をファイルとして保存する
			配置モード - 素材が十分にあるなら構造物を配置する
			液体は記録されない
			ワイヤーはプレビューでは表示されないが、記録され、配置される
			詳細は右上のはじめにをクリック
			[c/AAAAAA:ベータテスト機能、このModのSteamワークショップページでバグを報告してください]
			'''
	}

	MoveChest: {
		DisplayName: 虚空の杖
		Tooltip:
			'''
			この杖に宝箱を収納するために使用する
			もう一度使用すると宝箱を置く
			'''
	}

	CoinOne: {
		DisplayName: 幸運のコイン
		Tooltip:
			'''
			かなりツイてるな！
			これはおそらく売れるだろう...
			'''
	}

	ExtremeStorage: {
		DisplayName: ストレージマネージャー
		Tooltip:
			'''
			[c/cc2200:分からない場合はこのマニュアルをお読みください:]
			これは宝箱内のアイテムを管理するために使用する
			カテゴリを選択し、[i:ImproveGame/AddChestIconDummy] をクリックしてそのカテゴリに宝箱を追加する
			宝箱の並べ替えは、宝箱名の先頭に付けられた識別子によって行われる。[c/0088dd:宝箱名を後から編集しないように！]
			家具やポーションはそれぞれのカテゴリに入れ、その他のアイテムは「全て」のカテゴリに入れる
			[c/0099ff:携帯作業台] や [c/0099ff:無限ポーション] は、対応するカテゴリに保管すると、全てのプレイヤーが効果を得られる
			[c/cc2200:マルチプレイヤーモードで複数のストレージマネージャーを配置すると、送信されるパケットが増加し、ラグの原因になる可能性がある] 
			'''
	}

	GlobeBase: {
		DisplayName: "{0}探知機"
		Tooltip:
			'''
			マップ上に{0}をマークする
			[c/CC88AA:個人設定]でマーカーを非表示にできる
			'''
		Tooltip_Multi:
			'''
