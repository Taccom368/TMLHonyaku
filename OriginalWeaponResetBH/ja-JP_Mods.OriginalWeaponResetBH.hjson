		Tooltip:
			'''
			ダメージが20%増加
			クリティカル率が12%上昇
			'''
		SetBonus:
			'''
			5秒間攻撃しなかった場合、無意識状態になる
			無意識状態中は敵に狙われにくくなる
			被ダメージを80%軽減
			次の攻撃のダメージが5倍になる
			ダメージを受けるか、敵に接触すると解除される
			'''
	}

	VineWhip: {
		DisplayName: 蔓の鞭
		Tooltip:
