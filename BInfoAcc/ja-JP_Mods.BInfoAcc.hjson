Items: {
	EngiRegistry: {
		DisplayName: エンジニアの登録簿
		Tooltip:
			'''
			使用できるセントリースロットの数と、現在使用されているスロットの数を表示
			「セントリースロットの上限に近づいている」
			'''
	}

	AttendanceLog: {
		DisplayName: 出席記録
		Tooltip: 使用できるミニオンスロットの数と、現在使用されているスロットの数を表示
	}

	FortuneMirror: {
		DisplayName: 幸運の鏡
		Tooltip: 運を表示
	}

	HitMarker: {
		DisplayName: ヒットマーカー
		Tooltip:
			'''
			コンボのヒット数、持続時間、および合計ダメージを表示
			コンボは、3秒以内に連続してヒットした攻撃で構成される
			'''
	}

	RSH: {
		DisplayName: C.R.Mカウンター
		Tooltip: コンボ数、ライフ回復量、マナ消費量を表示
	}

	SafteyScanner: {
		DisplayName: 安全スキャナー
		Tooltip: 敵の出現率を表示
	}

	ScryingMirror: {
		DisplayName: 占いの鏡
		Tooltip: 運、セントリースロット、ミニオンスロットを表示
	}

	SmartHeart: {
		DisplayName: スマートハート
		Tooltip:
			'''
			ライフの回復量や減少量を表示
			「しっかり歩数を確保しよう」
			'''
	}

	BiomeCrystal: {
		DisplayName: バイオームのクリスタル
		Tooltip: 現在いるバイオームを表示
	}

	Magimeter: {
		DisplayName: マジメーター 
		Tooltip: マナの回復量、マナを消費するアイテムを使用時の消費量を表示
	}

	WantedPoster: {
		DisplayName: 指名手配の張り紙
		Tooltip:
			'''
			狙われやすさを表示
			これは、敵があなたを標的にする確率を示す
			「『生きてるか』の部分すら省略したのか…」
			'''
	}

	ThreatAnalyzer: {
		DisplayName: 脅威探知機
		Tooltip: 敵の出現率、狙われやすさ、バイオームを表示
	}
}

