Configs: {
	ConfigServer: {
		DisplayName: メイン設定

		easySell: {
			Label: 商人が新しいアクセサリを販売する
			Tooltip:
				'''
				オンにすると商人が月相によってこのModの情報アクセサリーを販売するようになります
				新しい情報表示を簡単に入手したい場合に最適です
				'''
		}

		extendedRecipe: {
			Label: PDAのレシピに新しいアクセサリを追加する
			Tooltip:
				'''
				PDAのレシピに占いの鏡、C.R.Mカウンター、脅威探知機を追加するか切り替えます
				携帯電話でこれ以上面倒な手続きをしたくない場合は、これをオフにしてみてください
				'''
		}

		updatedPhones: {
			Label: PDA、携帯電話、シェルフォンで新しい情報表示を有効にする
			Tooltip:
				'''
				PDAとそのアップグレードがこのModの新しい情報表示を継承するかどうかを切り替えます
				Thorium Modの願いの鏡にも対応しています
				'''
		}

		refreshRate: {
			Label: 情報更新のレート
			Tooltip:
				'''
				一部の情報表示（出現率/上限、バイオームなど）は、毎フレーム情報が更新されません
				これは、テキストのちらつきを防ぎ、遅延の可能性を低減するためです
				更新間隔はここでカスタマイズできます。設定値は、各更新間のティック数です
				参考までに、1秒＝60ティックです
				'''
		}

		cycleRate: {
			Label: 情報表示のサイクルレート
			Tooltip:
				'''
				特定の情報表示（出現率/上限、コンボ、バイオーム）には、複数の情報行が周期的に表示されます
				この動作は、砂嵐が発生しているときの通常の天気ラジオの動作と似ています
				この設定により、さまざまな情報ラインの切り替え速度が倍増します
				'''
		}

		prioModBiomes: {
			Label: バイオーム表示でModバイオームを優先
			Tooltip:
				'''
				バイオーム表示で、（サポートされている）Modバイオームが（ほとんどの）バニラバイオームより先に表示されるようにします
				近隣の全てのバイオームは引き続き順番に表示されます。優先度の高いバイオームは、サイクルの早い段階で表示されます
				バイオーム表示は以下のModをサポートしています:
				「Thorium Mod」、「Calamity Mod」、「Mod of Redemption」、「Exxo Avalon Origins」、「The Stars Above」、「Spirit Mod」、「Spooky Mod」、 
				「Confection Rebaked」、「The Depths」、「Aequus」、「Verdant」、「Food, Furniture & Fun」、「Remnants」
				'''
		}

		simpleDisplay: {
			Label: 簡略表示
			Tooltip:
				'''
				特定の表示画面から余分な記号を削除します。具体的には、複数の情報行が交互に表示される表示画面に表示される「+」記号を削除します。
				また、スポーン率/制限表示の前の「~」（「およそ」の略）も削除します。
				バイオーム、コンボ、および出現率/上限の表示に影響します
				'''
		}
	}
}
