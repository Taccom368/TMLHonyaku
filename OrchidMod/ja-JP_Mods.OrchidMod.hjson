Configs: {
	OrchidClientConfig: {
		DisplayName: Orchid クライアント設定

		Headers: {
			General: 一般
			Guardian: ガーディアン
			Shapeshifter: シェイプシフター
		}

		ShowClassTags: {
			Label: クラスタグを表示
			Tooltip: クラスタグの表示/非表示を切り替えます
		}

		ShowModTags: {
			Label: Modタグを表示
			Tooltip:
				'''
				Modタグの表示/非表示を切り替えます (Load Crossmod-Content without required mods must be enabled in Orchid Server Config)
				Orchid サーバー設定にある「必要なModがなくてもクロスモッドコンテンツを読み込む」がオンになっている必要があります
				'''
		}

		GuardianUseOldHammerUi: {
			Label: 古いガーディアンのハンマーUI
			Tooltip: ガーディアンのハンマーUIをペーパーマリオ風のスタイルに変更します
		}

		GuardianSwapPaviseImputs: {
			Label: パヴィスの操作を入れ替える
			Tooltip: ガーディアンのパヴィスの右クリックと左クリックを入れ替えます
		}

		GuardianSwapGauntletImputs: {
			Label: パリィの操作を入れ替える
			Tooltip: ガーディアンの武器のパリィと攻撃の操作を入れ替えます
		}

		GuardianAltChargeSounds: {
			Label: ガーディアンのチャージ音を変更する
			Tooltip: ガーディアン武器を最大までチャージしたときの効果音を変更します
		}

		GuardianBlockCancelChain: {
			Label: パヴィスのブロックをキャンセル時、再度ブロックする
			Tooltip: パヴィスのブロックをキャンセルしたとき、可能なら再度ブロックします
		}

		ShapeshifterUseHairColor: {
			Label: 変身に髪の色を反映させる
			Tooltip:
				'''
				「奇妙なヘアピン」の効果を常に発揮させ、変身時の色を髪の色と同じにします
				「奇妙なヘアピン」は変身時の色を変更するのに使用できます
				'''
		}

		ShapeshifterHookDelay: {
			Label: ショールのダッシュの遅延
			Tooltip:
				'''
				「ショール」系アクセサリを装備している際、「フック」をどのくらいの時間、
				押し続ける必要があるか変更します
				'''
		}

		ShapeshifterHookDashRelease: {
			Label: ショールのダッシュの操作を変更する
			Tooltip: 「フック」を押すのではなく、離すと「ショール」系のダッシュを行います
		}

		ShapeshifterScrollDelay: {
			Label: シェイプシフターのスクロール遅延
			Tooltip: スクロールした際、プレイヤーが新しく選択した武器の変身を行うまでの遅延を変更します
		}

		GuardianChargeCursor: {
			Label: ガーディアンのチャージの表示の位置を変更する
			Tooltip: ガーディアン武器をチャージするとプレイヤーではなく、カーソルの近くにアイコンが表示されます
		}

		GuardianMinHoldTimer: {
			Label: ガーディアンのチャージの最小タイマー
			Tooltip:
				'''
				UIが表示され、篭手などの武器がスラムを消費する前に、
				チャージする必要がある時間の最小タイマーをフレーム単位で変更します
				'''
		}

		GuardianMaxHoldTimer: {
			Label: ガーディアンのチャージの最大タイマー
			Tooltip:
				'''
				UIが表示され、篭手などの武器がスラムを消費する前に、
				チャージする必要がある時間の最大タイマーをフレーム単位で変更します
				'''
		}

		GuardianGauntletAlwaysSlam: {
			Label: ガーディアンの籠手は常にスラムを消費する
			Tooltip: オンにするとガーディアンの籠手がチャージ状態に関係なく、スラム攻撃を行うようになります
		}
	}

	OrchidServerConfig: {
		DisplayName: Orchid サーバー設定
		Headers.General: 一般

		LoadCrossmodContentWithoutRequiredMods: {
			Label: 必要なModがなくてもクロスモッドコンテンツを読み込む
			Tooltip: オンにすると必要なModがなくてもクロスモッドコンテンツを読み込みます
		}

		EnableContentAlchemist: {
			Label: 錬金術師のコンテンツ
			Tooltip: オンにすると錬金術師のアイテムを入手できるようになります
		}

		EnableContentGambler: {
			Label: ギャンブラーのコンテンツ
			Tooltip: オンにするとギャンブラーのアイテムを入手できるようになります
		}

		EnableContentShapeshifter: {
			Label: シェイプシフターのコンテンツ
			Tooltip: オンにするとシェイプシフターのアイテムを入手できるようになります
		}
	}
}

