		ImproveChlorophyteBulletsPerformance: {
			Label: クロロファイトの弾丸のパフォーマンスを改善
			Tooltip: クロロファイト弾の悪名高い動作の遅さを、よりパフォーマンスが高く、おそらく見た目も優れたものに置き換えます
		}

		OxfordComma: {
			Label: オックスフォード・カンマ
			Tooltip: 物語、説明、ダイアログに[fool:Configs.OriginClientConfig.OxfordComma.Comma]を付けるか変更します
			Comma: "[ox:,]"
		}

		DisableCoolVisualEffects: {
			Label: パフォーマンスを著しく低下させる視覚効果を無効にする
			Tooltip:
				'''
				シマーコンストラクト、その戦利品[ox:、]、およびグラスファイバーの茂みに関連する特定のエフェクトは、
				低スペックのハードウェアで深刻なラグを引き起こす可能性があります
				これをオンにすると、これらの効果を無効化または置き換えることができます
				'''
		}
	}

