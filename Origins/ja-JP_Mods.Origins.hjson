GuideAdvice: {
	World_Evils: {
		DA_Summon_Item: 恐ろしい粉と奇妙な紐を合成すると神経インパルス操作装置を作れる。{§荒廃}の地のみでしか使えないので気をつけて。
		PA_Summon_Item: 知覚の粉と悪性組織を合成すると怪しげなアイスクリームを作れる。{§不和}の地のみでしか使えないので気をつけて。
		DAltar: "{§ディファイルド}アルターは通常、{§荒廃}の地にあるんだ。その近くにいると、ある種のアイテムを作れるようになる。"
		RAltar: "{§リヴェン}アルターは通常、{§不和}の地にあるんだ。その近くにいると、ある種のアイテムを作れるようになる。"
		DFissure: "{§荒廃}の中継機は大抵、{§荒廃}の地の周辺の溝にあるよ。たくさん壊せば心臓が免疫系に警告する。そいつを倒せば、空から隕石が降ってくるかも！"
		RLesion: ゲルの気泡は大抵、{§不和}の地にあるよ。たくさん壊せばワールドクラッカーが解放される。そいつを倒せば、空から隕石が降ってくるかも！
		Defiled_Heart: "{§荒廃}の地は全ての{§荒廃}の心臓を破壊するまで、汚染を浄化しても元に戻ってしまうよ。心臓は荒廃の洞窟の中心にあるよ。"
		HardmodeAltarD: "{§ディファイルド}アルターを見つけたら必ず破壊しよう。そうすれば何か良い事が起こるよ！"
		HardmodeAltarR: "{§リヴェン}アルターを見つけたら必ず破壊しよう。そうすれば何か良い事が起こるよ！"
	}

	Other: {
		Stone_Mask: 世界の果てまで旅をすれば、邪悪な生き物から身を守ってくれる石の仮面が必ず見つかるよ。
		AcidFreakUnlock: 塩水の池に一人ぼっちのリザードの女性が住んでいるという噂を聞いたよ。確か塩水の池は住むには理想的な場所ではなかったはずだよ…。
		MojoInjection: 自然の恵みをモジョの注射器に変えてみたことはあるかい？世界の邪悪から君を浄化するのに最適なものだと聞いたことがあるよ！
	}
}

Words: {
	2ndrefcasualmale: 男
	2ndrefcasualfemale: 女

	SelectByTag: {
		Fallback: gleeblesnort

		Person!: {
			"": person
			Person;Male!;Casual?: 君
			Person;Female!;Casual?: 貴女
		}

		Pronoun!: {
			Female!: {
				Subject!: 彼女
				Object!: 彼女を
				Possessive!;Dependent?: 彼女
				Possessive!;Independent: 彼女の
				Reflexive: 彼女自身
			}

			Male!: {
				Subject!: 彼
				Object!: 彼を
				Possessive!: 彼ら
				Reflexive!: 彼自身
			}

			Neuter!: {
				"": it
				Possessive!: その
				Reflexive!: 自身
			}
		}
	}
}

