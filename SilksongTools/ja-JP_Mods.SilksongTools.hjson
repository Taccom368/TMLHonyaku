		Tooltip1: 敵が近くにいると、{0}秒ごとにマナを{1}消費して、敵を燃やすウィスプを生成する
	}

	EggOfFlealia_Item: {
		DisplayName: フレアリアの卵
		Tooltip:
			'''
			伝説に語られるノミの母のアイコン。古い時代よりキャラバンで受け継がれてきた。守護と同胞の絆の象徴でもある。
			ライフが最大なら、マナを消費しない
			'''
	}

	Compass_Item: {
		DisplayName: コンパス
		Tooltip:
			'''
			殻を削って作った、精巧な追跡装置。
			深さと横位置を表示する
			'''
	}

	DeadBugsPurse_Item: {
		DisplayName: 死んだムシの財布
		Tooltip: 命尽きた巡礼者が残した財布。
		Tooltip1:
			'''
			死亡してもコインを落とさなくなる
			コインを弾薬として使用する武器を使用中、{0}%の確率でコインを消費しない
			'''
	}

	ShellSatchel_Item: {
		DisplayName: 殻のサッチェル
		Tooltip:
			'''
			古い殻を使って作られた収納容器。
			金庫として使用でき、右クリックで開く
			'''
	}

	ShardPendant_Item: {
		DisplayName: 破片のペンダント
		Tooltip:
			'''
			収集者や職工が身につける、粗野な装飾品。
			ほとんどのスタックできるアイテムのドロップ量が増加する
			'''
	}

	MagnetiteBrooch_Item: {
		DisplayName: マグネタイトのブローチ
		Tooltip:
			'''
			ロザリーへの祈りが刻まれた聖なる石。
			周りのアイテムを着用者のもとに引き寄せる力がある。
			'''
	}

	WeightedBelt_Item: {
		DisplayName: 重いベルト
		Tooltip:
			'''
			脚元の安定しない者が好んで着ける、重い輪。
			ノックバックを無効化し、被ダメージ時の無敵時間を延長する
			'''
	}

	MagnetiteDice_Item: {
		DisplayName: マグネタイトのサイコロ
		Tooltip:
			'''
			マグネタイトを削って作られた遊び道具。持ち主に幸運をもたらすと考えられている。
			ダメージを無効化することがある
			'''
		Tooltip1: クリティカル率が{0}%上昇
	}

	SilkspeedAnklets_Item: {
		DisplayName: シルクアンクレット
		Tooltip:
			'''
			ウィーバーが実験的に作ったアンクレット。
			着用者のマナを利用して機動性を向上させる
			'''
		Tooltip1: マナを消費して飛行時間を延長する
	}

	ThiefsMark_Item: {
		DisplayName: 盗賊の証
		Tooltip:
			'''
			自らが盗賊の一味であることを証明するもの。
			倒した敵からより多くのコインを入手できるが、ダメージを受けるとコインを一部失う
			'''
		Tooltip1:
			'''
			コプリンのよろず屋のリフォージの費用が{0}%割引される
			「勝者はより多く稼ぎ、敗者は損失を被る！」
			'''
	}

	AscendantsGrip_Item: {
		DisplayName: 登攀者の爪
		Tooltip: 光沢を放つピン。壁につかまってその場にとどまることができる。
	}

	BarbedBracelet_Item: {
		DisplayName:トゲの腕輪
		Tooltip: 自らが適切に罰せられていないと感じる者たちが身につける、辛苦の腕輪。
		Tooltip1: ダメージが{0}%増加するが、被ダメージが{1}%増加する
	}

	Scuttlebrace_Item: {
		DisplayName: クモ走りの装具
		Tooltip:
			'''
			殻を覆うようにきつく装着する、背骨のような形状の装具。
			横方向入力2回で逆向きにダッシュし、入力し続けると移動を継続できる
			「戦術的撤退」
			'''
	}

	SpiderStrings_Item: {
		DisplayName: クモの弦
		Tooltip:
			'''
			洗練された古代の器具。音楽と共鳴し、そのパフォーマンスを高める力がある。
			魔法のリズムを演奏し、近づいてくる敵を混乱させる
			アクセサリを表示すると効果範囲が表示される
			'''
		Tooltip_Thorium: エンパワーメントの持続時間を{0}秒延長し、エンパワーメントの効果範囲がわずかに増加
	}

	BlueIcon: {
		DisplayName: 青の道具
		Tooltip: ""
	}

	RedIcon: {
		DisplayName: 赤の道具
		Tooltip: ""
	}

	YellowIcon: {
		DisplayName: 黄の道具
		Tooltip: ""
	}
}

