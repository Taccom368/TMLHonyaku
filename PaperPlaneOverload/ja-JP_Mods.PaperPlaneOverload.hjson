Configs: {
	PaperConfig: {
		Headers: {
			Paper-Planes: 設定
			Cheats: チート
			CrossMod: クロスModヘッダー
		}

		RemoveFancyEffects: {
			Label: エフェクトを減らす
			Tooltip: 遅延を引き起こす可能性のあるいくつかのエフェクトを変更/削除します
		}

		DisplayName: Paper-Plane Overload: クライアント設定

		RemovePaperPrefixes: {
			Label: 接頭辞を削除
			Tooltip:
				'''
				アクセサリにこのModで追加される接頭辞が付かなくなります
				これらの接頭辞はアクセサリから削除されず、リフォージのプールからのみ削除されます
				'''
		}

		TurnPlanesIntoAmmo: {
			Label: 飛行機を弾薬にする！
			Tooltip:
				'''
				飛行機を弾薬として使えるようになります！
				[c/969696:チート設定: 意図的したものではない（でも面白い）]
				-
				既知の問題 
				- 弾薬はリフォージできず、消費しないタイプの飛行機の接頭辞は削除されます
				- 弾薬を確率で消費しない効果で、弾薬を消費しなかった場合、飛行機のパッシブは無効になります
				-
				'''
		}

		TurnWindPhysicsOn: {
			Label: 風の物理法則は全ての弾に影響を与える
			Tooltip:
				'''
				全ての弾が風の影響を受けるようになります
				[c/969696:チート設定: 意図的したものではない（でも面白い）]
				'''
		}

		WindIntensity: {
			Label: 風の強さ
			Tooltip:
				'''
				風の影響の強さを変更します (0% - 1000%)
				[c/969696:チート設定: 意図的したものではない（でも面白い）]
				-
				飛行機の速度は変化せず、方向の強さのみが変化します
				風の物理法則は全ての発射物に影響を与えるがオンだと、他の発射物の速度も変化します
				'''
		}

		RemoveRecycleText: {
			Label: リサイクル時のテキストを削除
			Tooltip: "[c/92F892:「リサイクル！」]ポップアップを削除します"
		}

		RemoveBonusMoonlordDamage: {
			Label: 一部ボスに対するダメージ増加をなくす
			Tooltip:
				'''
				飛行機は基本ダメージが低いため、一部ボスに対して防御力をある程度無視します
				これをオンにするとそれがなくなり、戦闘が難しくなります
				[c/969696:対象 : メカボス (2)、プランテラ (4)、エンプレス (10)、ムーンロードのコア (20)]
				'''
		}
		PlaneLifetime: {
			Label: 飛行機の残存時間 (秒)
			Tooltip:
				'''
				ほとんどの飛行機の残存時間を設定します
				[c/969696:デフォルトは2で、5から60まで設定できます]
				'''
		}
	}

	PaperConfigServer: {
		RemoveNPCItemDrops: {
			Label: アイテムのドロップを削除
			Tooltip:
				'''
				このModで追加されるアイテムをNPCのアイテムのドロッププールから全て削除します
				一部のアイテムは入手できなくなります
				'''
		}

		RemoveNPCShopItems: {
			Label: ショップからアイテムを削除する
			Tooltip:
				'''
				NPCのショップからこのModで追加されるアイテムを全て削除します
				一部のアイテムは入手できなくなります
				'''
		}

		Headers.Items: アイテム
		DisplayName: Paper-Plane Overload: サーバー設定

		RemoveBossBagDrops: {
			Label: トレジャーバッグドロップを削除
			Tooltip:
				'''
				右クリックで開くアイテムから、このModで追加される全てのアイテムを削除します
				一部のアイテムは入手できなくなります
				'''
		}
	}
}

Prefixes: {
	AerodynamicPrefix.DisplayName: 空気力学的な
	AerodynamicTooltip:
		'''
		飛行機のダメージが2増加
		飛行機の速度が4%上昇
		'''
	SustainablePrefix.DisplayName: 持続可能な
	SustainableTooltip:
		'''
		リサイクル率が4%上昇
		飛行機のパッシブ効果の持続時間を4%延長
		'''
	FoilEdition.DisplayName: メッキされた
	FoilEditionTooltip: 飛行機のダメージが5増加
	HolographicEdition.DisplayName: 立体像のような
	HolographicEditionTooltip: 飛行機のクリティカル率が10%上昇
	PolychromeEdition.DisplayName: 多色な
	PolychromeEditionTooltip: 1.5倍
	NegativeEdition.DisplayName: ネガティブな
	NegativeEditionTooltip: 衣装スロットに装備中も機能するが、ダメージがマイナスになる可能性がある
	DextrousPrefix.DisplayName: 器用な
	DextrousTooltip:
		'''
		飛行機の攻撃速度が4%上昇
		4%の確率で飛行機を1機追加で投げる
		'''
}
