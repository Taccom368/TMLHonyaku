	}

	SuperCellCirclet: {
		SetBonus:
			'''
			翼を装備していない時に簡易飛行を付与する
			最大テクニックポイントが2増加
			ステルス上限が110増加
			'''
		Tooltip: ローグダメージが5%増加
		DisplayName: ガルーダサークレット
	}

	NecrosingerSkull: {
		SetBonus:
			'''
			音符が周囲を回転し、各1回まで弾を防ぐ
			すべて破壊されると5秒後に再生成される
			'''
		Tooltip:
			'''
			旋律ダメージが5%増加
			演奏速度が10%上昇
			旋律クリティカル率が5%上昇
			インスピレーション回復速度が15%増加
			'''
		DisplayName: 死の頭蓋
	}

	NecrosingerRibs: {
		Tooltip:
			'''
			旋律ダメージが14%増加
			旋律クリティカル率が5%上昇
			インスピレーション音符のドロップ率が10%増加
			エンパワーメント持続時間が3秒増加
			'''
		DisplayName: 死後の肋骨
	}

	NecrosingerAnkles: {
		Tooltip:
