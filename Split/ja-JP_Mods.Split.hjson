	LatopusGold.DisplayName: 黄金のラトパス

	TheSpirit: {
		DisplayName: スピリット

		Dialogues: {
			Call: 回線接続中...しばらくお待ちください...
			Summon_1: スピリットが参戦した！
			Summon_2: スピリットが出動した！
			Downed: スピリットが倒された！
			Treat_1: 悪党よ、観念せよ！今ここで正義の裁きを受けるのダ！
			Treat_2: 
				'''
				あぁ！通信装置が壊れた！！！
				これが最近どれだけ高いか知ってるのか！？
				'''
			Treat_3: 報告してやる！全部報告してやるからな！
			Escape: <Spirit> それでは皆さん、おやすみなさい！
		}

		Confusion: スピリットは...混乱している？

		DefeatDialogues: {
			Start: 
				'''
				まさかこんなことになるなんて...
				あれ？待って！君、もしかして宇宙海賊...ではない...？
				いやまさかそんなバカな...あぁ～
				もしかして...全部勘違いでした？
				でも通信機は確かにここを指してたし...
				まぁ肝心の通信機も今やスクラップだけど...
				ともかく、これじゃあどうやって帰れっていうんだ...
				'''
			StartConfirm: ゴメンナサイ...

			Talk: {
				0: 炭素生命体がワタシと交流しようとしている。どう対応すれば？
				1: 今チョット取り込み中で...
				2: あぁ、気にしないで。何か良いアイディアが浮かぶのを待ってるんだ。
				3: 妙な曲が聞こえる...なんだか不吉で、タイヘンなことが起こりそう。
				4: 答えは山ほどあるのに、肝心の質問が足りナイ！
			}
		}
	}

