Items: {
	Tooltip: {
		SlimeGun: ...しかし、異星の技術としては平和的すぎる。
		ReforgeWarning: 誰かが鍛え直せるかもしれない
		SharpReforge: 防具モディファイアを取り除ける
		TroublesomeVessel: ...頼むから、お気に入り登録しておいてくれ。
		PrimeRewardsComplete:
			'''
			「どうやら私の極上コレクションは全部受け取り終えたようだね！本当に、今はもう渡せる物が何もないんだ」
			「何と言えばいいかな...[c/{0}:おめでとう]」
			'''
	}

	# Armor
	ContraptionistHat: {
		DisplayName: 発明家の帽子
		Tooltip:
			'''
			「ロケットブースター、レーザー銃、そしてナルシズムは付属していない場合があります」
			召喚できるセントリーの数が1体増える
			ミニオンダメージが14%増加
			'''
		Set:
			'''
			召喚できるミニオンの数が1体増える
			狙った敵を掃射する『ヘリカル・コントラプション』タレットを召喚
			敵を倒したりボスへダメージを与えると弾薬が落ちる
			上方向入力2回でタレットを切り替える
			'''
	}

	ContraptionistChestplate: {
		DisplayName: 発明家の胸当て
		Tooltip:
			'''
			召喚できるセントリーの数が1体増える
