	JellyGelmet: {
		DisplayName: ジェリーゲルメット
		Tooltip:
			'''
			召喚できるセントリーの数が{0}体増える
			セントリー攻撃時、{1} タグダメージを与える
			'''
		Set:
			'''
			Wキー二回入力で、ともに戦う[c/CE861A:ジェリータJr.]を召喚する！
			Double tap W to recall [c/CE861A:ジェリータJr.]
			'''
		SlimeGooberName: ジェリータJr.

		JellyBond: {
			Title: ジェリーボンド
			Description:
				'''
