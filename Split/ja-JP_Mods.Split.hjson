Dialogue: {
	Menace: {
		Defeat:
			'''
			! name Menace
			! portrait 0 1
			! delay 2.2
			! pause_at 2 0.5
			- フン！このメナス様に災いなど訪れるものか！
			! portrait 1 1
			! shake 20 1.0
			! name Menace (Defeated)
			! delay 0.2
			...
			! portrait 2 1
			! delay 1
			...
			'''
		Escape:
			'''
			! name Menace
			! portrait 3 1
			! delay 2
			- つ、次は覚悟なさい！弱虫め！
			'''
	}

	MysteriousStranger:
		'''
		! name Mysterious Stranger
		! portrait 4 0
		! delay 2.5
		! pause_at 9 0.5
		- さあ、見たことを話してみろ。
		- 誰も信じはしないだろうがな。
		'''
}

