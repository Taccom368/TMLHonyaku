	RMagicConch: {
		DontUseMagicConch: 強大な存在に監視されているような気がする...

		RMagicConch: {
			DontUseMagicConch: 強大な存在に監視されているような気がする...
			DisplayName: 魔法の巻き貝
			Tooltip: 耳を澄ますと海の音が聞こえてくる
		}
	}

	GraniteTome: {
		DisplayName: 花崗岩の魔導書
		Tooltip:
			'''
			ゆっくりと敵を追尾する花崗岩エネルギーの球体を召喚する
			命中時に追尾する結晶の破片へと砕け散る
			'''
	}

	GraniteFlower: {
		DisplayName: 花崗岩の花
		Tooltip:
			'''
			結晶の種を発射し、持続するエネルギーの花を咲かせる
			花は数回脈動し、周囲へ結晶の花弁を撒き散らす
			'''
	}

	GraniteThrowingKnife: {
		DisplayName: 花崗岩の投げナイフ
		Tooltip:
			'''
			結晶エネルギーを纏った貫通ナイフを投げる
			最後の命中時または地形への衝突時に結晶の破片へ砕け散る
			'''
	}

	GraniteWalkingBoots: {
		DisplayName: 花崗岩のブーツ
		Tooltip:
			'''
			走行速度と加速力が大幅に増加する
			最高速度時には青い火花を放つ
			'''
	}

	MarbleClub: {
		DisplayName: 大理石の棍棒
		Tooltip:
			'''
			重く遅い一撃で敵を大きく吹き飛ばす
			敵を石化させ、一時的に動きを遅くすることがある
			各振りの初撃で大理石の衝撃波を放つ
			'''
	}

	MarbleHuntingKnife: {
		DisplayName: 大理石の狩猟ナイフ
		Tooltip:
			'''
			素早い斬撃を繰り出す
			3回目の攻撃は広範囲のフィニッシュ攻撃となり、大理石の破片を撒き散らす
			'''
	}

	MarbleDisc: {
		DisplayName: 大理石の円盤
		Tooltip:
			'''
			回転する円盤を投げ、敵や壁の間で跳ね返る
			その後手元へ戻り、最大2つまで同時に飛ばせる
			'''
	}

	MarblePebble: {
		DisplayName: 大理石の小石
		Tooltip:
			'''
			最大ライフが高い敵に対して高いダメージを与える
			地面で1回跳ね返る
			'''
	}

	MarbleShield: {
		DisplayName: 大理石の守護盾
		Tooltip:
			'''
			防御力とノックバック耐性が増加する
			再生する石の盾を維持し、受けた攻撃を1回吸収して破片を放出する
			タイミングよく防御すると投射物を反射する
			'''
	}

	MarbleBalloon: {
		DisplayName: 大理石の風船
		Tooltip:
			'''
			空中で下キーを押すと急降下し、着地時に衝撃波を放つ
			落下ダメージを無効化する
			'''
	}

	MarbleinaBottle: {
		DisplayName: 大理石入りの瓶
		Tooltip: 重い二段ジャンプを付与する
	}

	MarbleCloudBalloon: {
		DisplayName: 大理石の雲入りの風船
		Tooltip:
			'''
			重い二段ジャンプを付与する
			空中で下キーを押すと急降下し、着地時に衝撃波を放つ
			落下ダメージを無効化する
			'''
	}

	TestItem: {
		DisplayName: テキストアイテム
		Tooltip: 本来は所持してはいけないものだ
	}
}

