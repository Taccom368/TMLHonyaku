	UniversalFrost: {
		DisplayName: ユニバーサルフロスト
		Tooltip:
			'''
			雪玉を弾薬として使用する
			雹弾と冷気のオーブを発射する
			オーブは跳ね返り、敵を追尾し、爆発時に氷結ビームを放つ
			連続射撃で氷のエネルギーを蓄積する
			最大チャージ時、次の攻撃で氷河期を解き放つ
			氷河期はカーソル位置に大量の氷柱と吹雪の領域を発生させる
			「万物が静寂に沈むとき、世界を覆うのは永遠の霜のみ」
			'''
	}

	GodslayerScabbard: {
		DisplayName: 神殺しの鞘
		Tooltip:
			'''
			近接武器を持ったまま攻撃しないことでチャージを蓄積する
			最大チャージ状態で攻撃すると2秒間の無敵を得る
			「刃は鞘に収められているが、その殺意ははっきりと伝わってくる
			　時が来れば、神を斬るのに必要なのは一瞬だけだ」
			'''
	}

	Lumberjack: {
		Text1: 数が多すぎる！
		Text2: 電力不足！
		CycleModeText: 循環モード
		ClearModeText: 伐採モード
		DisplayName: ランバージャック
		Tooltip:
			'''
			電力を消費して木材を伐採する
			周囲の木を自動で伐採する
			右クリックで循環モードと伐採モードを切り替える
			循環モードでは木を伐採し続け、苗木を植え直す
			伐採モードでは木を伐採するのみで、植え直しは行わない
			'''
	}

	LifeWeaver: {
		NoValidPositionText: 近くに植えられる場所がない！
		NoEnergyText: 電力が不足している！
		DisplayName: ライフウィーバー
