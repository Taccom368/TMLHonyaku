QuestLogs: {
	QuestNode: {
		FirstQuest: {
			DisplayName: Calamityの世界へようこそ！
			Description: 旅の始まり
			DetailedDescription: 千里の道も一歩から。スタート用の装備を手に入れ、神々とモンスターで満ちた世界に立ち向かう準備をしよう。

			QuestObjective: {
				Description: スタートアイテムを手に入れる
			}
		}

		MiningQuest: {
			DisplayName: 採掘の基本
			Description: 銅鉱石を10個入手する
			DetailedDescription: 地下には無限の富が眠っている。まずはツールを作るための基本的な金属を手に入れよう。
		}

		MiningQuestII: {
			DisplayName: 鉄器時代
			Description: 鉄鉱石を50個集める
			DetailedDescription: 銅は柔らかすぎる。武器を作るには、もっと硬い金属が必要だ。地下深くに降りて、鉄鉱脈を見つけよう。
		}

		MiningQuestIII: {
			DisplayName: ゴールドラッシュ
			Description: 金鉱石を100個集める
			DetailedDescription: 金は単なる通貨ではない。優れた魔法的導電性と延性を持ち、鉄よりも柔らかいが、高度な装備を作るためには欠かせない素材だ。
		}

		BrimstoneElementalQuest: {
			DisplayName: ブリムストーンエレメンタル
			Description: ブリムストーンエレメンタルを倒す
			DetailedDescription: 煉獄の岩山の遺跡で、眠っているエレメンタルエレメンタルを目覚めさせ、倒す。彼女の弾幕に注意。
		}

		CalamitasCloneQuest: {
			DisplayName: カラミタスクローン
			Description: カラミタスクローンを倒す
			DetailedDescription: 憎しみと破壊への欲望に満ちたクローン。こいつを倒し、真の魔女と対峙する資格を証明しよう。
		}

		CrabulonQuest: {
			DisplayName: クラブロン
			Description: クラブロンを倒す
			DetailedDescription: 地下のキノコ群生地で、菌に侵された巨大なカニが潜んでいる。その胞子は非常に危険だ。
		}

		CryogenQuest: {
			DisplayName: クライオジェン
			Description: クライオジェンを倒す
			DetailedDescription: かつての大魔道士は、氷の牢獄に封印されている。解放し、極寒の力を解き放とう。
		}

		DesertScourgeQuest: {
			DisplayName: デザートスカージ
			Description: デザートスカージを倒す
			DetailedDescription: 海のかつての暴君が、乾ききった砂漠で息を切らしている。巨大な顎と部下たちに気をつけろ。
		}

		EaterofWorldsQuest: {
			DisplayName: イーターオブワールド / クトゥルフの脳
			Description: 不浄または真紅のボスを倒す

			QuestObjective: {
				Description: イーターオブワールドまたはクトゥルフの脳を倒す
			}

			DetailedDescription: 邪悪が広がっている。世界の病巣に足を踏み入れ、巨大な虫や忌まわしい脳を討ち滅ぼせ。
		}

		EyeofCthulhuQuest: {
			DisplayName: クトゥルフの目
			Description: クトゥルフの目を倒す
			DetailedDescription: その邪悪な眼差しを感じている限り、目は現れ続ける。これはあなたの力の真の試練だ。
		}

		GolemQuest: {
			DisplayName: ゴーレム
			Description: ゴーレムを倒す
			DetailedDescription: ジャングル寺院の奥深くに、古代の戦争機械が祀られている。レーザーと重い拳に気をつけろ。
		}

		HiveMindQuest: {
			DisplayName: ハイブマインド / パーフォレーター
			Description: 邪悪なバイオームの真の神を倒す

			QuestObjective: {
				Description: ハイブマインドまたはパーフォレーターを倒す
			}

			DetailedDescription: 彼らは不浄と真紅の意識の物理的な具現化だ。もし倒さなければ、この地に平和は訪れない。
		}

		KingSlimeQuest: {
			DisplayName: キングスライム
			Description: キングスライムを倒す
			DetailedDescription: すべてのゼラチン状の生物の支配者。見た目は少しコミカルだが、その巨大なサイズに圧倒されるな。
		}

		LunaticCultistQuest: {
			DisplayName: 狂気の崇拝者
			Description: 狂気の崇拝者を倒す
			DetailedDescription: ダンジョンの入り口で、終末を防ぐか、あるいは引き起こすことを試みている狂信的なカルト集団がいる。その儀式を止めろ。
		}

		MechanicalBossesQuest: {
			DisplayName: メカボス
			Description: すべてのメカボスを倒す

			QuestObjective: {
				Description: すべてのメカボスを倒す
			}

			DetailedDescription: ドレイドンの初期の創作物で、クトゥルフの部品を模倣している。彼らを倒すことで世界が再生される。
		}

		MoonLordQuest: {
			DisplayName: ムーンロード
			Description: ムーンロードを倒す
			DetailedDescription: すべての背後にいる黒幕、月の裏側から来た恐怖。長い悪夢を終わらせろ。
		}

		PlaguebringerGoliathQuest: {
			DisplayName: プレイグブリンガーゴライアス
			Description: プレイグブリンガーゴライアスを倒す
			DetailedDescription: ナノウイルスで改造された女王蜂。致命的であるだけでなく、危険な疫病も持っている。
		}

		PlanteraQuest: {
			DisplayName: プランテラ
			Description: プランテラを倒す
			DetailedDescription: ジャングルの奥に眠る巨大な肉食花。球根を壊し、ジャングルの怒りに直面せよ。
		}

		SkeletronQuest: {
			DisplayName: スケルトロン
			Description: スケルトロンを倒す
			DetailedDescription: この呪われた老人を倒さなければ、ダンジョンに安全に入ってその秘密を探ることはできない。
		}

		SlimeGodQuest: {
			DisplayName: スライムゴッド
			Description: スライムゴッドを倒す
			DetailedDescription: スライム種族の頂点、古代の貪欲な神。彼の化身たちの組み合わせ攻撃に気をつけろ。
		}

		WallofFleshQuest: {
			DisplayName: ウォールオブフレッシュ
			Description: ウォールオブフレッシュを倒す
			DetailedDescription: 世界の門番。ガイドのブードゥー人形を溶岩に投げ込んで、世界の古代の霊を解放し、ハードモードを開始せよ。
		}

		CeaselessVoidQuest: {
			DisplayName: シースレスヴォイド
			Description: シースレスヴォイドを倒す
			DetailedDescription: 神喰らいの使徒の一つ、別次元から来た無の鏡。
		}

		DevourerofGodsQuest: {
			DisplayName: デバウアーオブゴッド
			Description: デバウアーオブゴッドを倒す
			DetailedDescription: すべての神性を食らいたがる宇宙の蛇。虚空にて挑み、その牙に呑まれるな。
		}

		DragonfollyQuest: {
			DisplayName: ドラゴンフォリー
			Description: ドラゴンフォリーを倒す
			DetailedDescription: ヤーロンのクローン化に失敗した産物。狂気に取り憑かれ、電気を帯びた竜もどき。
		}

		ExoMechsQuest: {
			DisplayName: エクソメカ
			Description: エクソメカを倒す
			DetailedDescription: ドレイドンの究極の傑作、技術の頂点を象徴する存在。完璧なる舞台を生き延びよ。
		}

		OldDukeQuest: {
			DisplayName: オールドデューク
			Description: オールドデュークを倒す
			DetailedDescription: 硫黄の海深部の古代の支配者、変異と力の結合体。彼の有毒な蒸気に気をつけろ。
		}

		PolterghastQuest: {
			DisplayName: ポルターガイスト
			Description: ポルターガイストを倒す
			DetailedDescription: ダンジョンで死んだ復讐心に燃える魂が集まり、形成されたモンスター。彼らの怒りを鎮めよ。
		}

		PrimordialWyrmQuest: {
			DisplayName: 原初の竜
			Description: 原初の竜を倒す
			DetailedDescription: 最深部の深淵を守護する存在。神々よりも古い存在。必要でない限り、触れるべきではない。
		}

		ProfanedGuardiansQuest: {
			DisplayName: 冒涜された守護者
			Description: 冒涜された守護者を倒す
			DetailedDescription: 冒涜された女神の忠実なる守護者たち。彼らを倒すことで、女神の力が弱まるだろう。
		}

		ProvidenceQuest: {
			DisplayName: 冒涜された女神、プロヴィデンス
			Description: 冒涜された女神、プロヴィデンスを倒す
			DetailedDescription: 聖なる火と浄化を操る女神。聖域または地底世界で彼女に挑戦せよ、しかし聖なる炎に焼かれないように注意せよ。
		}

		SignusQuest: {
			DisplayName: 神喰らいの使徒、シグナス
			Description: シグナスを倒す
			DetailedDescription: 神喰らいの使徒の一つ。無形の暗殺者であり、虚無の幽霊。
		}

		StormWeaverQuest: {
			DisplayName: ストームウィーバー
			Description: ストームウィーバーを倒す
			DetailedDescription: 神喰らいの使徒の一つ、雷雨と稲妻をエネルギー源とする空の魔物。
		}

		SupremeCalamitasQuest: {
			DisplayName: 至高の魔女、カラミタス
			Description: カラミタスを倒す
			DetailedDescription: 伝説の煉獄の魔女。これがあなたの旅の終わりか、それとも新たな始まりか？
		}

		YharonQuest: {
			DisplayName: 再臨のドラゴン、ヤーロン
			Description: ヤーロンを倒す
			DetailedDescription: 暴君の忠実な仲間、不死鳥の再生能力を持つドラゴン。これは魂の試練だ。
		}

		BatteryQuest: {
			DisplayName: エネルギー貯蔵
			Description: 熱電池を作成する
			DetailedDescription: 発電後に電力を蓄える必要がある。バッテリーを作成することは、安定した電力網を構築する第一歩だ。
		}

		HydroelectricQuest: {
			DisplayName: 持続可能エネルギー
			Description: 水力発電機を作成する
			DetailedDescription: 流れる水の力を使って電力を生成する。クリーンで持続可能なエネルギー源だ。
		}

		IndustrialStartQuest: {
			DisplayName: 産業革命
			Description: 風力発電機を作成する
			DetailedDescription: 自動化の第一歩。風力エネルギーを利用して機械を駆動させろ。
		}

		ItemFilterQuest: {
			DisplayName: 物流仕分け
			Description: アイテムフィルターボードを作成する
			DetailedDescription: 自動化された生産ラインには秩序が必要だ。フィルターを使って、アイテムの流れを正確に制御せよ。
		}

		MiningMachineQuest: {
			DisplayName: 自動掘削
			Description: 採掘機を作成する
			DetailedDescription: 面倒な手動採掘にさようなら。この機械は驚異的な効率で鉱脈を食い尽くす。
		}

		MiningMachineIIQuest: {
			DisplayName: 深層コア掘削
			Description: 採掘機Mk2をクラフトする。
			DetailedDescription: 強化されたパワーコアにより、比類なき速度を発揮する。
		}

		PipelineQuest: {
			DisplayName: エネルギー伝送
			Description: 電力入力パイプラインを作成する
			DetailedDescription: 発電機と機械をつなぐ静脈。それがなければ、電力はただの停滞した水に過ぎない。
		}

		TeslaTowerQuest: {
			DisplayName: 磁気嵐の塔
			Description: テスラ電磁タワーを作成する
			DetailedDescription: ドレイドンの技術の結晶。このタワーにより、無線で電力を送信でき、配線のレイアウトに革命が起きるだろう。
		}

		ThermalPowerQuest: {
			DisplayName: 燃やす時
			Description: 熱発電機を作成する
			DetailedDescription: 燃料を燃やして大量の電力を生成する。環境に優しくはないが、初期段階では最も信頼できるエネルギー源だ。
		}

		AnnihilatingUniverseQuest: {
			DisplayName: 宇宙の殲滅者
			Description: 宇宙の殲滅者を手に入れる
			DetailedDescription: 銀河の力を弓の弦に圧縮せよ。この武器は宇宙次元を破壊する力を持ち、レンジャーにとって究極の証明となる。
		}

		AriaofTheCosmosQuest: {
			DisplayName: アリア・オブ・ザ・コスモス
			Description: アリア・オブ・ザ・コスモスを入手せよ
			DetailedDescription: 星々の交響曲を奏でよ。この書物はブラックホールや銀河核を召喚し、敵を宇宙の歌の中で消し去る。
		}

		DarkMatterCompressorQuest: {
			DisplayName: 暗黒物質圧縮機
			Description: 暗黒物質圧縮機を入手せよ
			DetailedDescription: 宇宙で最も神秘的な物質を操れ。この機械は暗黒物質を高密度エネルギー球に圧縮し、高度な製作に利用する。
		}

		InfiniteIngotQuest: {
			DisplayName: 無限のインゴット
			Description: 無限のインゴットを鍛造せよ
			DetailedDescription: 質量保存の法則を超越した金属。それは究極の力への礎となり、無限の可能性を秘めている。
		}

		InfinitePickQuest: {
			DisplayName: 強欲のツルハシ
			Description: 強欲のツルハシを入手せよ
			DetailedDescription: このツルハシは何も止めることができない。世界のすべてを掘り起こすことができる。
		}

		InfiniteToiletQuest: {
			DisplayName: 無限のトイレ
			Description: 無限のトイレを入手せよ
			DetailedDescription: 神々の玉座。おかしな話のように聞こえるが、それは何かしらの...至高の権威を象徴している。
		}

		InfinityCatalystQuest: {
			DisplayName: 無限の触媒
			Description: 無限の触媒を入手せよ
			DetailedDescription: 無限の反応を開始するための重要な媒介。物質が消滅と再生を繰り返すことを可能にし、膨大なエネルギーを生み出す。
		}

		NeutronBowQuest: {
			DisplayName: ロシュの弦
			Description: ロシュの弦を入手せよ
			DetailedDescription: 中性子星のコアの断片から鍛造された弓。その矢は崩壊する星の重力を帯びている。
		}

		NeutronGlaiveQuest: {
			DisplayName: ブラックゾーンクリーバー
			Description: ブラックゾーンクリーバーを入手せよ
			DetailedDescription: 驚異的な密度を持つ槍。それを振るうには巨大な力が必要だが、その斬撃に耐える鎧は存在しない。
		}

		NeutronGunQuest: {
			DisplayName: ステラーハンター
			Description: ステラーハンターを入手せよ
			DetailedDescription: マイクロ中性子流を発射する銃。その弾丸は極端な密度により、抵抗をほとんど受けない。
		}

		NeutronScytheQuest: {
			DisplayName: 惑星の使者
			Description: 惑星の使者を入手せよ
			DetailedDescription: 死神の収穫道具。空間を引き裂き、小麦のように命を刈り取る。
		}

		NeutronStarIngotQuest: {
			DisplayName: 中性子星インゴット
			Description: 中性子星インゴットを入手せよ
			DetailedDescription: 宇宙で最も密度の高い素材の一つ。この金属は想像を絶するほど重く、重力の変動を伴って唸っている。
		}

		NeutronWandQuest: {
			DisplayName: 星の墓の光
			Description: 星の墓の光を入手せよ
			DetailedDescription: 重力を操る杖。中性子星の力を使って時空を歪め、敵を圧倒せよ。
		}

		PandemoniumQuest: {
			DisplayName: パンデモニウム
			Description: パンデモニウムを入手せよ
			DetailedDescription: 無数の魂とカラミタスの力を融合させた究極の武器。それを持つ者は、地獄と奈落の扉を握る。
		}

		RockQuest: {
			DisplayName: 岩
			Description: 岩を入手せよ
			DetailedDescription: 一見普通の石。しかし、それは数え切れないほどの戦いを見守った証であり、永遠の忍耐の象徴だ。
		}

		TerminusQuest: {
			DisplayName: 終焉の遺物
			Description: 終焉の遺物を入手せよ
			DetailedDescription: ボスラッシュを開始するための鍵。この遺物を見つめ、世界最強の存在たちとの試練に備えよ。
		}

		TransmutationOfMatterQuest: {
			DisplayName: オメガ物質重合機
			Description: オメガ物質重合機を入手せよ
			DetailedDescription: 錬金術の究極形態。この機械は等価交換の法則を無視し、物質を自由に変換し、何もないところから創り出す。
		}

		HeavenfallLongbowQuest: {
			DisplayName: ヘブンリーゲール
			Description: ヘブンリーゲールを入手せよ
			DetailedDescription: 神々を撃ち落とした長弓。今、再びこの世界に現れる。
		}

		SpearOfLonginusQuest: {
			DisplayName: ロンギヌスの槍
			Description: ロンギヌスの槍を入手せよ
			DetailedDescription: 神性を貫いた伝説の聖槍。あらゆる領域と絶対障壁を貫く力を持つ。投げ放たれたとき、因果律すらその道を譲るという。
		}

		DragonsWordQuest: {
			DisplayName: ドラゴンの言葉
			Description: ドラゴンの言葉を入手せよ
			DetailedDescription: 竜が涙を流すのは生涯に一度、その最期の瞬間だけ。
		}

		RockQuestII: {
			DisplayName: 征服の循環
			Description: ボスラッシュを5回クリアし、岩を5個入手する。
			DetailedDescription: 真の戦士の証だ。
		}

		AdventurerQuests: {
			DisplayName: 冒険者
			Description: 世界は自分の歩む場所だ。

			QuestObjective: {
				Description: クリックして受け取る。
			}

			DetailedDescription: 千里の旅も一歩から。ブーツを履いて広大な世界を確かめろ。
		}

		ExploreDungeon: {
			DisplayName: 陰鬱なダンジョン
			Description: ダンジョンの入口を発見する。

			QuestObjective: {
				Description: ダンジョンに到達する。
			}

			DetailedDescription: 呪われた壁の向こうには終わりなき秘密と危険が潜む。足を踏み入れる者は勇者のみ。
		}

		ExploreHell: {
			DisplayName: 深淵の地底世界
			Description: 地底世界へ降下する。

			QuestObjective: {
				Description: 地底世界に到達する。
			}

			DetailedDescription: 世界最深部には溶岩の川が流れ、悪魔たちが棲む。黒曜石とヘルストーンの源でもある。足元に注意。
		}

		ExploreJungle: {
			DisplayName: 密林遠征
			Description: ジャングルへ踏み込む。

			QuestObjective: {
				Description: ジャングルに到達する。
			}

			DetailedDescription: 鮮やかで危険に満ちた緑の迷宮。濃密な植物は古代の寺院や凶暴な蜂の群れを隠す。
		}

		ExploreOcean: {
			DisplayName: 世界の果て
			Description: 海へ到達する。

			QuestObjective: {
				Description: 海に到達する。
			}

			DetailedDescription: 大陸の果て。空と海が交わる場所。沈んだ船や未知の海獣が深海に眠る。
		}

		ExploreSnow: {
			DisplayName: 凍てつく荒野
			Description: 雪原を探索する。

			QuestObjective: {
				Description: 雪原に到達する。
			}

			DetailedDescription: 永久凍土の地。刺すような風がすべてを氷雪で覆う。ここでは生命はより強靭な姿をとる。
		}

		ExploreSpace: {
			DisplayName: 星々の海
			Description: 宇宙へ飛び出す。

			QuestObjective: {
				Description: 宇宙に到達する。
			}

			DetailedDescription: 重力の鎖を断ち切り星々へ触れる。高く飛ぶほど世界の全景が見える。
		}

		HellLabSchematic: {
			DisplayName: 地獄の設計図
			Description: 地底世界のドレイドン研究所で暗号化された設計図を見つける。

			QuestObjective: {
				Description: 地底世界の設計図を入手する。
			}

			DetailedDescription: ドレイドンは地熱エネルギーの研究のため地底世界に前哨基地を築いた。設計図を見つければ新たな武器技術を手に入れられるだろう。
		}

		IceLabSchematic: {
			DisplayName: 極地の暗号
			Description: 雪原地下のドレイドン研究所で暗号化された設計図を見つける。

			QuestObjective: {
				Description: 雪原地下の設計図を入手する。
			}

			DetailedDescription: この低温環境は精密機器の保存に最適。氷の下に眠る研究所で封じられた極地技術を探し出す。
		}

		JungleLabSchematic: {
			DisplayName: 密林草稿
			Description: ジャングルのドレイドン研究所で暗号化された設計図を見つける。

			QuestObjective: {
				Description: ジャングルの設計図を入手する。
			}

			DetailedDescription: 密林にはドレイドンの生物学研究所が隠されている。彼は疫病やナノウイルスを研究していた。設計図を見つければ危険な真実が明らかになる。
		}

		PlanetoidLabSchematic: {
			DisplayName: 外殻の秘密
			Description: 小惑星のドレイドン研究所で暗号化された設計図を見つける。

			QuestObjective: {
				Description: 小惑星の設計図を入手する。
			}

			DetailedDescription: 高高度の微小重力環境に静かに浮かぶ研究所。そこにはエクソメカ初期設計の資料が残されているという。
		}

		SunkenSeaLabSchematic: {
			DisplayName: 沈んだ海
			Description: 沈んだ海のドレイドン研究所で暗号化された設計図を見つける。

			QuestObjective: {
				Description: 沈んだ海の設計図を入手する。
			}

			DetailedDescription: 穏やかな海中世界にプリズムエネルギーの研究が残されている。貴重なデータを回収せよ。
		}

		AquaticScourgeQuest: {
			DisplayName: アクアティックスカージ
			Description: アクアティックスカージを討伐する。
			DetailedDescription: かつては澄んだ海に棲む穏やかなリヴァイアサンだったが、硫酸の海の毒性により歪められた。汚染された酸の海域では、突進と毒雲に警戒せよ。
		}

		QueenSlimeQuest: {
			DisplayName: クイーンスライム
			Description: クイーンスライムを討伐する。
			DetailedDescription: 聖域に君臨する水晶の女帝であり、あらゆる浄化された粘体生物を統べる存在。その伴侶と比べ、はるかに俊敏で攻撃的だ。壮麗な猛攻に備えよ。
		}

		BuildHouse: {
			DisplayName: 建築の達人
			Description: 適切な家を建てる。

			QuestObjective: {
				Description: 有効な家を建てる。
			}

			DetailedDescription: 誰にとっても安らぎの場所は必要だ。家具と明かり、壁のある部屋を用意すれば、ガイドや旅人たちは力を貸してくれる。
		}

		CollectEvilOres: {
			DisplayName: 邪悪な鉱石
			Description: 邪悪な鉱石を集める。

			QuestObjective: {
				Description: デモナイトまたはクリムタン鉱石を集める。
			}

			DetailedDescription: これらの鉱石は不吉な気配を放ち、触れると冷たく湿っている。世界の病巣から生まれたものだが、強力な装備の素材として不可欠だ。
		}

		CollectFallenStars: {
			DisplayName: 星の収集家
			Description: 流れ星を集める。

			QuestObjective: {
				Description: 流れ星を集める。
			}

			DetailedDescription: 夜空の涙は、闇が訪れた後にのみ降り注ぐ。マナ容量の拡張だけでなく、強力な弾薬や魔法素材としても役立つ。
		}

		CollectGems: {
			DisplayName: 宝石収集家
			Description: 様々な宝石を集める。

			QuestObjective: {
				Description: 5種類の異なる宝石を集める。
			}

			DetailedDescription: 岩層に埋もれた輝く結晶。装飾品に留まらず、魔法の杖やグラップリングフックの制作に欠かせない。異なる色を集めれば、虹の輝きを繋ぎ合わせられるかもしれない。
		}

		CollectHerbs: {
			DisplayName: 見習いハーブコレクター
			Description: 様々なハーブを集める。

			QuestObjective: {
				Description: 3種類の異なるハーブを集める。
			}

			DetailedDescription: 錬金術の基礎。植物は砂漠やツンドラ、地底世界など、それぞれ異なる環境で育つ。見分けることが熟練への第一歩だ。
		}

		CollectOres: {
			DisplayName: 鉱石収集
			Description: 基本的な鉱石を集める。

			QuestObjective: {
				Description: {
					Iron: 鉄または鉛鉱石を集める
					Copper: 銅または錫鉱石を集める
				}
			}

			DetailedDescription: 採掘は生存の本質だ。銅や鉄はありふれているが、原始的な生活から抜け出す礎となる。侮るな。伝説の英雄も銅のツルハシから始まった。
		}

		DeepExplorer: {
			DisplayName: 深淵の探検者
			Description: 主要なバイオームをすべて探索する。

			QuestObjective: {
				Description: すべての探索クエストを完了する。
			}

			DetailedDescription: 雲上から地獄の最深部まで、世界の隅々を踏破した。その地図こそが勇気の証だ。今や世界はその足元にある。
		}

		ExploreCaverns: {
			DisplayName: 洞窟のさらに奥
			Description: より深い洞窟層を探索する。

			QuestObjective: {
				Description: 洞窟層に到達する。
			}

			DetailedDescription: ここに太陽の光はなく、闇と未知の生物が支配する。溶岩が現れ、鉱脈はより豊かになる。足元に注意せよ。深淵は見返してくる。
		}

		ExploreCorruption: {
			DisplayName: 不浄なる大地
			Description: 不浄または真紅を探索する。

			QuestObjective: {
				Description: 不浄または真紅に足を踏み入れる。
			}

			DetailedDescription: この地は病んでいる。紫の腐敗か真紅の肉塊が大地を蝕む。血に飢えた怪物が蔓延るが、シャドウスケイルや組織サンプルを得るには虎穴に入らねばならない。
		}

		ExploreDesert: {
			DisplayName: 灼熱の砂漠
			Description: 砂漠バイオームに入る。

			QuestObjective: {
				Description: 砂漠に到達する。
			}

			DetailedDescription: 灼けつく太陽が大地を焼き、黄金の砂海が古代の化石と獰猛なアントリオンを覆い隠す。十分な水を持て。この乾燥は命を奪う。
		}

		ExploreFloatingIsland: {
			DisplayName: 浮遊島
			Description: 空に浮かぶ島を見つける。

			QuestObjective: {
				Description: 浮遊島に到達する。
			}

			DetailedDescription: 雲の上には古代文明の遺した宝物庫があるという。重力異常を探すか、天へ伸びる塔を築いて確かめよ。
		}

		ExploreGlowingMushroom: {
			DisplayName: 発光キノコ群生地
			Description: キノコ群生地を見つける。

			QuestObjective: {
				Description: キノコ群生地に到達する。
			}

			DetailedDescription: 幻覚的な地下生態系。巨大な菌類が幽玄な青光を放ち、闇を照らす。トリュフと奇妙な昆虫の住処だ。
		}

		ExploreUnderground: {
			DisplayName: 地下探索
			Description: 洞窟へ踏み込む。

			QuestObjective: {
				Description: 地下層に到達する。
			}

			DetailedDescription: 表土を削るだけでは足りない。真の冒険は地下から始まる。松明を携えよ。最初の岩層は序章にすぎない。
		}

		FindLifeCrystal: {
			DisplayName: 生命の源
			Description: ライフクリスタルを見つける。

			QuestObjective: {
				Description: ライフクリスタルを見つける。
			}

			DetailedDescription: この赤い結晶は生命力の鼓動を放つ。砕いて取り込めば、身体能力が恒久的に強化される。強敵に挑むための鍵だ。
		}

		FindShadowOrb: {
			DisplayName: 邪悪の核心
			Description: 邪悪なバイオームの奥深くでシャドウオーブまたはクリムゾンハートを見つける。

			QuestObjective: {
				Description: シャドウオーブまたはクリムゾンハートを破壊する。
			}

			DetailedDescription: 邪悪の裂け目の奥で、腐敗した心臓か影の球体が脈動している。破壊すれば武器が得られるが、三つ壊せば恐るべき存在が目覚める。
		}

		FirstPotion: {
			DisplayName: 錬金術の基礎
			Description: 初めてのポーションを調合する。

			QuestObjective: {
				Description: 任意のポーションを調合する。
			}

			DetailedDescription: 空き瓶をテーブルに置けば簡易的な錬金台となる。複雑な呪文は不要だ。正しい素材の組み合わせだけでいい。飲み干し、魔力を感じよ。
		}

		NPCVillage: {
			DisplayName: 繁栄する村
			Description: 複数のNPCを呼び寄せる。

			QuestObjective: {
				Description: NPCを5人住まわせる。
			}

			DetailedDescription: 荒野で独り生きるのは孤独だ。力をつけ、資金を持てば、より多くの人々が集う。活気ある共同体を築き、支えとせよ。
		}

		QueenBeeQuest: {
			DisplayName: 女王蜂
			Description: 女王蜂を討伐する。
			DetailedDescription: 地下ジャングルの巨大な巣の奥で幼虫を壊すと、群れの支配者が激昂する。解毒ポーションを用意し、針と高速突進に警戒せよ。
		}

		CollectorQuest: {
			DisplayName: コレクションアシスタント
			Description: 収集機を入手する。
			DetailedDescription: あちこちに落ちた戦利品を拾うために、いちいち屈むのに疲れていないだろうか。この装置は、近くに落ちたアイテムを自動的に回収する。自動化された物流や仕分けシステムを構築するための中核コンポーネントであり、手作業から完全に解放してくれる。
		}

		LumberjackQuest: {
			DisplayName: 伐採の時間
			Description: ランバージャックを入手する。
			DetailedDescription: 木材は産業と建築の基盤だ。原始的な斧とは別れを告げよう。この機械は電力を消費し、安定した木材供給を実現する。
		}

		LifeWeaverQuest: {
			DisplayName: 植林の時間
			Description: ライフウィーバーを入手する。
			DetailedDescription: 森林の再生は通常ゆっくりと進むが、この機械は電力を使って苗木を正確に植え、荒れ果てた土地に素早く生命を取り戻す。完全自動で持続可能な植林を構築するための、最後のピースとなる装置だ。
		}

		IncineratorQuest: {
			DisplayName: 電動精錬
			Description: 電動インシネレーターをクラフトする。
			DetailedDescription: 従来の炉は効率が悪く、鉱石のエッセンスを大量に無駄にしてしまう。この機械は高電圧アークによる超高温を利用し、鉱石を徹底的に分解することで、従来の2倍の精錬量を引き出す。工業化への重要な一歩となる装置だ。
		}

		ItemPipelineQuest: {
			DisplayName: 物流システム
			Description: アイテムパイプラインをクラフトする。
			DetailedDescription: まだ宝箱の中身を手作業で移動させているの？これらのパイプは工業の血管だ。機械やコンテナ同士を接続すれば、アイテムが自動的に必要な場所へ流れていく。自動化ラインを構築し、労力なしで成果を得る快感を味わおう。
		}

		ThrowerQuest: {
			DisplayName: 投擲アシスタント
			Description: 射出機をクラフトする。
			DetailedDescription: すべてのアイテムが保管に値するわけではない。この装置は物流ネットワークからアイテムを排出する。液体への投入による自動クラフトや、不要物の廃棄装置としても活用でき、確実に役目を果たす。
		}
	}
}

Recipes: {
	CWRCrafted: {
		ApostolicRelicsGroup: 使徒の遺物
		GodEaterWeaponGroup: 神喰らいの武器
		FishGroupName: 魚
	}
}

RemakeItems: {
	ModifyChargingStationItem: {
		DisplayName: 充電ステーション
		Tooltip:
			'''
			電力を使って電子機器を充電する
			バッテリーを中に入れると電気を蓄えられる
			配管に接続して電力を送ることができる
			充電可能なアイテムを持ってブロックを右クリックすると素早く挿入できる
			Shift + 右クリックでアイテムを取り出す
			'''
	}

	DyeVatItem: {
		DisplayName: 染料作業台
		Tooltip:
			'''
			染料のクラフトに使用する
			設置後に右クリックで操作パネルを開き、アイテムを染色できる
			染料スロットに水入りバケツを入れると、染料を洗い落とすことができる
			'''
	}

	RDemonConch: {
		DisplayName: 地獄の巻き貝
		Tooltip:
			'''
			耳を澄ますと悲鳴が聞こえる
			「足元注意」
			'''
	}
}

Structures: {
	WorldGenSystem: {
		IndustrializationGenMessage: 世界を工業化中
	}
}

Tiles: {
	BloodAltarTP: {
		ApproachingText: 深紅の眼差しが近づいている…
		InsufficientOfferingText: 深紅の王へ捧げるための血のオーブが足りない…
		SacrificeDeathReason: "{0}は血と肉の果てなき狂乱に囚われました。"
	}
}

