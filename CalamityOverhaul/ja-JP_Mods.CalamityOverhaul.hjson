QuickHack: {
	SystemReset: {
		DisplayName: システムリセット
		Description: 対象のシステムを強制再起動させ、完全に行動不能にする
	}

	Cyberpsychosis: {
		Description: 対象を狂乱状態へ追い込み、周囲のあらゆるユニットを攻撃させる
		DisplayName: サイバーサイコシス
	}

	ShortCircuit: {
		Description: EMPを放出し、即時ダメージと短時間の麻痺を与える
		DisplayName: 回路ショート
	}

	SynapseBurn: {
		Description: 対象の神経シナプスを過負荷状態にし、継続的な熱ダメージを与える
		DisplayName: シナプス焼却
	}

	OpticOverload: {
		DisplayName: オプティクス再起動
		Description: 対象の視覚を遮断し、周囲を認識できなくする
	}

	MemoryWipe: {
		DisplayName: 記憶消去
		Description: 対象の敵対データを消去し、ヘイト状態をリセットする
	}

	Contagion: {
		DisplayName: コンテイジョン
		Description: 自己複製型マルウェアを埋め込み、周囲の対象へ感染を拡散させる
	}

	TileDetonate: {
		DisplayName: タイルデトネーション
		Description: 構造耐久性を破壊し、局所的な爆発を発生させる
	}

	TilePhase: {
		DisplayName: フェージングプロトコル
		Description: タイルの物理特性を変化させ、一時的にすり抜け可能にする
	}

	TileMagPull: {
		DisplayName: マグネティックプル
		Description: 磁場を発生させ、周囲に落ちているアイテムを引き寄せる
	}

	MachineShortCircuit: {
		DisplayName: 機械ショート
		Description: 対象機械のエネルギーを吸い上げ、周囲へ電撃アークを放出する
	}

	TurretHijack: {
		DisplayName: タレットジャック
		Description: IFF識別モジュールを改竄し、タレットの敵味方識別を一時的に反転させる
	}

	FalseMemory: {
		DisplayName: 虚偽記憶
		Description: 偽の記憶を植え付け、追跡行動を一時中断させる、または殺害パターンを抑制する
	}

	SelfDismember: {
		DisplayName: 自己切断
		Description: 超常存在へ自己解体を強制する
	}

	SystemHalt: {
		DisplayName: 強制停止
		Description: 対象を短時間沈黙させ、あらゆる行動を停止させる
	}

	TurretCircuitOverload: {
		DisplayName: 回路ショート
		Description: タレットの電力回路へ逆電流を流し込み、長時間完全停止させる
	}

	TurretShortCircuit: {
		DisplayName: タレットショート
		Description: タレットのエネルギーを瞬時に放電させ、短時間機能停止させる
	}

	VirusBroadcast: {
		DisplayName: ウイルスブロードキャスト
		Description: 信号塔へワームコードを注入し、放送範囲内の全タレットを長時間ショートさせるサイバーEMP波を発信する
	}
}

Resurrections: {
	ResurrectionDeath: {
		RetainValueFormat: 再誕値: {0}%
		MarkRemainText: 深淵の刻印がまだ残っている...
		DeathNoticeText: あなたは深淵に呑まれた...
		WarningCombatText: 深淵があなたを喰らっている...
		DeathText: "{0}は深淵の再誕に呑み込まれました。"
	}
}

