Tools: {
	RecipesLoseText: これは作ることができない
}

EndlessDamageClassTextContent: {
	EndlessDamageClass: {
		DisplayName: 無限のダメージ
	}
}

FishSkill: {
	FishFrostMinnow: {
		Studied: 凍傷に注意！
		Tooltip:
			'''
			射撃中、一定間隔で「氷のハヤ」を召喚
			散弾状の氷弾を放ち敵を攻撃する
			'''
		DisplayName: 凍てつく宣告
	}

	FishDoubleCod: {
		Studied: なんとも奇妙だ...
		Tooltip:
			'''
			射撃中、一定間隔で追尾する鱈を放つ
			鱈は敵を追跡し続け、接触ダメージを与える
			'''
		DisplayName: 双鱈の追撃
	}

	FishBrimlish: {
		Studied: 危険なほど高温だ...
		Tooltip:
			'''
			射撃中、一定間隔で魚を召喚
			散弾状の灰血弾を多数放ち敵を攻撃する
			'''
		DisplayName: 灰血の散布
	}

	FishNeonTetra: {
		Studied: この鱗の輝きは見惚れるほどだ...
		Tooltip:
			'''
			移動時、発光するネオンテトラを残す
			通過した軌跡上の敵にダメージを与える
			'''
		DisplayName: ネオンの軌跡
	}

	FishTropicalBarracuda: {
		Studied: 驚くほどの速度だ...
		Tooltip:
			'''
			射撃時、画面端からバラクーダの群れを召喚
			高速で画面を横断し、敵を貫く
			'''
		DisplayName: バラクーダ・ブリッツ
	}

	FishCrimsonTiger: {
		Studied: 非常に獰猛な性質をしているらしい...
		Tooltip:
			'''
			右クリックで紅虎魚の群れを召喚
			周囲を追従し、敵を見つけ次第攻撃する
			'''
		DisplayName: 深紅の巡行
	}

	FishPrincess: {
		Studied: 明らかに「王子」ではない...
		Tooltip:
			'''
			射撃時、プリンセスフィッシュを召喚して戦わせる
			プリンセスフィッシュは魔法弾を放ち敵を攻撃する
			'''
		DisplayName: 王女の輝き
	}

	FishVariegatedLard: {
		Studied: 洗剤をかなり使いそうだ...
		Tooltip:
			'''
			攻撃命中時、敵から油を噴き出させる
			油は地面や敵に付着し、さらに広がる
			'''
		DisplayName: 油の飛沫
	}

	FishRock: {
		Studied: 誰も、この魚が「槌になりたい」かは聞かないのだ。
		Tooltip:
			'''
			一定間隔でロックハンマーフィッシュを召喚する
			敵の上方に移動し、叩きつけ攻撃を行う
			'''
		DisplayName: 岩槌の一撃
	}

	FishObsidian: {
		Studied: 黒曜石って、意外と脆いんだよ。
		Tooltip:
			'''
			射撃時、黒曜魚を召喚しプレイヤーの周囲を旋回させる
			黒曜魚は接触ダメージを与えるが、被弾時に1体ずつ砕け散る
			'''
		DisplayName: 黒曜の守護
	}

	FishPrismite: {
		Studied: この魚の輝きは重金属を吸収した結果かもしれない...
		Tooltip:
			'''
			射撃時、弾を虹色の衝撃波に変換する
			命中時に分裂し、複数の弾を放つ
			'''
		DisplayName: 虹光の奔流
	}

	FishScorpio: {
		Studied: 体の隅々まで砂で満たされている...
		Tooltip: 地を這う蠍の守衛を召喚し、敵に砂弾を放つ
		DisplayName: 砂蠍の守護者
	}

	FishWyverntail: {
		Studied: 伝説級の存在として扱うべきだろう...
		Tooltip:
			'''
			射撃中、白竜を召喚する
			白竜は敵に素早く突進し、ダメージを与える
			'''
		DisplayName: 白影の竜
	}

	FishUnicorn: {
		Studied: 純潔の乙女だけが釣り上げられるという...
		Tooltip:
			'''
			右クリックで長距離の水平突進を行う
			ダッシュ中は無敵となり、壁を通過する
			'''
		DisplayName: 虹角の突撃
	}

	FishBloodyManowar: {
		Studied: 彼らの関係は共生なのか、それとも支配なのか...
		Tooltip:
			'''
			射撃時、敵に向かう血塗れのクラゲ群を召喚する
			集合時に大きな範囲ダメージを与える
			'''
		DisplayName: 深紅の審判
	}

	FishTunabeard: {
		Studied: 魚にとって「海賊」と「盗賊」に違いはあるのだろうか？
		Tooltip:
			'''
			右クリックでカーソル方向へ高速ダッシュ
			ダッシュ中は無敵になり、壁をすり抜ける
			'''
		DisplayName: 怒涛の突進
	}

	FishJewel: {
		Studied: 六色の旋律...虹の交響曲が作れそうだ...
		Tooltip:
			'''
			射撃時、宝石弾を一定の順序で放つ
			宝石の種類により異なる音を奏でる
			'''
		DisplayName: 虹彩の序曲
	}

	FishofCthulu: {
		Studied: ...見つめられている。
		Tooltip:
			'''
			射撃時、敵を監視する瞳を召喚する
			接近すると瞳が変化し突進する
			'''
		DisplayName: 深淵の眼差し
	}

	FishDrizzle: {
		Studied: 焚き火以外にも使い道がありそうだ...
		Tooltip:
			'''
			射撃中、一定間隔で硫黄弾を吐く魚を召喚する
			射撃中は再チャージが進まない
			'''
		DisplayName: 硫黄の雨
	}

	FishPeng: {
		Studied: もしかしたらマダガスカル出身かも...
		Tooltip:
			'''
			射撃時、敵の頭上からペンギンを降らせる
			落下時に範囲ダメージとノックバックを与える
			'''
		DisplayName: ペンギン急襲
	}

	FishMud: {
		Studied: 隠れる技に長けている。
		Tooltip:
			'''
			射撃時、地面から泥の守衛を呼び出す
			泥玉を放った後、再び地中へ沈む
			'''
		DisplayName: 泥の守衛
	}

	FishDirt: {
		Studied:
			'''
			土の香りが海底を思い出させる...
			この小さな群れは互いに寄り添って温もりを分け合う。
			'''
		Tooltip:
			'''
			移動中、自身の周囲を回る土魚の群れを召喚する
			球は跳ね、転がりながら連続ダメージを与えるが、同時に存在できる球は1つのみ
			'''
		DisplayName: 大地の群れ
	}

	FishCat: {
		Studied: この魚は蜂蜜に目がないようだ。
		Tooltip:
			'''
			右クリックで跳ね回るキャットフィッシュを複数投げる
			跳ねるたびに鳴き声を上げ、敵に触れるか時間経過で爆発する
			'''
		DisplayName: バウンドキャット
	}

	FishBunny: {
		Studied: 危険なほどふわふわしている！
		Tooltip:
			'''
			右クリックで跳ね回るバニーフィッシュを複数投げる
			敵に触れるか一定時間後に爆発する
			'''
		DisplayName: バウンドボム
	}

	FishSlime: {
		Studied: とても...“くっつきたがり”だ...
		Tooltip:
			'''
			移動中にスライム状のジェルを撒き散らす
			触れた敵に付着する
			'''
		DisplayName: 粘液の軌跡
	}

	FishCursed: {
		Studied: それでも釣り竿は燃えない...
		Tooltip:
			'''
			射撃時、呪われた炎を散布する
			炎は不自然な軌道で弧を描き落下する
			'''
		DisplayName: 呪炎の奔流
	}

	FishIchorn: {
		Studied: この魚の唾液は非常に有用だ！
		Tooltip:
			'''
			射撃時に霊液の飛沫を散らす
			命中時に霊液デバフを付与する
			'''
		DisplayName: 黄血の流れ
	}

	Fishotroning: {
		Studied: 腕は4本（以上）あるんだよ！
		Tooltip:
			'''
			射撃でスケルトロンの手を生み出し、共に戦わせるが、被弾すると手を1本失う
			遠距離では骨を投げ、近距離では平手打ちを繰り出す
			'''
		DisplayName: 骨の掌握
	}

	FishHoney: {
		Studied: なぜかナマズを怖がっているようだ...
		Tooltip:
			'''
			右クリックで蜂の群れを呼び出し、自身の周囲を旋回させる
			蜂は自動で敵を攻撃する
			'''
		DisplayName: 蜂の召喚者
	}

	FishAmanita: {
		Studied: この魚はひとつの菌類生態系そのものだ...
		Tooltip:
			'''
			射撃ごとに4種の胞子弾を順に切り替える
			（爆裂、追尾、毒、雷）
			'''
		DisplayName: 菌糸の循環
	}

	FishEaterofPlankton: {
		Studied: この魚...中に虫がいる！
		Tooltip: 射撃時、小型のソウルイーターを放ち、敵を襲わせる
		DisplayName: 捕食者の落とし子
	}

	FishBat: {
		Studied: この魚を逆さに吊るしたら...眠るのだろうか？
		Tooltip:
			'''
			右クリックでコウモリの群れに変身し、高速で突進する
			攻撃を行うと変身が解除される
			'''
		DisplayName: 幻影の残響
	}

	FishHunger: {
		Studied: まるで...飢えているようだ...
		Tooltip:
			'''
			射撃中、一定間隔で「ハングリー・モー」が周囲を旋回し出現する
			最大まで溜まると、モーが照準方向へ向かい敵を喰らう
			'''
		DisplayName: 飢えた顎
	}

	FishFallenStar: {
		Studied: 日中は......消えてしまうかもしれない
		Tooltip:
			'''
			射撃に星が伴い、その周囲を小さな星々が回転する
			一定の射撃ごとに星が降り注ぐ
			'''
		DisplayName: 星の落胤
	}

	FishHarpy: {
		Studied: 本当に飛べる魚なのかは怪しいが、一応翼はある。
		Tooltip:
			'''
			射撃中、一定間隔でハーピーの羽を召喚して周囲を回転させる
			撃ち続けると羽が外へ向かって発射される
			'''
		DisplayName: 羽嵐
	}

	FishBone: {
		Studied: 出汁にすればうまそうだ...カルシウムも豊富だ。
		Tooltip:
			'''
			射撃中、一定間隔で骨を召喚して周囲を回転させる
			旋回後、敵に向かって飛び出し、戻ってくるが、被弾すると骨は砕け散る
			'''
		DisplayName: 骨の旋風
	}

	FishDynamite: {
		Studied: 内部構造は非常に複雑で、主に「ドカン」となる部分でできている。
		Tooltip:
			'''
			右クリックで重力の影響を受けるダイナマイトフィッシュを投げる
			敵に接触、または一定時間後に爆発する
			'''
		DisplayName: ダイナマイトフィッシュ
	}

	FishDemonicHell: {
		Studied: 炎獄の中で燃え盛っている...
		Tooltip:
			'''
			射撃中、一定間隔で炎獄の紋章を召喚する
			完全にチャージされると、紋章が火球を発射し、飛んだ後に爆発する
			'''
		DisplayName: 炎獄の爆炎
	}

	FishVoodoo: {
		Studied: 有用な標本だ。新しい実験の発想が浮かんできた。
		Tooltip:
			'''
			致命傷を受けた際、即死を防ぎ、代わりに近くの敵へダメージを転移させる（クールダウンあり）
			発動中は、範囲内のすべての敵へ転移する
			'''
		DisplayName: 呪縛の守護
	}

	FishCloud: {
		Studied: 見た目は魚だが、実際には泳ぐ雲らしい。
		Tooltip:
			'''
			右クリックで雨雲に乗って高速移動し、通過した軌跡に雨を残す
			騎乗中は壁をすり抜け、武器を使用できる
			'''
		DisplayName: 雲上の波乗り
	}

	FishZombie: {
		Studied: 悪臭を放つ魚だ......生きてると言えるのか？
		Tooltip:
			'''
			右クリックで溺死者の群れを呼び出し、敵に突進させる
			接近すると爆発する
			'''
		DisplayName: 甦る潮
	}

	FishSparkling: {
		Studied: この標本の研究はレーザーポインター技術の発展に繋がるかもしれない。
		Tooltip:
			'''
			射撃中、一定間隔でスパークリングクイーンフィッシュを複数召喚して連射する
			発射中はクールダウンが回復しない
			'''
		DisplayName: 王家の閃魚舞
	}

	FishSwarm: {
		Studied: 特徴のない魚だが、潜在能力はかなり高い。
		Tooltip:
			'''
			右クリックで魚の群れに変化して突進する
			左クリックで群れをカーソル方向に射出する
			'''
		DisplayName: 幻影の群泳
	}
}

Configs: {
	CWRServerConfig: {
		GenSylvanOutpost: {
			Tooltip: 森の奥深くに木造のエルフまたは森の守護者の前哨基地を生成します
			Label: シルヴァン前哨基地を生成
		}

		GenRocketHut: {
			Tooltip: ロケット部品や技術的な遺物が入った謎の小屋を生成します
			Label: ロケット小屋を生成
		}

		GenJunkmanBase: {
			Tooltip: 荒野または地下にスカベンジャーの要塞拠点を生成します
			Label: ジャンクマンの拠点を生成
		}

		GenWGGCollector: {
			Tooltip: 敵対的なスカベンジャー構造物を世界中にランダム生成します。この設定はレジェンダリー難易度のワールドでのみ有効です。
			Label: スカベンジャー前哨基地を生成
		}

		GenWindGrivenGenerator: {
			Tooltip: 世界中に風力発電機の構造物を配置します
			Label: 風力発電機を生成
		}

		DialogueBox_Scale_Value: {
			Tooltip: 会話ボックス全体の大きさを調整します
			Label: 会話ボックスのサイズ
		}

		QuestLog: {
			Tooltip:
				'''
				有効にすると、クエストログがゲームの進行を案内します
				クエストブックアイテム、インベントリUI、またはホットキーからクエストインターフェースにアクセスし、現在のクエストを確認できます
				デフォルトで有効です。無効にすると全てのクエスト案内が削除されます
				'''
			Label: クエストログの案内
		}

		MuraPosStyleType: {
			Tooltip:
				'''
				プリセット1: 右下
				プリセット2: 左下
				プリセット3: 上部中央
				'''
			Label: UI表示位置選択
		}

		MuraUIStyleType: {
			Tooltip:
				'''
				スタイル1: 洗練 - 頭上浮遊型
				スタイル2: 洗練 - コンパクト型
				スタイル3: クラシック - 頭上浮遊型
				スタイル4: クラシック - コンパクト型
				'''
			Label: UI表示スタイル選択
		}

		BiologyOverhaul: {
			Tooltip:
				'''
				[c/c20909:未完成]
				デフォルトで有効になっており、デスモード時のボスなど、特定のボスのAI行動を変更します
				ゲームの難易度が大幅に上がる可能性があるため、好みに応じて無効にすることができます
				'''
			Label: 生物行動調整機能 [c/06e33f:(実験的機能)]
		}

		LensEasing: {
			Tooltip: 有効にすると、長距離の急速な移動時にレンズが減速し、移動が速すぎる感覚を抑えます
			Label: レンズイージング
		}

		Headers: {
			CWRWorldGen: ワールド生成設定
			CWRUI: UI設定
			CWRWeapon: 武器設定
			CWRSystem: システム設定
		}

		DomainConciseDisplay: {
			Tooltip: 有効にすると、領域内のほとんどの視覚効果が非表示になります
			Label: 領域簡易表示
		}

		MurasamaSpaceFragmentationBool: {
			Tooltip:
				'''
				デフォルトでオンになっており、ポリマー切断エッジが衝撃を強めるための画面粉砕効果を作成します
				オフにすると、これらの効果は無効になり、好みに応じて設定できます
				'''
			Label: ムラサマ空間分割ブール値
		}

		ScreenVibration: {
			Tooltip: オンにすると、一部の攻撃中に画面が振動し、より強い打撃感を感じられます
			Label: 武器画面振動
		}

		WeaponOverhaul: {
			Tooltip:
				'''
				有効にすると、Calamity Modのコンテンツを直接変更します。
				他のCalamityのアドオンModを有効にしている場合、この機能を有効にすることで競合が発生する可能性があります。
				無効にした場合、このModはゲーム内でリセットアイテムを入手できる方法を追加します。
				[c/fff08c: 補足：実際のところ、この機能をオフにすることはお勧めしません。]
				[c/fff08c: 深刻な競合が確認された場合のみ、この機能をオフにすることを推奨します。]
				[c/FF0000: Calamity Overhaulのコンテンツを最適化したい場合は、この機能をオンにしてください！]
				'''
			Label: 武器オーバーホール
		}

		DisplayName: コンテンツ設定
		ConfigChangeSuffix: サーバー設定を変更しました
		ConfigChangePrefix: ユーザー
	}
}

