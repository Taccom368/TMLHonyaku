Tooltips: {
	TreeTutorial: "[c/FFFFFF:{0}]でパッシブツリーを表示"
	KeyNotBoundWarning: "(!) キーが割り当てられていません！ 設定 -> コントロールからキーを設定してください"
	HoldShift: "[c/AAAAAA:Shift]を押したままにするとツリーパッシブが表示されます"
	TreeNodesTitle: "ツリーパッシブ:"
	NoKeyBound: なし
}

Items: {
	AcornofTransmutation: {
		DisplayName: 変異のドングリ
		Tooltip:
			'''
			使用したアイテムのポイントを全て払い戻し、完全に新しいパッシブツリーを再生成する
			このアイテムを持ち、パッシブツリーを持つアイテムを右クリックで使用する
			'''
		Replant: "{0} の根が植え直されました！"
	}

	EssenceofAutumn: {
		DisplayName: 秋のエッセンス
		Tooltip:
			'''
			使用したアイテムのパッシブツリーで割り振られたポイントを全て払い戻す
			このアイテムを持ち、パッシブツリーを持つアイテムを右クリックで使用する
			'''
		Refund: "{0}のパッシブポイントが払い戻されました。"
	}

	FallenLeaf: {
		DisplayName: 落ち葉
		Tooltip: パッシブの払い戻しポイントを1獲得する
	}

	ShiftingLeaf: {
		DisplayName: 揺らぐ落ち葉
		Tooltip: ノードの再抽選ポイントを1獲得する
	}

	LeechItem: {
		DisplayName: ヒル
		Tooltip: ""
		NoEXP:
			'''
			このヒルをアイテムに取り付けると、そのアイテムが獲得したEXPを吸収して保管する
			[c/32FF82:保管: {0} / {1} EXP]
			[c/808080:このヒルを持ち、パッシブツリーを持つアイテムを右クリックで取り付ける]
			ヒルはいつでも取り外すことができる
			EXPを保管したヒルは取り外すと滋養状態になり、
			滋養状態のヒルはアイテムに使用すると保管したEXPを移す
			'''
		WithEXP:
			'''
			[c/32FF82:保管: {0} / {1} EXP]
			[c/808080:このヒルを持ち、パッシブツリーを持つアイテムを右クリックで保管したEXPを移す]
			EXPを移した後、ヒルは消費される
			'''
		HostStatus: "{0} 保管EXP: {1} / {2}"
		HostInstruction: "(Shift + 右クリックで {0} を取り外す)"
		Extract: "{0} を取り外しました！"
		Absorb: "{0} は {1} の保管EXPを吸収しました！"
		Siphon: "{0} は {1} によって吸収されています！"
	}

	FungalLeech: {
		DisplayName: 菌糸のヒル
		Tooltip: ""
	}

	SporelingLeech: {
		DisplayName: 胞子のヒル
		Tooltip: ""
	}

	MutantLeech: {
		DisplayName: 変異したヒル
		Tooltip: ""
	}

	SpectralLeech: {
		DisplayName: 幽体ヒル
		Tooltip: ""
	}

	HeartoftheForest: {
		DisplayName: 森の心臓
		Tooltip:
			'''
			獲得したEXPの20%をパッシブツリーを持つアイテムと共有する
			最大ライフが20増加
			'''
	}

	OvergrownHeartoftheForest: {
		DisplayName: 繁茂した森の心臓
		Tooltip:
			'''
			獲得したEXPの50%をパッシブツリーを持つアイテムと共有する
			最大ライフが40増加
			'''
	}

	ExtractorItem: {
		UsedPrefix: "[Used] {0}"
		FilledPrefix: "[Filled] {0}"
		EmptyTooltip:
			'''
			[c/32FF82:保管: {0} / {1} EXP]
			アイテムからEXPを抽出し、他のアイテムに移すことができる
			EXPを移すと、抽出装置は使用済み状態になり、EXPを抽出できなくなる
			使用済み状態の抽出装置にEXPが残っていない場合、抽出装置が壊れる
			'''
		FullTooltip: "[c/32FF82:保管: {0} / {1} EXP]"
		TransferRules:
			'''
			アイテムからEXPを抽出し、他のアイテムに移すことができる
			EXPを移すと、抽出装置は使用済み状態になり、EXPを抽出できなくなる
			使用済み状態の抽出装置にEXPが残っていない場合、抽出装置が壊れる
			'''
		UsedInfo: 保管したEXPを他のアイテムに移すことができる
		UsedWarning: この抽出装置はEXPの転送に使用されており、抽出できなくなりました
		BreakWarning: 残りのEXPを移すと、この抽出装置が壊れます
		InstructionGive: この抽出装置を持ち、Shiftを押しながらアイテムを右クリックでEXPを移すことができる
		InstructionGeneral: この抽出装置を持ち、アイテムを右クリックでEXPを抽出する / Shiftを押しながら右クリックでEXPを移す
	}

	SapExtractor: {
		Tooltip: ""
		DisplayName: 抽出装置
	}

	HallowedSapExtractor: {
		DisplayName: 神聖な抽出装置
		Tooltip: ""
	}

	CelestialSapExtractor: {
		Tooltip: ""
		DisplayName: 天空の抽出装置
	}
}
