Configs: {
	TreeConfig: {
		RarityRequirementMultiplier: {
			Label: レアリティの倍率
			Tooltip: 
			'''
			高いレアリティのアイテムに対する必要EXPの増加度合いを変更します
			値が高いほどレアリティが必要EXP量に強く影響します (デフォルト: 0.3)
			'''
		}

		ExpRequirementMultiplier: {
			Label: EXPの必要倍率
			Tooltip: 値を高くするとアイテムのLVアップが遅くなります (デフォルト: 0.5)
		}

		GlobalExpMultiplier: {
			Label: 獲得EXPの倍率
			Tooltip: 値を高くすると獲得できるEXPが増加し、低くすると減少します (デフォルト: 1)
		}

		DisplayName: ツリー設定

		MaxItemLevel: {
			Label: アイテムの最大LV
			Tooltip: アイテムの最大LVを変更します (デフォルト: 100)
		}

		AllowModdedAccessories: {
			Label: Mod追加アクセサリースロットでもEXPを獲得できる
			Tooltip: バグが発生する場合はオフにしてください
		}

		ShowHUD: {
			Label: アイテム情報HUDを表示
			Tooltip: ""
		}

		HUDScale: {
			Label: アイテム情報HUDのスケール
			Tooltip: ""
		}

		NodePowerMultiplier: {
			Label: ノードの効果倍率
			Tooltip: 全てのパッシブノードの基本効果を倍率で増加させます (デフォルト: 1)
		}

		EnableAccessoryExp: {
			Label: アクセサリがEXPを獲得できる
			Tooltip: ""
		}

		EnableArmorExp: {
			Label: 防具がEXPを獲得できる
			Tooltip: ""
		}

		AccessorySharingOnly: {
			Label: アクセサリの部分共有
			Tooltip: 
			'''
			オンにすると、アクセサリはダメージを受けても EXPを獲得できず、
			武器や防具による敵の撃破や敵から攻撃を受けるなどで、EXPの一部を獲得します
			'''
		}

		EnableVariableNodeCosts: {
			Label: ノードのコストの変化を有効にする
			Tooltip: 
			'''
			オンにすると、特別なノード（ユニーク/バフ）の必要ポイントが高くなります
			オフにすると、全てのノードのコストが1ポイントになります
			'''
		}
	}
}

UI: {
	TreePassivesHeader: パッシブツリー
	NoNodeSelected: パッシブが割り振られていません
	AvailablePoints: 利用可能なポイント: {0}
	Level: LV: {0} / {1}
	EXP: EXP: {0} / {1} ({2}%)
	MaxLevel: 最大LV
	FallenLeaf: 右クリックでノードを払い戻す
	ShiftingLeaf: Shift + 右クリックでノードを再抽選する
	ShiftingLeaf2: 再抽選したノードはムーンロードを撃破するまで再度再抽選できません
	HUDLocked: ロック
	HUDUnlocked: ロック解除
}

Keybinds: {
	"Open Item Passive Tree.DisplayName": アイテムのパッシブツリーを開く
	"Zoom Out .DisplayName": ズームアウト
}

