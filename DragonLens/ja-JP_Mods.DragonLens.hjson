	ToolConfig: {
		Title: ツール設定

		preloadSpawners: {
			Label: スポナーを事前読み込み
			Tooltip: 
			'''
			スポナーのデータをゲーム起動時に読み込むことで、
			ゲームのフリーズを防ぎますが、ロード時間が長くなる可能性があります
			'''
		}

		preloadAssets: {
			Label: アセットを事前読み込み
			Tooltip: 
			'''
			スポナー用のアセットをゲーム起動時に読み込むことで、ゲームのフリーズを防ぎますが、
			ロード時間が長くなる可能性があります
			'''
		}
	}
